bal defaults only.\")\n        _b = {\"_global\": {\"best_model\":\"Realistic-Vision-V5.1\",\"model_scores\":{},\n                          \"learned_realism\":REALISM_ANCHOR,\"n_top\":0,\"top_faces\":[]}}\n        for _p in PROCEDURES:\n            _b[_p] = {\"best_model\":\"Realistic-Vision-V5.1\",\"model_scores\":{},\n                      \"learned_tokens\":\"\",\"exemplars\":[],\"n_examples\":0}\n        return _b, None\n    df = pd.read_csv(csv_path)\n    df.columns = [str(c).strip() for c in df.columns]\n\n    # --- auto-detect columns (your CSV headers may differ) ---\n    def pick(cands):\n        low = {c.lower(): c for c in df.columns}\n        for want in cands:                              # exact (case-insensitive) first\n            if want in low: return low[want]\n        for want in cands:                              # then substring\n            for lc, orig in low.items():\n                if want in lc: return orig\n        return None\n    C_REF   = pick([\"refined_prompt\",\"refined prompt\",\"final_prompt\",\"optimized_prompt\",\"edited_prompt\",\"prompt\"])\n    C_BASE  = pick([\"base_prompt\",\"base prompt\",\"input_prompt\",\"original_prompt\",\"edit_intent\",\"goal\",\"instruction\"])\n    C_SCORE = pick([\"realism_score\",\"realism\",\"human_score\",\"quality_score\",\"rating\",\"score\"])\n    C_MODEL = pick([\"model_name\",\"model_id\",\"checkpoint\",\"model\",\"engine\"])\n    print(\"Detected columns  :\",\n          {\"prompt\":C_REF, \"base\":C_BASE, \"score\":C_SCORE, \"model\":C_MODEL})\n\n    if C_REF is None or C_SCORE is None:\n        print(\"⚠ Could not find prompt/score columns. Available:\", list(df.columns))\n        print(\"  → falling back to global defaults (notebook still runs).\")\n        _b = {\"_global\": {\"best_model\":\"epiCRealism\",\"model_scores\":{},\n                          \"learned_realism\":REALISM_ANCHOR,\"n_top\":0,\"top_faces\":[]}}\n        for _p in PROCEDURES:\n            _b[_p] = {\"best_model\":\"epiCRealism\",\"model_scores\":{},\n                      \"learned_tokens\":\"\",\"exemplars\":[],\"n_examples\":0}\n        return _b, df\n\n    # drop any repeated-header rows (a cell whose value equals its own column name)\n    mask = pd.Series(True, index=df.index)\n    for col in [C_REF, C_SCORE, C_MODEL, C_BASE]:\n        if col: mask &= (df[col].astype(str).str.strip() != col)\n    df = df[mask].copy()\n\n    df[C_SCORE] = pd.to_numeric(df[C_SCORE], errors=\"coerce\")\n    df = df.dropna(subset=[C_REF, C_SCORE])\n    df[C_REF]  = df[C_REF].astype(str)\n    df[\"__base\"]  = df[C_BASE].astype(str) if C_BASE else df[C_REF]\n    df[\"__model\"] = df[C_MODEL].astype(str) if C_MODEL else \"recorded-model\"\n    # expose canonical names so the rest of the notebook is schema-independent\n    df[\"refined_prompt\"] = df[C_REF]; df[\"base_prompt\"] = df[\"__base\"]\n    df[\"realism_score\"]  = df[C_SCORE]; df[\"model_name\"] = df[\"__model\"]\n\n    smax = float(df[\"realism_score\"].max()) if len(df) else 5.0\n    top  = smax if smax > 0 else 5.0          # \"top score\" adapts if scale isn't 0–5\n\n    gperf = defaultdict(list); pperf = defaultdict(lambda: defaultdict(list))\n    pex = defaultdict(list); ptok = defaultdict(Counter); gtok = Counter()\n\n    # tokens that describe the *edit itself* (per-procedure) vs generic realism/identity\n    GENERIC = (\"skin\",\"pore\",\"photoreal\",\"realistic\",\"portrait\",\"photo\",\"lighting\",\"detail\",\n               \"identity\",\"same person\",\"same face\",\"facial features\",\"natural skin\",\"texture\",\n               \"gender\",\"structure\",\"high quality\",\"sharp focus\",\"dslr\",\"8k\")\n    def is_generic(tag): return any(g in tag for g in GENERIC)\n\n    for _, r in df.iterrows():\n        s = float(r[\"realism_score\"]); gperf[r[\"model_name\"]].append(s)\n        proc, hits = classify_intent(r[\"base_prompt\"], return_hits=True)\n        toks = [t.strip().lower() for t in str(r[\"refined_prompt\"]).split(\",\") if t.strip()]\n        if s >= top:\n            for t in toks:                                   # learn generic realism recipe\n                if is_generic(t): gtok[t]+=1\n        if hits > 0:\n            pperf[proc][r[\"model_name\"]].append(s)\n            if s >= top:\n                pex[proc].append({\"refined_prompt\": r[\"refined_prompt\"], \"model\": r[\"model_name\"]})\n                for t in toks:                               # learn this procedure's winning recipe\n                    if not is_generic(t): ptok[proc][t]+=1\n\n    # best CelebA source faces (which recorded input photos scored highest)\n    top_faces = []\n    if \"celeba_image_path\" in df.columns:\n        cg = df.groupby(\"celeba_image_path\")[\"realism_score\"].agg([\"mean\",\"count\"])\n        cg = cg[cg[\"count\"]>=3].sort_values(\"mean\", ascending=False)\n        top_faces = [os.path.basename(p) for p in cg.head(40).index if isinstance(p,str)]\n\n    gscores = {m: round(statistics.mean(v),3) for m,v in gperf.items()}\n    gbest = max(gscores, key=gscores.get) if gscores else \"epiCRealism\"\n    learned_realism = \", \".join([t for t,_ in gtok.most_common(6)])\n    bank = {\"_global\": {\"best_model\": gbest, \"model_scores\": gscores,\n                        \"learned_realism\": learned_realism or REALISM_ANCHOR,\n                        \"n_top\": int((df[\"realism_score\"]>=top).sum()),\n                        \"top_faces\": top_faces}}\n    for proc in PROCEDURES:\n        perf = pperf.get(proc, {})\n        if perf and sum(len(v) for v in perf.values()) >= 20:\n            ms = {m: round(statistics.mean(v),3) for m,v in perf.items()}; bm = max(ms, key=ms.get)\n        else:\n            ms, bm = gscores, gbest\n        learned = \", \".join([t for t,_ in ptok.get(proc, Counter()).most_common(5)])\n        bank[proc] = {\"best_model\": bm, \"model_scores\": ms, \"learned_tokens\": learned,\n                      \"exemplars\": pex.get(proc, [])[:12], \"n_examples\": len(pex.get(proc, []))}\n    return bank, df\n\nKNOWLEDGE_BANK, RECORD_DF = build_knowledge_bank(CSV_PATH)\nprint(\"Global best model :\", KNOWLEDGE_BANK[\"_global\"][\"best_model\"])\nprint(\"Global model means:\", KNOWLEDGE_BANK[\"_global\"][\"model_scores\"])\nprint(\"Learned realism   :\", KNOWLEDGE_BANK[\"_global\"].get(\"learned_realism\"))\nprint(\"Learned from      :\", KNOWLEDGE_BANK[\"_global\"].get(\"n_top\"), \"top-scored (score 5) recorded results\")\nfor _p in PROCEDURES:\n    lt = KNOWLEDGE_BANK.get(_p, {}).get(\"learned_tokens\")\n    if lt: print(f\"  recipe · {_p}: {lt}\")\nprint(\"Top CelebA faces  :\", len(KNOWLEDGE_BANK[\"_global\"].get(\"top_faces\", [])), \"high-scoring source images\")\nprint(\"Cell 3 complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:07.905156Z","iopub.execute_input":"2026-07-08T17:04:07.905597Z","iopub.status.idle":"2026-07-08T17:04:07.928285Z","shell.execute_reply.started":"2026-07-08T17:04:07.90557Z","shell.execute_reply":"2026-07-08T17:04:07.927278Z"}},"outputs":[{"name":"stdout","text":"⚠ No recorded CSV found — using global defaults only.\nGlobal best model : Realistic-Vision-V5.1\nGlobal model means: {}\nLearned realism   : realistic portrait photo, photorealistic, natural skin texture, visible pores, realistic lighting, high detail\nLearned from      : 0 top-scored (score 5) recorded results\nTop CelebA faces  : 0 high-scoring source images\nCell 3 complete\n","output_type":"stream"}],"execution_count":4},{"id":"e7f1f0c3","cell_type":"code","source":"# ── Cell 3b · LEARNED realism scorer (replaces the random VLM score) ────────────────────\n# The old vlm_score was constant/random. Here we train a small regressor to PREDICT the human\n# realism_score from image features, so the app can rank its own outputs by predicted human rating.\nfrom sklearn.ensemble import GradientBoostingRegressor\nfrom scipy.stats import pearsonr\n\nclass RealismScorer:\n    def __init__(self): self.fitted=False\n    def feats(self, pil):\n        arr=np.array(pil.convert(\"RGB\")); g=cv2.cvtColor(arr,cv2.COLOR_RGB2GRAY)\n        lap=cv2.Laplacian(g,cv2.CV_64F).var()                       # sharpness (blur/grey -> low)\n        R,G_,B=[arr[...,i].astype(np.float64) for i in range(3)]\n        rg=R-G_; yb=0.5*(R+G_)-B\n        colour=np.sqrt(rg.std()**2+yb.std()**2)+0.3*np.sqrt(rg.mean()**2+yb.mean()**2)\n        contrast=float(g.std()); edges=float(cv2.Canny(g,50,150).mean())\n        sat=float(np.array(pil.convert(\"HSV\"))[...,1].mean())\n        hf=float(np.abs(cv2.Laplacian(cv2.GaussianBlur(g,(3,3),0),cv2.CV_64F)).mean())\n        return np.array([lap,colour,contrast,edges,sat,hf],np.float64)\n    def fit(self, imgs, scores):\n        X=np.array([self.feats(i) for i in imgs]); y=np.array(scores,np.float64)\n        self.mu=X.mean(0); self.sd=X.std(0)+1e-6\n        self.model=GradientBoostingRegressor(max_depth=2,n_estimators=150,learning_rate=0.05)\n        self.model.fit((X-self.mu)/self.sd,y); self.fitted=True\n        try:\n            p=self.model.predict((X-self.mu)/self.sd); self.train_r=float(pearsonr(p,y)[0])\n        except Exception: self.train_r=float(\"nan\")\n        return self\n    def predict(self, pil):\n        if not self.fitted: return None\n        x=((self.feats(pil)-self.mu)/self.sd).reshape(1,-1)\n        return float(np.clip(self.model.predict(x)[0]/5.0,0,1))\n\ndef _match_scored_images(df, limit=500):\n    # find generated result images that can be matched to a realism_score in the CSV\n    if df is None: return [],[]\n    cols=[c for c in df.columns if any(k in c.lower() for k in\n          [\"result\",\"output\",\"gen\",\"edited\",\"image_path\",\"filepath\",\"file\"])]\n    roots=[\"/kaggle/input\",\"/kaggle/working\"]; index={}\n    for r in roots:\n        for p in glob.glob(r+\"/**/*.png\",recursive=True)+glob.glob(r+\"/**/*.jpg\",recursive=True):\n            index.setdefault(os.path.basename(p), p)\n    imgs,scores=[],[]\n    for _,row in df.iterrows():\n        if len(imgs)>=limit: break\n        sc=row.get(\"realism_score\");\n        try: sc=float(sc)\n        except Exception: continue\n        cand=None\n        for c in cols:\n            v=str(row.get(c,\"\")); b=os.path.basename(v)\n            if b in index: cand=index[b]; break\n        if cand:\n            try: imgs.append(Image.open(cand).convert(\"RGB\").resize((256,256))); scores.append(sc)\n            except Exception: pass\n    return imgs,scores\n\nSCORER=RealismScorer()\ntry:\n    _imgs,_scores=_match_scored_images(RECORD_DF)\n    if len(_imgs)>=40:\n        SCORER.fit(_imgs,_scores)\n        print(f\"Realism scorer: TRAINED on {len(_imgs)} scored images (train Pearson r={SCORER.train_r:.2f})\")\n    else:\n        print(f\"Realism scorer: only {len(_imgs)} scored images found -> using built-in realism heuristic\")\nexcept Exception as e:\n    print(\"Realism scorer: heuristic fallback -\", str(e)[:70])\nprint(\"Cell 3b complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:12.617328Z","iopub.execute_input":"2026-07-08T17:04:12.617813Z","iopub.status.idle":"2026-07-08T17:04:13.168382Z","shell.execute_reply.started":"2026-07-08T17:04:12.617785Z","shell.execute_reply":"2026-07-08T17:04:13.167584Z"}},"outputs":[{"name":"stdout","text":"Realism scorer: only 0 scored images found -> using built-in realism heuristic\nCell 3b complete\n","output_type":"stream"}],"execution_count":5},{"id":"81d64b72","cell_type":"code","source":"# ── Cell 4 · DSPy prompt optimizer (works with OR without an LM) ────────\nimport dspy\n\nclass PatientGoalToPrompt(dspy.Signature):\n    '''Compose ONE optimized Stable-Diffusion inpainting prompt for a cosmetic-surgery\n    visualization, guided by high-scoring reference prompts. Preserve the patient's identity\n    strictly; realistically simulate ONLY the requested procedure.'''\n    patient_goal    = dspy.InputField(desc=\"what the patient wants changed, in their words\")\n    procedure       = dspy.InputField(desc=\"cosmetic procedure category\")\n    exemplars       = dspy.InputField(desc=\"high-scoring reference prompts for realism scaffolding\")\n    optimized_prompt= dspy.OutputField(desc=\"single positive prompt, comma-separated tags\")\n    negative_prompt = dspy.OutputField(desc=\"single negative prompt, comma-separated tags\")\n\ndef _compose(goal, procedure, bank):\n    cfg = PROCEDURES[procedure]; goal = (goal or \"\").strip()\n    learned_recipe  = bank.get(procedure, {}).get(\"learned_tokens\", \"\")     # this procedure's score-5 recipe\n    learned_realism = bank.get(\"_global\", {}).get(\"learned_realism\", REALISM_ANCHOR)  # mined realism tokens\n    parts = [p for p in [goal, cfg[\"core\"], learned_recipe, learned_realism, IDENTITY_ANCHOR] if p]\n    tags = dict.fromkeys(t.strip() for t in \", \".join(parts).split(\",\") if t.strip())  # de-dupe, keep order\n    pos = \", \".join(list(tags)[:34])                            # cap so CLIP (77 tok) keeps it all\n    return pos, NEGATIVE_ANCHOR\n\nclass ConsultationOptimizer(dspy.Module):\n    def __init__(self, bank):\n        super().__init__(); self.bank = bank; self.predict = dspy.Predict(PatientGoalToPrompt)\n    def forward(self, patient_goal, procedure=None):\n        procedure = classify_intent(patient_goal, procedure)\n        info = self.bank.get(procedure, {})\n        refs = [e[\"refined_prompt\"] for e in info.get(\"exemplars\", [])[:4]]\n        ex_text = \"\\n\".join(f\"- {r}\" for r in refs) or \"(rely on learned realism + identity anchors)\"\n        if dspy.settings.lm is not None:\n            try:\n                o = self.predict(patient_goal=patient_goal, procedure=procedure, exemplars=ex_text)\n                pos = (o.optimized_prompt or \"\").strip(); neg = (o.negative_prompt or \"\").strip()\n                if not pos: raise ValueError(\"empty\")\n                if not neg: neg = NEGATIVE_ANCHOR\n            except Exception:\n                pos, neg = _compose(patient_goal, procedure, self.bank)\n        else:\n            pos, neg = _compose(patient_goal, procedure, self.bank)\n        gbest = self.bank[\"_global\"][\"best_model\"]\n        return dspy.Prediction(\n            procedure=procedure, region=PROCEDURES[procedure][\"region\"],\n            optimized_prompt=pos, negative_prompt=neg,\n            recommended_source_model=info.get(\"best_model\", gbest),\n            recommended_strength=PROCEDURES[procedure][\"strength\"],\n            recommended_blend=PROCEDURES[procedure][\"blend\"],\n            use_reference=PROCEDURES[procedure].get(\"use_reference\", False),\n            ip_scale=PROCEDURES[procedure].get(\"ip_scale\", 0.5),\n            learned_tokens=info.get(\"learned_tokens\", \"\"),\n            model_scores=info.get(\"model_scores\", {}),\n            n_examples=info.get(\"n_examples\", 0))\n\n# --- API KEY IS OPTIONAL --------------------------------------------------\n# Leave USE_LLM = False for an easy, key-free run: DSPy composes prompts with a\n# deterministic composer grounded in your recorded CSV. Set it True (and add an\n# OPENAI_API_KEY secret) only if you want an LLM to write the prompts instead.\nUSE_LLM = False   # <- flip to True only if you added OPENAI_API_KEY\n# --------------------------------------------------------------------------\nLM_ACTIVE = False\ntry:\n    if USE_LLM and os.environ.get(\"OPENAI_API_KEY\"):\n        dspy.configure(lm=dspy.LM(\"openai/gpt-4o-mini\", max_tokens=400))\n        LM_ACTIVE = True\nexcept Exception as e:\n    print(\"LM config skipped:\", str(e)[:80])\nprint(\"DSPy mode    :\", \"LLM (OPENAI_API_KEY)\" if LM_ACTIVE\n      else \"key-free deterministic composer (grounded in recorded CSV)\")\n\nOPTIMIZER = ConsultationOptimizer(KNOWLEDGE_BANK)\n\n# --- Optional DSPy optimization (BootstrapFewShot) using score-5 rows as training pairs ---\ndef build_trainset(df, max_per=6):\n    ex, cnt = [], defaultdict(int)\n    if df is None or not {\"realism_score\",\"base_prompt\",\"refined_prompt\"}.issubset(df.columns):\n        return ex\n    top = float(df[\"realism_score\"].max()) or 5.0\n    for _, r in df[df[\"realism_score\"] >= top].iterrows():\n        proc = classify_intent(r[\"base_prompt\"])\n        if cnt[proc] >= max_per: continue\n        cnt[proc]+=1\n        ex.append(dspy.Example(patient_goal=r[\"base_prompt\"], procedure=proc, exemplars=\"\",\n                               optimized_prompt=r[\"refined_prompt\"], negative_prompt=NEGATIVE_ANCHOR\n                               ).with_inputs(\"patient_goal\",\"procedure\",\"exemplars\"))\n    return ex\n\nif LM_ACTIVE:\n    try:\n        from dspy.teleprompt import BootstrapFewShot\n        def _metric(ex, pred, trace=None):\n            p = (getattr(pred,\"optimized_prompt\",\"\") or \"\").lower()\n            return float(sum(t in p for t in [\"identity\",\"skin\",\"realistic\",\"same\"]) >= 2)\n        trainset = build_trainset(RECORD_DF)\n        OPTIMIZER = BootstrapFewShot(metric=_metric, max_bootstrapped_demos=3).compile(\n            OPTIMIZER, trainset=trainset)\n        print(\"✓ DSPy optimized with\", len(trainset), \"recorded exemplars\")\n    except Exception as e:\n        print(\"DSPy optimization skipped:\", str(e)[:80])\n\n_demo = OPTIMIZER(patient_goal=\"reduce the hump on my nose and refine the tip\")\nprint(\"LM active:\", LM_ACTIVE)\nprint(\"Sample →\", _demo.procedure, \"| model:\", _demo.recommended_source_model,\n      \"| strength:\", _demo.recommended_strength)\nprint(\"Prompt →\", _demo.optimized_prompt[:160], \"...\")\nprint(\"Cell 4 complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:18.095166Z","iopub.execute_input":"2026-07-08T17:04:18.096399Z","iopub.status.idle":"2026-07-08T17:04:18.653102Z","shell.execute_reply.started":"2026-07-08T17:04:18.096368Z","shell.execute_reply":"2026-07-08T17:04:18.652482Z"}},"outputs":[{"name":"stdout","text":"DSPy mode    : key-free deterministic composer (grounded in recorded CSV)\nLM active: False\nSample → Rhinoplasty (nose reshaping) | model: Realistic-Vision-V5.1 | strength: 0.42\nPrompt → reduce the hump on my nose and refine the tip, smaller thinner nose, narrow slim nasal bridge, refined pointed nasal tip, pinched narrower nostrils, straight no ...\nCell 4 complete\n","output_type":"stream"}],"execution_count":6},{"id":"8f1ea8d3","cell_type":"code","source":"# ── Cell 5 · MediaPipe FaceMesh landmark + region-mask engine ──────────\n# Backend priority: legacy solutions.face_mesh → tasks FaceLandmarker → OpenCV Haar (always works)\nNOSE_IDX = [1,2,4,5,6,19,44,45,51,94,97,98,115,122,125,168,195,197,236,274,275,281,344,351,354,440,220,305]\nFOREHEAD_IDX = [10,338,297,332,284,251,21,54,103,67,109,151,108,337,69,299,104,333,\n                105,334,66,296,65,295,107,336,9,8]\n# cheeks as TWO separate groups so the convex hull never bridges across the nose\nLEFT_CHEEK_IDX  = [116,117,118,119,120,100,142,36,205,50,187,123,147,213]\nRIGHT_CHEEK_IDX = [345,346,347,348,349,329,371,266,425,280,411,352,376,433]\n# jawline / jowls as TWO side groups so the hull never covers the mouth (protects teeth)\nLEFT_JAW_IDX  = [172,136,150,149,176,58,132,215,177,147,213,123]\nRIGHT_JAW_IDX = [397,365,379,378,400,288,361,435,401,366,433,352]\n# chin bottom points — used as the TOP edge of the under-chin/neck band (extended downward)\nCHIN_IDX = [152,148,176,377,400,149,378,150,379,175,171,396]\n# full face oval (for whole-face edits: slimming, facelift) and lower-face oval (double chin)\nFACE_OVAL_IDX = [10,338,297,332,284,251,389,356,454,323,361,288,397,365,379,378,400,377,152,148,176,\n                 149,150,136,172,58,132,93,234,127,162,21,54,103,67,109]\nLOWERFACE_IDX = [234,93,132,58,172,136,150,149,176,148,152,377,400,378,379,365,397,288,361,323,454,\n                 425,205,50,101,36,206,203,423,266,280,411]\n\n# wrinkle zones for Botox: forehead + under-eyes + nasolabial (smile) lines\nUNDER_EYE_L_IDX = [230,231,232,233,228,229,25,110,24,23,22,26,112]\nUNDER_EYE_R_IDX = [450,451,452,453,448,449,255,339,254,253,252,256,341]\nNASOLABIAL_L_IDX = [129,203,206,216,207,187,205,50,101,118,117]\nNASOLABIAL_R_IDX = [358,423,426,436,427,411,425,280,330,347,346]\n\n# region -> list of landmark groups (unioned hulls). Broad regions include a background margin\n# so diffusion can actually reshape the silhouette (this is how slimming works, no warp).\nREGION_PARTS = {\n    \"nose\":       [NOSE_IDX],\n    \"forehead\":   [FOREHEAD_IDX],\n    \"face\":       [FACE_OVAL_IDX],\n    \"lower_face\": [LOWERFACE_IDX],\n    \"jowls\":      [LEFT_JAW_IDX, RIGHT_JAW_IDX, NASOLABIAL_L_IDX, NASOLABIAL_R_IDX],  # facelift target\n    \"wrinkles\":   [FOREHEAD_IDX, UNDER_EYE_L_IDX, UNDER_EYE_R_IDX,\n                   NASOLABIAL_L_IDX, NASOLABIAL_R_IDX],\n}\nREGION_NECK = {\"lower_face\"}          # lower-face edits extend down into the neck\n# how far each region grows outward (margin of background) + how hard the edge is\nREGION_GROW = {\"face\":0.16,\"lower_face\":0.14,\"nose\":0.10,\"forehead\":0.10,\"wrinkles\":0.06,\"jowls\":0.10}\n\n_BACKEND=None; _FM=None; _TASK=None\ndef _init_backend():\n    global _BACKEND,_FM,_TASK\n    if _BACKEND is not None: return _BACKEND\n    try:\n        import mediapipe as mp\n        _FM = mp.solutions.face_mesh.FaceMesh(static_image_mode=True, max_num_faces=1,\n                                              refine_landmarks=True, min_detection_confidence=0.4)\n        _BACKEND=\"solutions\"; return _BACKEND\n    except Exception: pass\n    try:\n        import mediapipe as mp, urllib.request\n        from mediapipe.tasks import python as mpp\n        from mediapipe.tasks.python import vision as mpv\n        mp_path = str(WORK/\"face_landmarker.task\")\n        if not os.path.exists(mp_path):\n            urllib.request.urlretrieve(\n                \"https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/\"\n                \"float16/1/face_landmarker.task\", mp_path)\n        _TASK = mpv.FaceLandmarker.create_from_options(\n            mpv.FaceLandmarkerOptions(base_options=mpp.BaseOptions(model_asset_path=mp_path), num_faces=1))\n        _BACKEND=\"tasks\"; return _BACKEND\n    except Exception: pass\n    _BACKEND=\"opencv\"; return _BACKEND\n\n_HAAR = cv2.CascadeClassifier(cv2.data.haarcascades + \"haarcascade_frontalface_default.xml\")\n\ndef get_landmarks(pil):\n    b=_init_backend(); rgb=np.array(pil.convert(\"RGB\")); H,W=rgb.shape[:2]\n    if b==\"solutions\":\n        r=_FM.process(rgb)\n        if not r.multi_face_landmarks: return None,b\n        return np.array([[p.x*W,p.y*H] for p in r.multi_face_landmarks[0].landmark],np.float32),b\n    if b==\"tasks\":\n        import mediapipe as mp\n        r=_TASK.detect(mp.Image(image_format=mp.ImageFormat.SRGB,data=rgb))\n        if not r.face_landmarks: return None,b\n        return np.array([[p.x*W,p.y*H] for p in r.face_landmarks[0]],np.float32),b\n    return None,b\n\ndef _haar_rect(pil):\n    W,H=pil.size; gray=cv2.cvtColor(np.array(pil.convert(\"RGB\")),cv2.COLOR_RGB2GRAY)\n    f=_HAAR.detectMultiScale(gray,1.05,4,minSize=(40,40))\n    if len(f)==0:\n        fw,fh=int(W*0.6),int(H*0.6); return ((W-fw)//2,int(H*0.18),fw,fh)\n    return tuple(max(f,key=lambda r:r[2]*r[3]))\n\ndef _hull(size, pts, idxs, dilate=0.10):\n    W,H=size; m=Image.new(\"L\",(W,H),0)\n    idxs=[i for i in idxs if i < len(pts)]\n    if not idxs: return m\n    sel=pts[idxs]; hull=cv2.convexHull(sel.astype(np.int32))\n    cx,cy=sel[:,0].mean(),sel[:,1].mean()\n    grown=[[cx+(x-cx)*(1+dilate),cy+(y-cy)*(1+dilate)] for x,y in hull.reshape(-1,2)]\n    ImageDraw.Draw(m).polygon([tuple(p) for p in grown],fill=255)\n    return m\n\ndef detect_wrinkles(pil, pts):\n    # THIN-LINE wrinkle finder: black-hat isolates the actual wrinkle LINES; we mask only those\n    # (slightly dilated) so Botox erases lines while keeping real skin/pores -> no waxy over-smoothing.\n    W,H=pil.size; gray=cv2.cvtColor(np.array(pil.convert(\"RGB\")),cv2.COLOR_RGB2GRAY)\n    zones=Image.new(\"L\",(W,H),0)\n    for g in [FOREHEAD_IDX,UNDER_EYE_L_IDX,UNDER_EYE_R_IDX,NASOLABIAL_L_IDX,NASOLABIAL_R_IDX]:\n        h=_hull((W,H),pts,g,dilate=0.08); zones=Image.fromarray(np.maximum(np.array(zones),np.array(h)))\n    z=np.array(zones)>0\n    k=cv2.getStructuringElement(cv2.MORPH_ELLIPSE,(7,7))\n    black=cv2.morphologyEx(gray,cv2.MORPH_BLACKHAT,k)                 # dark thin lines pop out\n    thr=max(10,int(np.percentile(black[z],88))) if z.any() else 12\n    lines=((black>=thr)&z).astype(np.uint8)*255\n    lines=cv2.dilate(lines,cv2.getStructuringElement(cv2.MORPH_ELLIPSE,(5,5)),1)  # just thicken the lines\n    cov=(lines>0).mean()\n    if cov < 0.006:                       # no clear wrinkles found -> fall back to a soft zone smoothing\n        return Image.fromarray((np.array(zones)*0.5).astype(np.uint8)).filter(ImageFilter.GaussianBlur(9))\n    return Image.fromarray(lines).filter(ImageFilter.GaussianBlur(3))\n\nPROTECT_IDX = [33,133,157,158,159,160,161,173,246,7,145,153,\n               263,362,384,385,386,387,388,398,466,249,374,380,\n               1,2,4,5,6,168,197,195,98,327]      # eyes + nose = keep exactly (identity)\n\ndef _poly_mask(size, pts, groups, region, grow, blur=6):\n    W,H=size; m=Image.new(\"L\",(W,H),0)\n    for g in groups:\n        h=_hull(size,pts,g,dilate=grow); m=Image.fromarray(np.maximum(np.array(m),np.array(h)))\n    if region in REGION_NECK:                          # extend down into the neck (double chin)\n        chin=pts[[i for i in CHIN_IDX if i<len(pts)]]\n        if len(chin):\n            cx=float(chin[:,0].mean()); cy=float(chin[:,1].max())\n            jaw_w=float(chin[:,0].max()-chin[:,0].min()) or W*0.25; dy=jaw_w*1.05\n            ImageDraw.Draw(m).ellipse([cx-jaw_w*0.8,cy-dy*0.15,cx+jaw_w*0.8,min(H,cy+dy)],fill=255)\n    if region in (\"face\",\"lower_face\"):                # punch out eyes+nose so identity stays exact\n        core=_hull(size,pts,PROTECT_IDX,dilate=0.10)\n        core=core.filter(ImageFilter.GaussianBlur(6))\n        m=Image.fromarray(np.clip(np.array(m).astype(int)-np.array(core).astype(int),0,255).astype(np.uint8))\n    return m.filter(ImageFilter.GaussianBlur(blur))\n\ndef _box_mask(pil,region,blur=8):\n    W,H=pil.size; m=Image.new(\"L\",(W,H),0); d=ImageDraw.Draw(m); fx,fy,fw,fh=_haar_rect(pil)\n    pad=int(fw*0.14)\n    if region==\"nose\":\n        cx,cy=fx+fw//2,fy+int(fh*0.50); rx,ry=int(fw*0.22),int(fh*0.24)\n        d.ellipse([cx-rx,cy-ry,cx+rx,cy+ry],fill=255)\n    elif region==\"forehead\":\n        d.rectangle([fx+int(fw*0.06),max(0,fy-int(fh*0.02)),fx+int(fw*0.94),fy+int(fh*0.30)],fill=255)\n    elif region==\"wrinkles\":\n        d.rectangle([fx+int(fw*0.08),fy+int(fh*0.03),fx+int(fw*0.92),fy+int(fh*0.30)],fill=255)\n        for cx in (fx+int(fw*0.32),fx+int(fw*0.68)):\n            d.ellipse([cx-int(fw*0.15),fy+int(fh*0.40),cx+int(fw*0.15),fy+int(fh*0.52)],fill=255)\n        for cx in (fx+int(fw*0.34),fx+int(fw*0.66)):\n            d.ellipse([cx-int(fw*0.11),fy+int(fh*0.58),cx+int(fw*0.11),fy+int(fh*0.74)],fill=255)\n    elif region==\"lower_face\":\n        d.ellipse([max(0,fx-pad),fy+int(fh*0.42),min(W,fx+fw+pad),min(H,fy+fh+int(fh*0.30))],fill=255)\n    elif region==\"jowls\":\n        for cx in (fx+int(fw*0.18),fx+int(fw*0.82)):          # jaw/jowl sides\n            d.ellipse([cx-int(fw*0.16),fy+int(fh*0.52),cx+int(fw*0.16),fy+int(fh*0.82)],fill=255)\n        for cx in (fx+int(fw*0.36),fx+int(fw*0.64)):          # nasolabial folds\n            d.ellipse([cx-int(fw*0.08),fy+int(fh*0.52),cx+int(fw*0.08),fy+int(fh*0.70)],fill=255)\n    else:  # face (whole face + background margin so slimming can reshape the outline)\n        d.ellipse([max(0,fx-pad),max(0,fy-int(fh*0.06)),min(W,fx+fw+pad),min(H,fy+fh+int(fh*0.10))],fill=255)\n    return m.filter(ImageFilter.GaussianBlur(blur))\n\ndef build_region_mask(pil,region):\n    pts,_=get_landmarks(pil)\n    if pts is not None and region==\"wrinkles\":\n        return detect_wrinkles(pil,pts)\n    if pts is not None and region in REGION_PARTS:\n        return _poly_mask(pil.size,pts,REGION_PARTS[region],region,REGION_GROW.get(region,0.12))\n    return _box_mask(pil,region)\n\ndef mask_overlay(pil,mask,color=(255,80,20)):\n    # SHARP, clearly-visible marking (hard fill + bright outline) — no soft fade\n    base=np.array(pil.convert(\"RGB\")); a=(np.array(mask.convert(\"L\"))>90)\n    out=base.copy(); out[a]=(0.55*np.array(color)+0.45*base[a]).astype(np.uint8)\n    edge=cv2.morphologyEx(a.astype(np.uint8),cv2.MORPH_GRADIENT,\n                          cv2.getStructuringElement(cv2.MORPH_ELLIPSE,(5,5)))\n    out[edge>0]=color\n    return Image.fromarray(out)\n\ndef composite_identity_safe(orig,gen,mask,blend=1.0):\n    a=np.asarray(mask.convert(\"L\"),np.float32)[:,:,None]/255.0*float(blend)\n    o=np.asarray(orig.convert(\"RGB\"),np.float32)\n    g=np.asarray(gen.convert(\"RGB\").resize(orig.size),np.float32)\n    return Image.fromarray((a*g+(1-a)*o).clip(0,255).astype(np.uint8))\n\nIDCORE_IDX = [33,133,362,263,1,2,168,6,197,195,98,327]   # eyes + nose bridge = identity core\n\n# ---- SSIM: structural-similarity quality + identity metric ----\ntry:\n    from skimage.metrics import structural_similarity as _sk_ssim\n    _HAS_SK=True\nexcept Exception:\n    _HAS_SK=False\ndef _ssim_flat(a,b):\n    a=a.astype(np.float64); b=b.astype(np.float64)\n    mu_a,mu_b=a.mean(),b.mean(); va,vb=a.var(),b.var(); cov=((a-mu_a)*(b-mu_b)).mean()\n    c1=(0.01*255)**2; c2=(0.03*255)**2\n    return float(((2*mu_a*mu_b+c1)*(2*cov+c2))/((mu_a**2+mu_b**2+c1)*(va+vb+c2)+1e-9))\ndef ssim_regions(orig,edited,mask):\n    a=np.array(orig.convert(\"L\")); b=np.array(edited.convert(\"L\").resize(orig.size))\n    m=np.array(mask.convert(\"L\").resize(orig.size))>128\n    if _HAS_SK:\n        full=_sk_ssim(a,b,data_range=255,full=True)[1]\n        inside =float(full[m].mean())  if m.any()     else 1.0\n        outside=float(full[~m].mean()) if (~m).any()  else 1.0\n        overall=float(full.mean())\n    else:\n        inside =_ssim_flat(a[m],b[m])   if m.any()    else 1.0\n        outside=_ssim_flat(a[~m],b[~m]) if (~m).any() else 1.0\n        overall=_ssim_flat(a,b)\n    return {\"ssim_overall\":round(overall,4),\"ssim_identity_outside\":round(outside,4),\n            \"ssim_inside\":round(inside,4),\"region_change\":round(1.0-inside,4)}\n\ndef landmark_identity_check(orig,edited):\n    p0,b=get_landmarks(orig); p1,_=get_landmarks(edited)\n    if p0 is None or p1 is None: return {\"face_found\":0,\"landmark_shift_mean\":-1.0,\"backend\":b}\n    n=min(len(p0),len(p1)); diag=math.hypot(*orig.size)\n    s=np.linalg.norm(p0[:n]-p1[:n],axis=1)/diag\n    return {\"face_found\":1,\"landmark_shift_mean\":float(s.mean()),\n            \"landmark_shift_max\":float(s.max()),\"landmark_count\":int(n),\"backend\":b}\n\ndef idcore_ssim(orig,edited):\n    p0,_=get_landmarks(orig)\n    a=np.array(orig.convert(\"L\")); b=np.array(edited.convert(\"L\").resize(orig.size))\n    if p0 is not None and len(p0)>200:\n        idx=[i for i in IDCORE_IDX if i<len(p0)]; pc=p0[idx]\n        x0,y0=int(pc[:,0].min())-10,int(pc[:,1].min())-10\n        x1,y1=int(pc[:,0].max())+10,int(pc[:,1].max())+10\n        x0,y0=max(0,x0),max(0,y0); x1,y1=min(a.shape[1],x1),min(a.shape[0],y1)\n        a,b=a[y0:y1,x0:x1],b[y0:y1,x0:x1]\n    if a.size==0: return 1.0\n    if _HAS_SK: return float(_sk_ssim(a,b,data_range=255))\n    return _ssim_flat(a,b)\n\nprint(\"Landmark backend:\", _init_backend(), \"| SSIM:\", \"skimage\" if _HAS_SK else \"builtin\")\nprint(\"Cell 5 complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:24.898537Z","iopub.execute_input":"2026-07-08T17:04:24.898797Z","iopub.status.idle":"2026-07-08T17:04:25.231629Z","shell.execute_reply.started":"2026-07-08T17:04:24.898778Z","shell.execute_reply":"2026-07-08T17:04:25.230748Z"}},"outputs":[{"name":"stdout","text":"Landmark backend: tasks | SSIM: skimage\nCell 5 complete\n","output_type":"stream"},{"name":"stderr","text":"WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nW0000 00:00:1783530265.155915     163 face_landmarker_graph.cc:174] Sets FaceBlendshapesGraph acceleration to xnnpack by default.\nINFO: Created TensorFlow Lite XNNPACK delegate for CPU.\nW0000 00:00:1783530265.199871     166 inference_feedback_manager.cc:114] Feedback manager requires a model with a single signature inference. Disabling support for feedback tensors.\nW0000 00:00:1783530265.223097     165 inference_feedback_manager.cc:114] Feedback manager requires a model with a single signature inference. Disabling support for feedback tensors.\n","output_type":"stream"}],"execution_count":7},{"id":"c16c93ee","cell_type":"code","source":"# ── Cell 6 · Inpainting models + ONE-SHOT generation ───────────────────\nfrom diffusers import (StableDiffusionInpaintPipeline, StableDiffusionXLInpaintPipeline,\n                       EulerDiscreteScheduler)\n\n# Only known-good inpaint checkpoints (DSPy's model *recommendation* is shown as info).\nMODEL_REGISTRY = {\n    \"Realistic-Vision (SD1.5 inpaint)\": dict(\n        repo=\"Uminosachi/realisticVisionV51_v51VAE-inpainting\", size=(512,512),\n        steps=30, guidance=7.0, is_xl=False),\n    \"SDXL (inpaint, max detail)\": dict(\n        repo=\"diffusers/stable-diffusion-xl-1.0-inpainting-0.1\", size=(1024,1024),\n        steps=28, guidance=7.5, is_xl=True),\n}\nDEFAULT_MODEL = \"Realistic-Vision (SD1.5 inpaint)\"\n_PIPES = {}\n# ROOT-CAUSE FIX: loading IP-Adapter globally swaps the UNet attention processors, so any\n# procedure that does NOT pass a reference image gets corrupted (grey/black) output. We therefore\n# keep IP-Adapter OFF by default and learn the surgery look through the train-once LoRA instead\n# (Cell 6b). If you enable it, generation neutralises it (scale 0 + neutral image) when unused.\nUSE_IP_ADAPTER = False\n_IP_OK = {}\nTRAINED_DIR = WORK / \"trained_surgery\"; TRAINED_DIR.mkdir(exist_ok=True, parents=True)\n\n# ---- TRAIN ONCE: distill each surgery dataset into a cached reference set ----\n# Built a single time, then reused for every generation. Rhinoplasty learns the \"after\" nose look\n# from morlako/rhinoplasty_lora (+ Roboflow if present); Botox learns firm skin from the Botox afters.\ndef _after_only(paths):\n    a=[p for p in paths if \"after\" in os.path.basename(p).lower() or \"/after\" in p.lower()]\n    return a or paths\n_TRAINED_REFS = None\ndef trained_refs():\n    global _TRAINED_REFS\n    if _TRAINED_REFS is not None: return _TRAINED_REFS\n    def load(paths, n=6):\n        out=[]\n        for p in _after_only(paths)[:n]:\n            try: out.append(Image.open(p).convert(\"RGB\").resize((256,256)))\n            except Exception: pass\n        return out\n    _TRAINED_REFS = {\n        \"Rhinoplasty (nose reshaping)\": load(RHINO_IMAGES, 8),\n        \"Botox / wrinkle softening\":    load(BOTOX_AFTER, 8),\n    }\n    for k,v in _TRAINED_REFS.items(): print(f\"Trained refs  : {k.split('/')[0].strip()} -> {len(v)} dataset images\")\n    return _TRAINED_REFS\n\ndef _lora_is_safe(pipe):\n    # quick probe: inpaint a patch on a plain skin-tone image; a broken LoRA returns flat grey / NaN\n    try:\n        img=Image.new(\"RGB\",(256,256),(150,120,110))\n        m=Image.new(\"L\",(256,256),0); ImageDraw.Draw(m).ellipse([88,88,168,168],fill=255)\n        with torch.inference_mode():\n            out=pipe(prompt=\"a close up photo of skin, face\", image=img, mask_image=m,\n                     strength=0.7, num_inference_steps=6, guidance_scale=6.0,\n                     generator=torch.Generator(device=DEVICE).manual_seed(0)).images[0]\n        a=np.array(out.convert(\"RGB\")).astype(np.float32)\n        if not np.isfinite(a).all(): return False\n        patch=a[100:156,100:156]\n        return float(patch.std()) > 6.0          # real texture, not a flat grey fill\n    except Exception:\n        return False\n\ndef get_pipe(name):\n    if name in _PIPES: return _PIPES[name]\n    if len(_PIPES) >= 1:                       # keep 1 pipe hot (T4 memory)\n        _PIPES.clear(); gc.collect()\n        if DEVICE==\"cuda\": torch.cuda.empty_cache()\n    cfg = MODEL_REGISTRY[name]\n    cls = StableDiffusionXLInpaintPipeline if cfg[\"is_xl\"] else StableDiffusionInpaintPipeline\n    kw = dict(torch_dtype=DTYPE, use_safetensors=True)\n    if DEVICE==\"cuda\" and cfg[\"is_xl\"]: kw[\"variant\"]=\"fp16\"\n    pipe = cls.from_pretrained(cfg[\"repo\"], **kw)\n    pipe.scheduler = EulerDiscreteScheduler.from_config(pipe.scheduler.config)\n    pipe.to(DEVICE)\n    if DEVICE==\"cuda\":\n        pipe.enable_attention_slicing()\n        try: pipe.enable_vae_tiling()\n        except Exception: pass\n    # auto-load a trained LoRA if you ran the optional training cell — but VERIFY it first.\n    # A bad LoRA corrupts every inpaint into grey, so we test it on a probe and unload if broken.\n    lora=str(TRAINED_DIR/\"surgery_lora.safetensors\")\n    if os.path.exists(lora):\n        try:\n            pipe.load_lora_weights(lora)\n            if _lora_is_safe(pipe):\n                print(\"Trained LoRA  : loaded + verified\", lora)\n            else:\n                pipe.unload_lora_weights(); print(\"Trained LoRA  : DISABLED — it produced artifacts, using plain inpaint. Retrain with Cell 6b.\")\n        except Exception as e:\n            try: pipe.unload_lora_weights()\n            except Exception: pass\n            print(\"Trained LoRA  : skip -\", str(e)[:60])\n    _IP_OK[name]=False\n    if USE_IP_ADAPTER and not cfg[\"is_xl\"]:\n        try:\n            pipe.load_ip_adapter(\"h94/IP-Adapter\", subfolder=\"models\",\n                                 weight_name=\"ip-adapter_sd15.bin\")\n            pipe.set_ip_adapter_scale(0.0)         # neutral by default; raised only when a ref is used\n            _IP_OK[name]=True\n            print(\"IP-Adapter    : loaded (surgery datasets steer rhinoplasty + botox)\")\n        except Exception as e:\n            print(\"IP-Adapter    : unavailable, using plain inpaint —\", str(e)[:60])\n    _PIPES[name]=pipe; return pipe\n\ndef reference_for(procedure):\n    refs = trained_refs().get(procedure) or []\n    return refs or None                        # a LIST of dataset images -> IP-Adapter averages them\n\ndef center_square(img):\n    w,h=img.size; s=min(w,h); return img.crop(((w-s)//2,(h-s)//2,(w-s)//2+s,(h-s)//2+s))\n\n# ---- Cosmetic realism scoring + artifact/corruption detection (kills grey/black outputs) ----\ndef _region_stats(img, mask):\n    arr=np.array(img.convert(\"RGB\")); m=np.array(mask.convert(\"L\").resize(img.size))>90\n    m=cv2.erode(m.astype(np.uint8), np.ones((9,9),np.uint8), 1).astype(bool)   # interior only (skip edge)\n    if m.sum()<50: return 0.5, 200.0\n    hsv=np.array(img.convert(\"HSV\")); sat=float(hsv[:,:,1][m].mean())/255.0\n    lap=cv2.Laplacian(cv2.cvtColor(arr,cv2.COLOR_RGB2GRAY),cv2.CV_64F)\n    return sat, float(lap[m].var())\n\ndef is_corrupt(img, mask):\n    arr=np.array(img.convert(\"RGB\"))\n    if not np.isfinite(arr).all(): return True                # NaN/inf -> grey/black\n    sat, sharp = _region_stats(img, mask)\n    return (sat < 0.08 and sharp < 25) or sharp < 6           # flat grey / near-constant patch\n\ndef realism_of(img, mask):                                    # 0..1 cosmetic realism proxy\n    sat, sharp = _region_stats(img, mask)\n    return float(np.clip(0.55*np.tanh(sharp/120.0)+0.45*np.clip(sat/0.35,0,1),0,1))\n\n# ---- DSPy prompt/parameter MEMORY: remember what produced the best results, reuse next time ----\nMEM_PATH = TRAINED_DIR / \"prompt_memory.json\"\ndef load_memory():\n    try: return json.loads(MEM_PATH.read_text())\n    except Exception: return {}\ndef save_memory(m):\n    try: MEM_PATH.write_text(json.dumps(m, indent=2))\n    except Exception: pass\nPROMPT_MEMORY = load_memory()\n\ndef one_shot_consult(image, patient_goal, procedure, model_name, strength_override,\n                     steps_override, seed, candidates=2):\n    '''DSPy prompt -> region mask -> inpaint candidates -> realism+SSIM scoring -> best, artifact-safe.'''\n    if image is None:\n        return None, None, \"Please upload a photo or tap Load demo face first.\", None, None\n    plan = OPTIMIZER(patient_goal=patient_goal, procedure=procedure)\n    cfg  = MODEL_REGISTRY[model_name]\n    W,H  = cfg[\"size\"]\n    orig = center_square(image.convert(\"RGB\")).resize((W,H), Image.LANCZOS)\n\n    mask    = build_region_mask(orig, plan.region)\n    overlay = mask_overlay(orig, mask)\n    # AUTOMATIC PARAMETER SELECTION: if memory holds a strength that worked well before, use it\n    mem = PROMPT_MEMORY.get(plan.procedure, {})\n    strength = (float(strength_override) if strength_override\n                else float(mem.get(\"strength\", plan.recommended_strength)))\n    strength = max(0.25, min(0.85, strength))\n    blend    = float(plan.recommended_blend)\n    steps    = int(steps_override) if steps_override else int(cfg[\"steps\"])\n    n_cand   = max(1, min(4, int(candidates)))\n\n    try:\n        pipe = get_pipe(model_name)\n        ref = reference_for(plan.procedure) if (_IP_OK.get(model_name) and plan.use_reference) else None\n        if _IP_OK.get(model_name):                        # neutralise IP-Adapter unless a ref is used\n            try: pipe.set_ip_adapter_scale(float(plan.ip_scale) if ref is not None else 0.0)\n            except Exception: pass\n        def _gen(gseed, guidance, use_ref):\n            kw = dict(prompt=plan.optimized_prompt, negative_prompt=plan.negative_prompt,\n                      image=orig, mask_image=mask, strength=strength,\n                      num_inference_steps=steps, guidance_scale=float(guidance),\n                      generator=torch.Generator(device=DEVICE).manual_seed(gseed))\n            if ref is not None and use_ref: kw[\"ip_adapter_image\"]=ref\n            with torch.inference_mode():\n                try:\n                    return pipe(**kw).images[0]\n                except Exception:\n                    kw.pop(\"ip_adapter_image\", None)\n                    try: pipe.set_ip_adapter_scale(0.0)\n                    except Exception: pass\n                    return pipe(**kw).images[0]\n        cand = []\n        for k in range(n_cand):\n            gen = _gen(int(seed)+k*101, cfg[\"guidance\"], True)\n            res = composite_identity_safe(orig, gen, mask, blend)\n            corrupt = is_corrupt(gen, mask)\n            realism = 0.0 if corrupt else (SCORER.predict(res) if SCORER.fitted else realism_of(gen, mask))\n            core = idcore_ssim(orig, res)\n            reg  = ssim_regions(orig, res, mask)[\"region_change\"]\n            # rank: not-corrupt >> identity kept >> realistic >> visibly changed\n            score = (0 if corrupt else 100) + (10 if core>=0.55 else 0) + 3*realism + reg\n            cand.append((score, res, core, reg, realism, corrupt, int(seed)+k*101))\n        cand.sort(key=lambda t:t[0], reverse=True)\n        best = cand[0]\n        # SAFE RETRY: if the best is still corrupt, regenerate once with IP off + gentler guidance\n        if best[5]:\n            gen = _gen(int(seed)+999, max(4.5, cfg[\"guidance\"]-2.0), False)\n            res = composite_identity_safe(orig, gen, mask, blend)\n            best = (0, res, idcore_ssim(orig,res), ssim_regions(orig,res,mask)[\"region_change\"],\n                    realism_of(gen,mask), is_corrupt(gen,mask), int(seed)+999)\n        _, result, core_ssim, region_change, realism, corrupt, used_seed = best\n    except RuntimeError as e:\n        if \"out of memory\" in str(e).lower():\n            gc.collect(); torch.cuda.empty_cache()\n            return None, overlay, \"The GPU ran out of memory. Try the SD1.5 model or fewer steps.\", None, None\n        return None, overlay, f\"Something went wrong during generation: {e}\", None, None\n\n    idc = landmark_identity_check(orig, result)\n    # CONFIDENCE: identity kept + realistic + actually changed (0..1)\n    confidence = round(float(np.clip(0.45*core_ssim + 0.35*realism +\n                                     0.20*min(region_change/0.25,1.0), 0, 1)), 2)\n    # MEMORY: remember settings that produced a confident, realistic, non-corrupt result\n    if (not corrupt) and confidence >= 0.6 and confidence > mem.get(\"confidence\", 0):\n        PROMPT_MEMORY[plan.procedure] = {\"strength\": round(strength,3),\n            \"prompt\": plan.optimized_prompt, \"confidence\": confidence, \"realism\": round(realism,3)}\n        save_memory(PROMPT_MEMORY)\n    ssim = ssim_regions(orig, result, mask); ssim[\"identity_core\"]=round(core_ssim,4)\n    meta = {\"procedure\": plan.procedure, \"edit_region\": plan.region,\n            \"reference_dataset_used\": bool(_IP_OK.get(model_name) and plan.use_reference),\n            \"generator_model\": model_name, \"recommended_by_dspy\": plan.recommended_source_model,\n            \"learned_recipe\": plan.learned_tokens, \"dspy_lm_used\": bool(LM_ACTIVE),\n            \"strength\": round(strength,3), \"identity_blend\": blend, \"steps\": steps,\n            \"candidates_generated\": n_cand, \"chosen_seed\": used_seed,\n            \"realism_score\": round(realism,3), \"confidence\": confidence,\n            \"artifact_free\": (not corrupt), \"used_memory\": bool(mem),\n            \"optimized_prompt\": plan.optimized_prompt, \"negative_prompt\": plan.negative_prompt,\n            \"ssim_metrics\": ssim, \"identity_core_ssim\": round(core_ssim,4),\n            \"region_change\": round(region_change,4),\n            \"recorded_model_scores\": plan.model_scores, \"dataset_examples_used\": plan.n_examples,\n            \"identity_check\": idc, \"disclaimer\": DISCLAIMER}\n    path = OUT / f\"consult_{datetime.datetime.now():%Y%m%d_%H%M%S}.json\"\n    path.write_text(json.dumps(meta, indent=2))\n\n    # ---- patient-friendly notes (plain language, no jargon) ----\n    change_pct = int(round(region_change*100)); same_pct = int(round(core_ssim*100))\n    strength_word = \"strong\" if region_change>0.25 else \"moderate\" if region_change>0.12 else \"subtle\"\n    notes = (\n        f\"Your {plan.procedure.split('/')[0].strip().lower()} preview is ready.\\n\\n\"\n        f\"What we changed: {DEFAULT_GOALS.get(plan.procedure,'the requested area').lower()}.\\n\"\n        f\"We only edited the {plan.region.replace('_',' ')} area and kept the rest of your face the same.\\n\\n\"\n        f\"How noticeable is it: a {strength_word} change (about {change_pct}% difference in the edited area).\\n\"\n        f\"Is it still you: yes. Your eyes and nose (the parts that make you recognisable) are about \"\n        f\"{same_pct}% identical to your original photo, so this looks like you, just with the treatment applied.\\n\"\n        f\"Confidence in this preview: {int(round(confidence*100))} out of 100\"\n        f\"{' (clean, artifact-free result)' if not corrupt else ' (please regenerate — the edit looked off)'}.\\n\\n\"\n        f\"This is a computer visualisation to help you picture a possible result. \"\n        f\"It is not a promise of the exact outcome. Please discuss any real procedure with a qualified surgeon.\")\n    return result, overlay, notes, str(path), plan.optimized_prompt\n\nprint(\"Cell 6 complete · models:\", list(MODEL_REGISTRY))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:32.120186Z","iopub.execute_input":"2026-07-08T17:04:32.120988Z","iopub.status.idle":"2026-07-08T17:04:37.067445Z","shell.execute_reply.started":"2026-07-08T17:04:32.120958Z","shell.execute_reply":"2026-07-08T17:04:37.066533Z"}},"outputs":[{"name":"stderr","text":"Flax classes are deprecated and will be removed in Diffusers v1.0.0. We recommend migrating to PyTorch classes or pinning your version of Diffusers.\nFlax classes are deprecated and will be removed in Diffusers v1.0.0. We recommend migrating to PyTorch classes or pinning your version of Diffusers.\n","output_type":"stream"},{"name":"stdout","text":"Cell 6 complete · models: ['Realistic-Vision (SD1.5 inpaint)', 'SDXL (inpaint, max detail)']\n","output_type":"stream"}],"execution_count":8},{"id":"7b62f0f3","cell_type":"code","source":"# ── Cell 6b · OPTIONAL: train a surgery LoRA ONCE, then it is auto-loaded forever ───────\n# This is the recommended way to teach the model the rhinoplasty + botox look from the datasets\n# (the global IP-Adapter is OFF by default because it corrupted non-reference edits). Set\n# TRAIN_LORA_NOW=True and run THIS cell one time to bake the \"after\" look into a small LoRA saved\n# to /kaggle/working. On every future run, get_pipe() finds surgery_lora.safetensors and loads it\n# automatically — train once, use always. Save it as a Kaggle Dataset so it survives session resets.\nTRAIN_LORA_NOW = False        # <- set True once to train, then set back to False\nLORA_STEPS     = 600          # ~15-25 min on a T4; raise for a stronger effect\n\nif TRAIN_LORA_NOW:\n    try:\n        import torch, random\n        from diffusers import StableDiffusionInpaintPipeline, DDPMScheduler\n        from peft import LoraConfig, get_peft_model_state_dict\n        from safetensors.torch import save_file\n\n        # ---- keep only FRONTAL FACE photos (drop side profiles / nose-only crops) ----\n        def _is_frontal(img):\n            pts,_=get_landmarks(img)\n            if pts is None or len(pts)<200: return False\n            xs=pts[:,0]; ys=pts[:,1]\n            w=xs.max()-xs.min(); h=ys.max()-ys.min()\n            if w<img.size[0]*0.25 or h<img.size[1]*0.25: return False   # face too small (nose-only crop)\n            # frontal = both eyes present and roughly level & symmetric about the nose\n            le,re,nose=pts[33],pts[263],pts[1]\n            eye_dx=abs(re[0]-le[0]); \n            if eye_dx < w*0.35: return False                            # eyes too close -> profile view\n            sym=abs((nose[0]-le[0])-(re[0]-nose[0]))/(eye_dx+1e-3)\n            return sym < 0.45                                           # nose roughly centred between eyes\n        pairs = [(\"a photorealistic frontal portrait after rhinoplasty, refined slim pointed nose\", RHINO_IMAGES),\n                 (\"a photorealistic frontal portrait after botox, firm smooth wrinkle-free skin\", BOTOX_AFTER)]\n        imgs=[]; caps=[]; dropped=0\n        for cap, paths in pairs:\n            for p in _after_only(paths)[:250]:\n                try:\n                    im=Image.open(p).convert(\"RGB\")\n                    im=center_square(im).resize((512,512))\n                    if _is_frontal(im): imgs.append(im); caps.append(cap)\n                    else: dropped+=1\n                except Exception: pass\n        print(f\"Training images: kept {len(imgs)} frontal faces, dropped {dropped} side/nose-only\")\n        assert len(imgs)>=8, \"Not enough frontal training images — add the datasets.\"\n\n        base=\"Uminosachi/realisticVisionV51_v51VAE-inpainting\"\n        pipe=StableDiffusionInpaintPipeline.from_pretrained(base, torch_dtype=torch.float32,\n                                                            safety_checker=None).to(DEVICE)\n        sched=DDPMScheduler.from_config(pipe.scheduler.config)\n        unet=pipe.unet\n        unet.add_adapter(LoraConfig(r=8, lora_alpha=8, init_lora_weights=\"gaussian\",\n                                    target_modules=[\"to_k\",\"to_q\",\"to_v\",\"to_out.0\"]))\n        for p in pipe.vae.parameters(): p.requires_grad_(False)\n        for p in pipe.text_encoder.parameters(): p.requires_grad_(False)\n        unet.train()\n        opt=torch.optim.AdamW([p for p in unet.parameters() if p.requires_grad], lr=5e-5)\n        vae, te, tok = pipe.vae, pipe.text_encoder, pipe.tokenizer\n        sf=vae.config.scaling_factor\n        for step in range(LORA_STEPS):\n            j=random.randrange(len(imgs))\n            px=(torch.tensor(np.array(imgs[j])/127.5-1).permute(2,0,1)[None].float()).to(DEVICE)\n            with torch.no_grad():\n                lat=vae.encode(px).latent_dist.sample()*sf\n                Lh,Lw=lat.shape[-2:]\n                # RANDOM rectangular mask -> teaches the model to fill masked skin from context\n                mh,mw=random.randint(Lh//4,Lh//2), random.randint(Lw//4,Lw//2)\n                my,mx=random.randint(0,Lh-mh), random.randint(0,Lw-mw)\n                mask=torch.zeros((1,1,Lh,Lw),device=DEVICE); mask[...,my:my+mh,mx:mx+mw]=1.0\n                masked_lat=lat*(1.0-mask)                                  # masked region hidden (correct)\n                ids=tok(caps[j],return_tensors=\"pt\",padding=\"max_length\",truncation=True,max_length=77).input_ids.to(DEVICE)\n                enc=te(ids)[0]\n            nz=torch.randn_like(lat)\n            t=torch.randint(0,sched.config.num_train_timesteps,(1,),device=DEVICE).long()\n            noisy=sched.add_noise(lat,nz,t)\n            inp=torch.cat([noisy,mask,masked_lat],dim=1) if unet.config.in_channels==9 else noisy\n            pred=unet(inp,t,encoder_hidden_states=enc).sample\n            loss=torch.nn.functional.mse_loss(pred.float(),nz.float())\n            loss.backward()\n            torch.nn.utils.clip_grad_norm_([p for p in unet.parameters() if p.requires_grad],1.0)\n            opt.step(); opt.zero_grad()\n            if step%100==0: print(f\"  lora step {step}/{LORA_STEPS} loss {loss.item():.3f}\")\n        unet.eval()\n        ok = _lora_is_safe(pipe)                                          # validate before saving\n        if ok:\n            sd={f\"unet.{k}\":v for k,v in get_peft_model_state_dict(unet).items()}\n            out=str(TRAINED_DIR/\"surgery_lora.safetensors\"); save_file(sd,out)\n            print(\"Saved verified LoRA ->\", out, \" (auto-loads next run)\")\n        else:\n            print(\"Trained LoRA failed the artifact check and was NOT saved. Try more steps or check the data.\")\n        del pipe; gc.collect()\n        if DEVICE==\"cuda\": torch.cuda.empty_cache()\n    except Exception as e:\n        print(\"LoRA training skipped:\", str(e)[:160])\nelse:\n    print(\"LoRA training OFF. Set TRAIN_LORA_NOW=True and run once to bake the surgery look into weights.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:40.717882Z","iopub.execute_input":"2026-07-08T17:04:40.718553Z","iopub.status.idle":"2026-07-08T17:04:40.738057Z","shell.execute_reply.started":"2026-07-08T17:04:40.718524Z","shell.execute_reply":"2026-07-08T17:04:40.737301Z"}},"outputs":[{"name":"stdout","text":"LoRA training OFF. Set TRAIN_LORA_NOW=True and run once to bake the surgery look into weights.\n","output_type":"stream"}],"execution_count":9},{"id":"991d1014","cell_type":"markdown","source":"---\n# PART 2 · Build the dataset, then launch the 3-tab app\nEngine is above. Below: database + cloud + **fast** batch build, then the Manual / Batch / Community app.\nFor the full set change `N=1500`. For a one-day run keep `FAST=True`.","metadata":{}},{"id":"b41af214","cell_type":"code","source":"import subprocess, sys\nsubprocess.run([sys.executable,\"-m\",\"pip\",\"install\",\"-q\",\"supabase\",\"scikit-image\"])\ntry:\n    from kaggle_secrets import UserSecretsClient\n    _s=UserSecretsClient()\n    os.environ[\"SUPABASE_URL\"]=_s.get_secret(\"SUPABASE_URL\"); os.environ[\"SUPABASE_KEY\"]=_s.get_secret(\"SUPABASE_KEY\")\n    print(\"Supabase secrets loaded\")\nexcept Exception as e:\n    print(\"No Supabase secrets — staying local:\", str(e)[:60])","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:04:46.252601Z","iopub.execute_input":"2026-07-08T17:04:46.253454Z","iopub.status.idle":"2026-07-08T17:04:50.620824Z","shell.execute_reply.started":"2026-07-08T17:04:46.253426Z","shell.execute_reply":"2026-07-08T17:04:50.619926Z"}},"outputs":[{"name":"stdout","text":"   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 48.4/48.4 kB 4.0 MB/s eta 0:00:00\nSupabase secrets loaded\n","output_type":"stream"}],"execution_count":10},{"id":"b46ce646","cell_type":"markdown","source":"### Data layer","metadata":{}},{"id":"e6bebdae","cell_type":"code","source":"\"\"\"\ndata_layer.py — dataset engine for Vision Studio.\nLocal-first (SQLite, never lose data) with an optional Supabase mirror (auto-sync to cloud).\nProvides: balanced CelebA sampling, an edit registry (makeup/beard/feminize/surgery/…),\nand one iterate-and-store loop shared by Batch mode and Manual mode. Every iteration's\nimage + mask + row is saved and grouped per source face.\n\"\"\"\nimport os, json, sqlite3, datetime, hashlib, glob, csv\nimport numpy as np\nfrom PIL import Image, ImageDraw, ImageFilter\n\nROOT    = os.environ.get(\"VS_ROOT\", \"/kaggle/working/vision_studio\")\nIMG_DIR = os.path.join(ROOT, \"images\")\nDB_PATH = os.path.join(ROOT, \"vision_studio.db\")\nos.makedirs(IMG_DIR, exist_ok=True)\ndef _now(): return datetime.datetime.now().isoformat(timespec=\"seconds\")\n\n# --------------------------------------------------------------------- edit registry\n# Each edit = a prompt recipe + the region it touches + a default strength.\nEDITS = {\n  # ---- non-surgical / manual-mode favourites ----\n  \"add_makeup\":      dict(region=\"face\",     strength=0.45, label=\"Add makeup\",\n                          prompt=\"natural glam makeup, foundation, subtle eyeshadow, mascara, defined lips, even skin\",\n                          neg=\"over-edited, clown makeup, different person\"),\n  \"remove_makeup\":   dict(region=\"face\",     strength=0.45, label=\"Remove makeup\",\n                          prompt=\"bare natural skin, no makeup, clean face, natural lips, visible pores\",\n                          neg=\"makeup, lipstick, eyeshadow, different person\"),\n  \"add_beard\":       dict(region=\"lower_face\",strength=0.55, label=\"Add beard\",\n                          prompt=\"full natural beard, stubble, facial hair, well groomed\",\n                          neg=\"clean shaven, patchy, different person\"),\n  \"remove_beard\":    dict(region=\"lower_face\",strength=0.55, label=\"Remove beard (clean shave)\",\n                          prompt=\"clean shaven smooth jaw, no facial hair, natural skin\",\n                          neg=\"beard, stubble, facial hair, different person\"),\n  \"feminize\":        dict(region=\"face\",     strength=0.5,  label=\"Feminizing (FFS preview)\",\n                          prompt=\"softer feminine facial features, smoother jaw, refined brow, fuller lips, feminine face\",\n                          neg=\"masculine, heavy jaw, different person\"),\n  \"masculinize\":     dict(region=\"face\",     strength=0.5,  label=\"Masculinizing preview\",\n                          prompt=\"stronger masculine features, defined jaw, heavier brow, masculine face\",\n                          neg=\"feminine, soft jaw, different person\"),\n  \"clear_skin\":      dict(region=\"face\",     strength=0.4,  label=\"Clear skin / acne\",\n                          prompt=\"clear smooth skin, fewer blemishes, reduced acne, even complexion, natural pores\",\n                          neg=\"plastic skin, over-smoothed, different person\"),\n  # ---- surgical procedures (from your main notebook) ----\n  \"rhinoplasty\":     dict(region=\"nose\",     strength=0.42, label=\"Rhinoplasty\",\n                          prompt=\"smaller thinner refined nose, straight bridge, refined tip\",\n                          neg=\"bigger nose, distorted, different person\"),\n  \"facelift\":        dict(region=\"jowls\",    strength=0.46, label=\"Facelift / tightening\",\n                          prompt=\"lifted tightened jawline, reduced jowls, firmer youthful skin, same person younger\",\n                          neg=\"different person, distorted\"),\n  \"botox\":           dict(region=\"wrinkles\", strength=0.45, label=\"Botox / wrinkle softening\",\n                          prompt=\"smooth youthful skin, wrinkle lines removed, firm fresh complexion\",\n                          neg=\"waxy plastic skin, different person\"),\n  \"double_chin\":     dict(region=\"lower_face\",strength=0.54, label=\"Double chin / neck\",\n                          prompt=\"no double chin, slim defined jaw and neck, contoured lower face\",\n                          neg=\"different person, distorted\"),\n  \"slimming\":        dict(region=\"face\",     strength=0.58, label=\"Face slimming\",\n                          prompt=\"slimmer narrower face, reduced cheek fat, defined jawline, slim V-shape\",\n                          neg=\"different person, distorted\"),\n}\n# popular concerns the proactive one-shot will look for (built from the edit set above)\nPROACTIVE_CONCERNS = [\"clear_skin\",\"botox\",\"slimming\"]\n\n# --------------------------------------------------------------------- store (SQLite + optional Supabase)\nclass Store:\n    def __init__(self, db_path=DB_PATH):\n        self.db_path = db_path; self._init()\n        self.sb = self._connect_supabase()   # None unless env creds are present\n    def _c(self):\n        con = sqlite3.connect(self.db_path); con.row_factory = sqlite3.Row; return con\n    def _init(self):\n        con=self._c(); con.executescript(\"\"\"\n        CREATE TABLE IF NOT EXISTS sources(source_id TEXT PRIMARY KEY, dataset TEXT, celeba_file TEXT,\n          attrs TEXT, created_at TEXT);\n        CREATE TABLE IF NOT EXISTS sessions(session_id TEXT PRIMARY KEY, source_id TEXT, mode TEXT,\n          edit_type TEXT, goal TEXT, username TEXT, created_at TEXT, best_iter_id INTEGER,\n          n_iters INTEGER DEFAULT 0, status TEXT);\n        CREATE TABLE IF NOT EXISTS iterations(iter_id INTEGER PRIMARY KEY AUTOINCREMENT, session_id TEXT,\n          iter_num INTEGER, image_path TEXT, cloud_url TEXT, mask_path TEXT, prompt TEXT, negative TEXT,\n          edit_type TEXT, model TEXT, strength REAL, seed INTEGER, realism REAL, identity REAL,\n          ssim_locality REAL, drift REAL, human_score REAL, accepted INTEGER, created_at TEXT);\n        CREATE TABLE IF NOT EXISTS users(username TEXT PRIMARY KEY, google_sub TEXT, coins INTEGER DEFAULT 50,\n          streak INTEGER DEFAULT 0, level INTEGER DEFAULT 1, created_at TEXT);\n        CREATE TABLE IF NOT EXISTS model_usage(username TEXT, model TEXT, uses_today INTEGER DEFAULT 0,\n          day TEXT, PRIMARY KEY(username,model));\n        CREATE TABLE IF NOT EXISTS votes(vote_id INTEGER PRIMARY KEY AUTOINCREMENT, iter_id INTEGER,\n          username TEXT, looks_real INTEGER, created_at TEXT);\n        CREATE INDEX IF NOT EXISTS ix_it_sess ON iterations(session_id);\n        \"\"\"); con.commit(); con.close()\n    def _connect_supabase(self):\n        url=os.environ.get(\"SUPABASE_URL\"); key=os.environ.get(\"SUPABASE_KEY\")\n        if not (url and key): return None\n        try:\n            from supabase import create_client\n            sb=create_client(url,key); print(\"Supabase: connected (cloud mirror ON)\"); return sb\n        except Exception as e:\n            print(\"Supabase: not available, staying local -\", str(e)[:60]); return None\n    def _mirror(self, table, row):\n        if not self.sb: return\n        try: self.sb.table(table).upsert(row).execute()\n        except Exception as e: print(\"cloud mirror skipped:\", str(e)[:50])\n    def _upload(self, local_path):\n        if not self.sb: return None\n        try:\n            with open(local_path,\"rb\") as f:\n                key=os.path.basename(local_path)\n                self.sb.storage.from_(\"iterations\").upload(key,f,{\"upsert\":\"true\"})\n                return self.sb.storage.from_(\"iterations\").get_public_url(key)\n        except Exception: return None\n\n    # ---- writes ----\n    def new_source(self, dataset, celeba_file, attrs, img):\n        sid=hashlib.md5((str(celeba_file)+_now()+str(np.random.rand())).encode()).hexdigest()[:12]\n        row=dict(source_id=sid,dataset=dataset,celeba_file=str(celeba_file),attrs=json.dumps(attrs),created_at=_now())\n        con=self._c(); con.execute(\"INSERT OR REPLACE INTO sources VALUES(:source_id,:dataset,:celeba_file,:attrs,:created_at)\",row)\n        con.commit(); con.close(); self._mirror(\"sources\",row); return sid\n    def new_session(self, source_id, mode, edit_type, goal, username):\n        sid=hashlib.md5((source_id+_now()+edit_type).encode()).hexdigest()[:12]\n        row=dict(session_id=sid,source_id=source_id,mode=mode,edit_type=edit_type,goal=goal,\n                 username=username,created_at=_now(),best_iter_id=None,n_iters=0,status=\"open\")\n        con=self._c(); con.execute(\"INSERT INTO sessions VALUES(:session_id,:source_id,:mode,:edit_type,:goal,\"\n            \":username,:created_at,:best_iter_id,:n_iters,:status)\",row); con.commit(); con.close()\n        self._mirror(\"sessions\",row); return sid\n    def add_iteration(self, session_id, iter_num, image, mask, plan, meta, metrics, human, accepted):\n        base=f\"{session_id}_{iter_num:02d}\"; ipath=os.path.join(IMG_DIR,base+\".png\"); mpath=os.path.join(IMG_DIR,base+\"_m.png\")\n        image.save(ipath); mask.convert(\"L\").save(mpath); url=self._upload(ipath)\n        con=self._c(); cur=con.execute(\"\"\"INSERT INTO iterations(session_id,iter_num,image_path,cloud_url,mask_path,\n          prompt,negative,edit_type,model,strength,seed,realism,identity,ssim_locality,drift,human_score,accepted,created_at)\n          VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)\"\"\",\n          (session_id,iter_num,ipath,url,mpath,plan[\"prompt\"],plan[\"neg\"],plan[\"edit_type\"],meta[\"model\"],\n           meta[\"strength\"],meta[\"seed\"],metrics[\"realism\"],metrics[\"identity\"],metrics[\"ssim_locality\"],\n           metrics[\"drift\"],human,int(accepted),_now()))\n        iid=cur.lastrowid; con.execute(\"UPDATE sessions SET n_iters=n_iters+1 WHERE session_id=?\",(session_id,))\n        if accepted: con.execute(\"UPDATE sessions SET best_iter_id=?,status='accepted' WHERE session_id=?\",(iid,session_id))\n        con.commit(); con.close()\n        self._mirror(\"iterations\",{\"iter_id\":iid,\"session_id\":session_id,\"iter_num\":iter_num,\"cloud_url\":url,\n            \"edit_type\":plan[\"edit_type\"],\"realism\":metrics[\"realism\"],\"identity\":metrics[\"identity\"],\n            \"human_score\":human,\"accepted\":int(accepted)}); return iid\n\n    # ---- users / gamification ----\n    def ensure_user(self, username, google_sub=None):\n        con=self._c(); u=con.execute(\"SELECT * FROM users WHERE username=?\",(username,)).fetchone()\n        if not u: con.execute(\"INSERT INTO users(username,google_sub,created_at) VALUES(?,?,?)\",(username,google_sub,_now()))\n        con.commit(); con.close()\n    def add_coins(self, username, n):\n        con=self._c(); con.execute(\"UPDATE users SET coins=coins+? WHERE username=?\",(n,username)); con.commit(); con.close()\n    def can_use_model(self, username, model, daily_limit):\n        day=datetime.date.today().isoformat(); con=self._c()\n        r=con.execute(\"SELECT uses_today,day FROM model_usage WHERE username=? AND model=?\",(username,model)).fetchone()\n        uses=0 if (not r or r[\"day\"]!=day) else r[\"uses_today\"]; con.close()\n        return uses<daily_limit, uses\n    def record_use(self, username, model):\n        day=datetime.date.today().isoformat(); con=self._c()\n        con.execute(\"\"\"INSERT INTO model_usage(username,model,uses_today,day) VALUES(?,?,1,?)\n            ON CONFLICT(username,model) DO UPDATE SET uses_today=CASE WHEN day=? THEN uses_today+1 ELSE 1 END, day=?\"\"\",\n            (username,model,day,day,day)); con.commit(); con.close()\n    def add_vote(self, iter_id, username, looks_real):\n        con=self._c(); con.execute(\"INSERT INTO votes(iter_id,username,looks_real,created_at) VALUES(?,?,?,?)\",\n            (iter_id,username,int(looks_real),_now())); con.commit(); con.close()\n\n    # ---- reads / analytics ----\n    def groups(self):\n        con=self._c(); sess=con.execute(\"SELECT * FROM sessions ORDER BY created_at DESC\").fetchall(); out=[]\n        for s in sess:\n            its=con.execute(\"SELECT * FROM iterations WHERE session_id=? ORDER BY iter_num\",(s[\"session_id\"],)).fetchall()\n            out.append({\"session\":dict(s),\"iterations\":[dict(x) for x in its]})\n        con.close(); return out\n    def stats(self):\n        con=self._c()\n        n_src=con.execute(\"SELECT COUNT(*) c FROM sources\").fetchone()[\"c\"]\n        n_it =con.execute(\"SELECT COUNT(*) c FROM iterations\").fetchone()[\"c\"]\n        acc  =con.execute(\"SELECT AVG(n_iters) a FROM sessions WHERE status='accepted'\").fetchone()[\"a\"]\n        by   =con.execute(\"SELECT edit_type,COUNT(*) c,AVG(human_score) s FROM iterations GROUP BY edit_type\").fetchall()\n        con.close()\n        return {\"sources\":n_src,\"iterations\":n_it,\"avg_iters_to_accept\":round(acc,2) if acc else None,\n                \"by_edit\":{r[\"edit_type\"]:{\"n\":r[\"c\"],\"avg_score\":round(r[\"s\"],2) if r[\"s\"] else None} for r in by}}\n    def best_model(self, min_n=3):\n        \"\"\"Model with the highest average human score — becomes the premium/limited one in gamification.\"\"\"\n        con=self._c(); rows=con.execute(\"SELECT model, AVG(human_score) s, COUNT(*) n FROM iterations \"\n            \"GROUP BY model HAVING n>=? ORDER BY s DESC\",(min_n,)).fetchall(); con.close()\n        return (rows[0][\"model\"], round(rows[0][\"s\"],2)) if rows else (\"realistic-vision\", None)\n    def model_leaderboard(self):\n        con=self._c(); rows=con.execute(\"SELECT model, AVG(human_score) s, AVG(realism) r, COUNT(*) n \"\n            \"FROM iterations GROUP BY model ORDER BY s DESC\").fetchall(); con.close()\n        return [dict(x) for x in rows]\n    def community_top(self, limit=12):\n        con=self._c(); rows=con.execute(\"\"\"SELECT i.iter_id,i.image_path,i.edit_type,i.human_score,\n            COALESCE(SUM(v.looks_real),0) up, COUNT(v.vote_id) votes FROM iterations i\n            LEFT JOIN votes v ON v.iter_id=i.iter_id WHERE i.accepted=1\n            GROUP BY i.iter_id ORDER BY i.human_score DESC, up DESC LIMIT ?\"\"\",(limit,)).fetchall()\n        con.close(); return [dict(r) for r in rows]\n    def export_csv(self, path=None):\n        path=path or os.path.join(ROOT,\"iterations.csv\"); con=self._c()\n        rows=con.execute(\"SELECT * FROM iterations\").fetchall(); con.close()\n        if rows:\n            with open(path,\"w\",newline=\"\") as f:\n                w=csv.DictWriter(f,fieldnames=rows[0].keys()); w.writeheader()\n                for r in rows: w.writerow(dict(r))\n        return path\n\n# --------------------------------------------------------------------- balanced CelebA sampler\ndef attrs_from_caption(cap):\n    \"\"\"CelebA-small has captions, not attribute flags. Derive light Male/Young signals from the\n       caption text so we can still show the demographic-balance graph (rebuts the JCM 2023 bias).\"\"\"\n    c=(cap or \"\").lower()\n    male  = 1 if any(w in c for w in [\" man\",\"male\",\" he \",\" his \",\"gentleman\",\" boy\"]) else \\\n           -1 if any(w in c for w in [\"woman\",\"female\",\" she \",\" her \",\" lady\",\" girl\"]) else 0\n    young = 1 if any(w in c for w in [\"young\",\"youth\"]) else \\\n           -1 if any(w in c for w in [\" old\",\"elderly\",\"aged\",\"senior\",\"wrinkle\"]) else 0\n    return {\"Male\":male, \"Young\":young}\n\ndef load_celeba_small(images_dir, captions_csv=None, n=1500):\n    \"\"\"Return up to n UNIQUE photos (one at a time), each as (path, PIL image, attrs-from-caption).\"\"\"\n    files = sorted(glob.glob(os.path.join(images_dir, \"*.jpg\")) + glob.glob(os.path.join(images_dir, \"*.png\")))\n    caps = {}\n    if captions_csv and os.path.exists(captions_csv):\n        import pandas as pd\n        df = pd.read_csv(captions_csv)\n        fcol = next((c for c in df.columns if any(k in c.lower() for k in [\"image\",\"file\",\"name\",\"id\"])), df.columns[0])\n        ccol = next((c for c in df.columns if \"cap\" in c.lower() or \"text\" in c.lower()), df.columns[-1])\n        for _,r in df.iterrows(): caps[os.path.basename(str(r[fcol]))] = str(r[ccol])\n    out=[]\n    for f in files[:n]:\n        try:\n            img=Image.open(f).convert(\"RGB\")\n            out.append((f, img, attrs_from_caption(caps.get(os.path.basename(f),\"\"))))\n        except Exception: pass\n    return out\n\ndef balanced_celeba_sample(attr_df, n, balance_on=(\"Male\",\"Young\",\"Pale_Skin\")):\n    \"\"\"Pick n rows spread across the balance attributes so the dataset isn't all young pale women\n       (directly addresses the bias the JCM 2023 paper reported).\"\"\"\n    import itertools, random\n    cols=[c for c in balance_on if c in attr_df.columns]\n    if not cols: return attr_df.sample(min(n,len(attr_df))).to_dict(\"records\")\n    groups={}\n    for combo in itertools.product([1,-1],repeat=len(cols)):\n        mask=np.ones(len(attr_df),bool)\n        for c,v in zip(cols,combo): mask&=(attr_df[c]==v).values\n        sub=attr_df[mask]\n        if len(sub): groups[combo]=sub\n    per=max(1,n//max(1,len(groups))); picked=[]\n    for sub in groups.values(): picked.append(sub.sample(min(per,len(sub))))\n    import pandas as pd; out=pd.concat(picked)\n    if len(out)<n:  # top up\n        rest=attr_df.drop(out.index); out=pd.concat([out,rest.sample(min(n-len(out),len(rest)))])\n    return out.head(n).to_dict(\"records\")\n\n# --------------------------------------------------------------------- iterate-and-store loop\ndef build_plan(edit_type, goal=None):\n    e=EDITS[edit_type]; g=(goal or \"\").strip()\n    prompt=(g+\", \" if g else \"\")+e[\"prompt\"]+\", photorealistic, natural skin texture, same person, preserve identity\"\n    return {\"edit_type\":edit_type,\"region\":e[\"region\"],\"strength\":e[\"strength\"],\n            \"prompt\":prompt,\"neg\":e[\"neg\"]+\", different person, distorted, blurry\",\"_iter\":0}\n\ndef refine_plan(plan, metrics):\n    plan=dict(plan)\n    if metrics[\"identity\"]<0.88: plan[\"strength\"]=max(0.3,plan[\"strength\"]-0.08)\n    if metrics[\"realism\"]<0.6:   plan[\"prompt\"]+=\", sharp focus, realistic lighting, high detail\"\n    plan[\"_iter\"]=plan.get(\"_iter\",0)+1; return plan\n\ndef run_and_store(store, source_id, source_img, edit_type, generate, score_fn, mode=\"batch\",\n                  goal=None, username=\"admin\", max_iter=4, target=4.0, human_rater=None, model=\"realistic-vision\"):\n    \"\"\"Shared by batch & manual. Iterates edit->score until satisfied, storing EVERY iteration.\"\"\"\n    sid=store.new_session(source_id, mode, edit_type, goal, username)\n    plan=build_plan(edit_type, goal)\n    for i in range(max_iter):\n        plan[\"edit_type\"]=edit_type\n        img, mask, meta = generate(source_img, plan, 42+i, model)\n        m = score_fn(source_img, img, mask)\n        # batch: scorer proxy stands in for the human (can't hand-rate 1500). manual: real user rating.\n        human = human_rater(img, mask, m) if human_rater else round(1+4*m[\"realism\"],2)\n        ok = human>=target\n        store.add_iteration(sid, i, img, mask, plan, meta, m, human, ok)\n        if ok: break\n        plan = refine_plan(plan, m)\n    return sid\n","metadata":{},"outputs":[],"execution_count":null},{"id":"259f8ebe","cell_type":"code","source":"store=Store(); print(\"store ready · cloud mirror:\", \"ON\" if store.sb else \"OFF (local only)\")","metadata":{},"outputs":[],"execution_count":null},{"id":"353df7bc","cell_type":"markdown","source":"### Generator + SPEED settings\n`FAST=True` → SD1.5 only, 18 steps, **1 pass per photo** (feasible for 1500 in a day).\n`FAST=False` → all 3 models, 28 steps, up to 4 iterations (slower, richer).","metadata":{}},{"id":"af04e2b6","cell_type":"code","source":"FAST = True\nSTEPS          = 18 if FAST else 28\nBATCH_MAX_ITER = 1  if FAST else 4\nMODELS         = [\"realistic-vision\"] if FAST else [\"realistic-vision\",\"juggernaut-xl\",\"epicrealism\"]\nMODEL_MAP={\"realistic-vision\":DEFAULT_MODEL,\n           \"juggernaut-xl\":(\"SDXL (inpaint, max detail)\" if \"SDXL (inpaint, max detail)\" in MODEL_REGISTRY else DEFAULT_MODEL),\n           \"epicrealism\":DEFAULT_MODEL}\nUSE_REAL=True   # set False for a no-GPU plumbing test\n\nif USE_REAL:\n    def generate(src,plan,seed,model):\n        import torch\n        key=MODEL_MAP.get(model,DEFAULT_MODEL); W,H=MODEL_REGISTRY[key][\"size\"]\n        orig=src.convert(\"RGB\").resize((W,H)); mask=build_region_mask(orig,plan[\"region\"])\n        g=torch.Generator(device=DEVICE).manual_seed(seed)\n        gen=get_pipe(key)(prompt=plan[\"prompt\"],negative_prompt=plan[\"neg\"],image=orig,mask_image=mask,\n                          strength=plan[\"strength\"],num_inference_steps=STEPS,guidance_scale=7.0,generator=g).images[0]\n        return composite_identity_safe(orig,gen,mask,1.0), mask, {\"model\":model,\"strength\":plan[\"strength\"],\"seed\":seed}\n    def score_fn(orig,edited,mask):\n        return {\"realism\":SCORER.predict(edited,mask) if getattr(SCORER,\"fitted\",False) else realism_of(edited,mask),\n                \"identity\":idcore_ssim(orig,edited),\n                \"ssim_locality\":ssim_regions(orig,edited,mask)[\"ssim_identity_outside\"],\n                \"drift\":(landmark_identity_check(orig,edited).get(\"landmark_shift_mean\") or 0.01)}\nelse:\n    from PIL import Image, ImageDraw, ImageFilter\n    def _m(img,region):\n        m=Image.new(\"L\",img.size,0); ImageDraw.Draw(m).ellipse([img.size[0]*.2,img.size[1]*.2,img.size[0]*.8,img.size[1]*.85],fill=255)\n        return m.filter(ImageFilter.GaussianBlur(6))\n    def generate(src,plan,seed,model):\n        import numpy as _np; rng=_np.random.default_rng(seed); a=_np.array(src.convert(\"RGB\").resize((256,256))).astype(int)\n        mk=_np.array(_m(src.resize((256,256)),plan[\"region\"]))>128; a[mk]=_np.clip(a[mk]+rng.integers(-30,30,a.shape)[mk],0,255)\n        return Image.fromarray(a.astype(\"uint8\")), _m(src.resize((256,256)),plan[\"region\"]), {\"model\":model,\"strength\":plan[\"strength\"],\"seed\":seed}\n    def score_fn(orig,edited,mask):\n        import numpy as _np; g=cv2.cvtColor(_np.array(edited.convert(\"RGB\")),cv2.COLOR_RGB2GRAY)\n        aa=_np.array(orig.convert(\"L\")).astype(float); bb=_np.array(edited.convert(\"L\").resize(orig.size)).astype(float)\n        return {\"realism\":float(_np.clip(_np.tanh(cv2.Laplacian(g,cv2.CV_64F).var()/120),0,1)),\n                \"identity\":float(_np.clip(1-_np.abs(aa-bb).mean()/255,0,1)),\"ssim_locality\":.97,\"drift\":.01}\nprint(f\"wired · USE_REAL={USE_REAL} · FAST={FAST} · steps={STEPS} · max_iter={BATCH_MAX_ITER} · models={MODELS}\")","metadata":{},"outputs":[],"execution_count":null},{"id":"548e0054","cell_type":"markdown","source":"### Load YOUR CelebA-small","metadata":{}},{"id":"4d42dc5d","cell_type":"code","source":"IMAGES_DIR=\"/kaggle/input/datasets/sathyavgc/celeba-dataset-small/content/dataset_sample/images\"\nCAPTIONS_CSV=\"/kaggle/input/datasets/sathyavgc/celeba-dataset-small/content/dataset_sample/captions.csv\"\nif not os.path.isdir(IMAGES_DIR):\n    h=glob.glob(\"/kaggle/input/**/dataset_sample/images\",recursive=True); IMAGES_DIR=h[0] if h else IMAGES_DIR\n    h=glob.glob(\"/kaggle/input/**/captions.csv\",recursive=True); CAPTIONS_CSV=h[0] if h else CAPTIONS_CSV\nN=30   # <-- 1500 for the full dataset\nphotos=load_celeba_small(IMAGES_DIR,CAPTIONS_CSV,n=N); print(f\"loaded {len(photos)} photos\")","metadata":{},"outputs":[],"execution_count":null},{"id":"3ae3ab55","cell_type":"markdown","source":"### BATCH — build the dataset (fast: one pass per photo)","metadata":{}},{"id":"ac38ae1b","cell_type":"code","source":"EDIT_CYCLE=list(EDITS.keys())\nfor k,(path,img,attrs) in enumerate(photos):\n    sid=store.new_source(\"celeba\",os.path.basename(path),attrs,img)\n    run_and_store(store,sid,img,EDIT_CYCLE[k%len(EDIT_CYCLE)],generate,score_fn,\n                  mode=\"batch\",username=\"admin\",max_iter=BATCH_MAX_ITER,target=4.0,model=MODELS[k%len(MODELS)])\n    if (k+1)%50==0: print(f\"  {k+1}/{len(photos)}\")\nprint(\"BATCH DONE ·\",store.stats()); print(\"Best model:\",store.best_model())","metadata":{},"outputs":[],"execution_count":null},{"id":"8e5e7740","cell_type":"markdown","source":"### (optional) dashboard","metadata":{}},{"id":"b9ef8ed9","cell_type":"code","source":"import matplotlib.pyplot as plt, sqlite3, json as _json, numpy as _np\ncon=sqlite3.connect(DB_PATH); it=con.execute(\"SELECT edit_type,human_score,realism,identity,model FROM iterations\").fetchall()\nni=[r[0] for r in con.execute(\"SELECT n_iters FROM sessions WHERE status='accepted'\").fetchall()]\nsrc=[_json.loads(a[0]) for a in con.execute(\"SELECT attrs FROM sources\").fetchall() if a[0]]; con.close()\nhs=[r[1] for r in it]; re=[r[2] for r in it]; idn=[r[3] for r in it]; ml=[r[4] for r in it]; et=[r[0] for r in it]\nfig,ax=plt.subplots(2,3,figsize=(15,8)); fig.suptitle(\"Vision Studio dashboard\",weight=\"bold\")\nax[0,0].hist(hs or [0],bins=_np.arange(1,5.6,.5),color=\"#54D6C7\"); ax[0,0].set_title(\"scores (auto placeholder until humans rate)\")\nif ni: ax[0,1].hist(ni,bins=range(1,7),color=\"#E7B15A\")\nax[0,1].set_title(\"iterations\")\nmods=sorted(set(ml)); ax[0,2].bar(mods,[_np.mean([hs[i] for i in range(len(ml)) if ml[i]==m]) for m in mods],color=\"#7aa2c9\"); ax[0,2].set_ylim(0,5); ax[0,2].set_title(\"by model\")\nax[1,0].scatter(idn,re,c=\"#54D6C7\"); ax[1,0].set_title(\"identity vs realism\")\ndef frac(k): v=[1 if x.get(k)==1 else 0 for x in src if x.get(k) in (1,-1)]; return _np.mean(v) if v else 0\nax[1,1].bar([\"Male\",\"Young\"],[frac(\"Male\"),frac(\"Young\")],color=\"#c98a7a\"); ax[1,1].axhline(.5,ls=\"--\",c=\"gray\"); ax[1,1].set_ylim(0,1); ax[1,1].set_title(\"balance\")\nty=sorted(set(et)); ax[1,2].barh(ty,[_np.mean([hs[i] for i in range(len(et)) if et[i]==t]) for t in ty],color=\"#8ac9a0\"); ax[1,2].set_xlim(0,5); ax[1,2].set_title(\"by edit\")\nplt.tight_layout(); plt.show(); print(\"CSV ->\",store.export_csv())","metadata":{},"outputs":[],"execution_count":null},{"id":"e5204051","cell_type":"markdown","source":"### LAUNCH THE APP — Manual · Batch(admin) · One-shot · Community\nSign in as **admin** or **zaki** to see the Batch tab.","metadata":{}},{"id":"7787c232","cell_type":"code","source":"# ── 3-TAB APP · Manual (rate) · Batch (admin) · Community (vote) · One-shot ──\nimport gradio as gr\nCSS = \".gradio-container{max-width:100%!important}\"\nADMINS = {\"admin\",\"zaki\"}; PREMIUM = {\"juggernaut-xl\",\"epicrealism\"}; DAILY_LIMIT = 3\nEDIT_CHOICES = [(v[\"label\"], k) for k,v in EDITS.items()]\n\ndef _sign_in(name):\n    name=(name or \"guest\").strip().lower(); store.ensure_user(name)\n    con=store._c(); u=con.execute(\"SELECT coins FROM users WHERE username=?\", (name,)).fetchone(); con.close()\n    return name, f\"Signed in as **{name}** · coins {u['coins'] if u else 50}\", gr.update(visible=(name in ADMINS))\n\ndef _manual_gen(image, edit, goal, model, user, st):\n    if image is None: return None, None, \"Upload a photo first.\", st\n    if model in PREMIUM:\n        ok,uses=store.can_use_model(user,model,DAILY_LIMIT)\n        if not ok: return None,None,f\"'{model}' daily limit reached ({uses}/{DAILY_LIMIT}). Earn coins or use a free model.\",st\n        store.record_use(user,model)\n    plan=build_plan(edit,goal); plan[\"_iter\"]=st.get(\"iter\",0) if st else 0\n    img,mask,meta=generate(image,plan,42+plan[\"_iter\"],model); m=score_fn(image,img,mask)\n    note=f\"realism {m['realism']:.2f} · identity {m['identity']:.2f}. Rate it below (this is a REAL human score).\"\n    st={\"src\":store.new_source(\"upload\",\"manual\",{},image.resize((256,256))),\"edit\":edit,\"goal\":goal,\n        \"user\":user,\"iter\":plan[\"_iter\"],\"img\":img,\"mask\":mask,\"meta\":meta,\"m\":m,\"plan\":plan}\n    return img, _overlay(image.resize(img.size),mask), note, st\n\ndef _manual_rate(score, st):\n    if not st or \"img\" not in st: return \"Generate first.\", st\n    sid=store.new_session(st[\"src\"],\"manual\",st[\"edit\"],st[\"goal\"],st[\"user\"]); ok=score>=4\n    store.add_iteration(sid,st[\"iter\"],st[\"img\"],st[\"mask\"],st[\"plan\"],st[\"meta\"],st[\"m\"],float(score),ok)\n    if ok: store.add_coins(st[\"user\"],8); return f\"Saved · human score {score}/5 · +8 coins.\", {}\n    return f\"Saved · {score}/5. Tap Refine for a better version.\", st\n\ndef _manual_refine(st):\n    if not st: return st\n    st=dict(st); st[\"iter\"]=st.get(\"iter\",0)+1; st[\"plan\"]=refine_plan(st[\"plan\"],st[\"m\"]); return st\n\ndef _overlay(img,mask,color=(84,214,199)):\n    import numpy as _np; b=_np.array(img.convert(\"RGB\").resize(mask.size)); a=(_np.array(mask.convert(\"L\"))>90)\n    b[a]=(0.5*_np.array(color)+0.5*b[a]).astype(\"uint8\"); return Image.fromarray(b)\n\ndef _run_batch(n, user, progress=gr.Progress()):\n    if user not in ADMINS: return \"Batch is admin-only.\", None\n    ph=load_celeba_small(IMAGES_DIR,CAPTIONS_CSV,n=int(n)); cyc=list(EDITS.keys())\n    for k,(p,img,attrs) in progress.tqdm(list(enumerate(ph)),desc=\"building\"):\n        sid=store.new_source(\"celeba\",os.path.basename(p),attrs,img)\n        run_and_store(store,sid,img,cyc[k%len(cyc)],generate,score_fn,mode=\"batch\",\n                      username=user,max_iter=BATCH_MAX_ITER,target=4.0,model=MODELS[k%len(MODELS)])\n    return f\"Done · {store.stats()} · best model {store.best_model()}\", None\n\ndef _commun():\n    rows=store.community_top(9)\n    return [(r[\"image_path\"],f\"{r['edit_type']} · {r['human_score']}★\") for r in rows if os.path.exists(r[\"image_path\"])], [r[\"iter_id\"] for r in rows]\ndef _vote(idx,ids,user,real):\n    if idx is None or idx<0 or not ids or idx>=len(ids): return \"Tap an image, then vote.\"\n    store.add_vote(ids[idx],user,real); store.add_coins(user,2); return f\"Vote recorded ({'real' if real else 'not real'}) · +2 coins\"\n\nwith gr.Blocks(css=CSS, title=\"Vision Studio\") as demo:\n    user=gr.State(\"guest\"); vids=gr.State([]); sel=gr.State(-1)\n    gr.Markdown(\"## Vision Studio — console\")\n    with gr.Row(): nm=gr.Textbox(label=\"Username\",scale=3); si=gr.Button(\"Sign in\",scale=1)\n    who=gr.Markdown(\"Not signed in.\")\n    with gr.Tab(\"Manual\"):\n        with gr.Row():\n            with gr.Column():\n                mi=gr.Image(type=\"pil\",label=\"Photo\"); me=gr.Dropdown(EDIT_CHOICES,value=\"add_makeup\",label=\"Edit\")\n                mg=gr.Textbox(label=\"Note\"); mm=gr.Dropdown([\"realistic-vision\",\"juggernaut-xl\",\"epicrealism\"],value=\"realistic-vision\",label=\"Model\")\n                mgo=gr.Button(\"Generate\",variant=\"primary\")\n            with gr.Column():\n                ma=gr.Image(label=\"Result\"); mr=gr.Image(label=\"Edited region\"); mn=gr.Markdown()\n                ms=gr.Slider(1,5,step=1,value=4,label=\"Your rating\"); \n                with gr.Row(): msave=gr.Button(\"Save rating\"); mref=gr.Button(\"Refine\")\n                mst=gr.State({})\n        mgo.click(_manual_gen,[mi,me,mg,mm,user,mst],[ma,mr,mn,mst])\n        msave.click(_manual_rate,[ms,mst],[mn,mst])\n        mref.click(_manual_refine,[mst],[mst]).then(_manual_gen,[mi,me,mg,mm,user,mst],[ma,mr,mn,mst])\n    with gr.Tab(\"Batch (admin)\",visible=False) as bt:\n        bn=gr.Slider(5,1500,value=30,step=5,label=\"Photos\"); bgo=gr.Button(\"Build dataset\",variant=\"primary\"); bn2=gr.Markdown()\n        bgo.click(_run_batch,[bn,user],[bn2,gr.State(None)])\n    with gr.Tab(\"One-shot (after training)\"):\n        gr.Markdown(\"Proactive DSPy+SSIM one-shot — enabled after the dataset is built and the scorer retrained.\")\n    with gr.Tab(\"Community\"):\n        cg=gr.Gallery(columns=3,height=360,label=\"top rated\")\n        with gr.Row(): cr=gr.Button(\"Looks real ✓\"); cf=gr.Button(\"Not real ✗\"); cx=gr.Button(\"Refresh\")\n        cm=gr.Markdown()\n        cg.select(lambda e:e.index,None,sel); cx.click(_commun,None,[cg,vids])\n        cr.click(lambda i,ids,u:_vote(i,ids,u,True),[sel,vids,user],cm)\n        cf.click(lambda i,ids,u:_vote(i,ids,u,False),[sel,vids,user],cm)\n    si.click(_sign_in,[nm],[user,who,bt]); demo.load(_commun,None,[cg,vids])\ndemo.launch(share=True)\n","metadata":{},"outputs":[],"execution_count":null}]}