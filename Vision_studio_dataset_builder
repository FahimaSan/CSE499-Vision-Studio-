l_seed(seed)\n","    gen=get_pipe(key)(prompt=plan[\"prompt\"],negative_prompt=plan[\"neg\"],image=orig,mask_image=mask,\n","                      strength=plan[\"strength\"],num_inference_steps=STEPS,guidance_scale=7.0,generator=g).images[0]\n","    out=composite_identity_safe(orig,gen,mask,1.0); out=texture_restore(orig,out,mask,TEXTURE_AMOUNT)\n","    out=out.resize((ow,oh))                           # back to original shape -> NO stretching\n","    return out, mask, {\"model\":model,\"strength\":plan[\"strength\"],\"seed\":seed}\n","def score_fn(orig,edited,mask):\n","    return {\"realism\":realism_of(edited,mask),\"identity\":idcore_ssim(orig,edited),\n","            \"ssim_locality\":ssim_regions(orig,edited,mask)[\"ssim_identity_outside\"],\n","            \"drift\":(landmark_identity_check(orig,edited).get(\"landmark_shift_mean\") or 0.01)}\n","IMAGES_DIR=\"\"; CAPTIONS_CSV=None\n","print(\"generator ready · aspect-preserving (no stretch)\")"]},{"cell_type":"markdown","id":"26844ca9","metadata":{"papermill":{"duration":0.006365,"end_time":"2026-07-13T10:28:49.344693+00:00","exception":false,"start_time":"2026-07-13T10:28:49.338328+00:00","status":"completed"},"tags":[]},"source":["---\n","## Part 3 · Train on the dataset (only images scored ≥ 3)"]},{"cell_type":"code","execution_count":12,"id":"d6c13f10","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:28:49.35815Z","iopub.status.busy":"2026-07-13T10:28:49.3575Z","iopub.status.idle":"2026-07-13T10:28:49.361119Z","shell.execute_reply":"2026-07-13T10:28:49.360537Z"},"papermill":{"duration":0.011866,"end_time":"2026-07-13T10:28:49.362609+00:00","exception":false,"start_time":"2026-07-13T10:28:49.350743+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["MIN_SCORE=3.0"]},{"cell_type":"code","execution_count":13,"id":"7dbe2e8a","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:28:49.376558Z","iopub.status.busy":"2026-07-13T10:28:49.37614Z","iopub.status.idle":"2026-07-13T10:2