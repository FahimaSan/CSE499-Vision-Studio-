"CSS=\"\"\"\n",".gradio-container{max-width:100%!important;background:#0b0e13!important}\n","#shbox{position:fixed;top:8px;right:14px;z-index:99;background:#141b24;border:1px solid #2a3644;border-radius:12px;padding:6px 14px;font-weight:700;color:#ffd166}\n",".card{background:#121821;border:1px solid #223041;border-radius:16px;padding:14px}\n","h1,h2,h3{color:#e9eef5}\n","#feedimg img{border-radius:18px}\n",".gr-button-primary{background:linear-gradient(90deg,#ff7a45,#ff5470)!important;border:0!important}\n","\"\"\"\n","SH=\"✴️\"\n","ADMINS={\"admin\",\"zaki\",\"fahima\"}\n","EDIT_CHOICES=[(v[\"label\"],k) for k,v in EDITS.items()]\n","LABEL2KEY={v[\"label\"]:k for k,v in EDITS.items()}\n","def _key(e): return e if e in EDITS else LABEL2KEY.get(e,\"add_makeup\")\n","def _bal(u): n,adm=store.shuriken(u); return \"∞\" if adm else n\n","def _box(u): return f\"<div id='shbox'>{SH} {_bal(u)}</div>\"\n","def _ssim2(a_pil,b_pil):\n","    a=np.array(a_pil.convert(\"L\").resize((256,256))); b=np.array(b_pil.convert(\"L\").resize((256,256)))\n","    return float(_ssim(a,b))\n","\n","def sign_in(name):\n","    name=(name or \"guest\").strip().lower(); adm=name in ADMINS; store.ensure_user(name,is_admin=adm)\n","    return name, f\"### Welcome, {name}\"+(\"  ·  admin\" if adm else \"\"), gr.update(visible=adm), _box(name), gr.update(visible=False)\n","\n","# ---------- Manual ----------\n","def manual_gen(image, edit, goal, shade, model, user, st):\n","    if image is None: return None,None,\"Upload a photo first.\",st,_box(user)\n","    ok,rem=store.spend_shuriken(user,1)\n","    if not ok: return None,None,\"Out of shuriken. Score in Community to earn more.\",st,_box(user)\n","    ek=_key(edit); tone=detect_skin_tone(image)\n","    use_shade=shade if ek in ('lipstick',) else None\n","    plan=build_plan(ek,goal,shade=use_shade)\n","    img,mask,meta=generate(image,plan,int(plan[\"seed\"]),model); m=score_fn(image,img,mask)\n","    st={\"orig\":image,\"edit\":ek,\"goal\":goal,\"user\":user,\"img\":img,\"mask\":mask,\"meta\":meta,\"m\":m,\"plan\":plan,\"model\":model,\"tone\":tone,\"shade\":use_shade}\n","    tip=f\" · skin tone **{tone}**\" + (f\" · shade **{use_shade}**\" if use_shade else \"\")\n","    note=f\"region **{plan['region']}** · realism {m['realism']:.2f} · identity {m['identity']:.2f}{tip}\"\n","    return img,_ov(image.resize(img.size),mask),note,st,_box(user)\n","def manual_rate(score, st, user):\n","    if not st or \"img\" not in st: return \"Generate first.\",st\n","    src=store.new_source(\"upload\",\"manual\",{},st[\"orig\"].resize((256,256)))\n","    sid=store.new_session(src,\"manual\",st[\"edit\"],st[\"goal\"],user); vlm=round(1+4*st[\"m\"][\"realism\"],2)\n","    store.add_iteration(sid,0,st[\"img\"],st[\"mask\"],st[\"plan\"],st[\"meta\"],st[\"m\"],score>=4,vlm=vlm,\n","                        human=float(score),scored_by=user,orig_path=store.orig_path(src),\n","                        skin_tone=st.get(\"tone\"),lip_shade=st.get(\"shade\"))\n","    return f\"Saved · your score {score}/5.\",{}\n","def _q(m): return 0.6*m[\"realism\"]+0.4*m[\"identity\"]\n","def manual_refine(st, user):\n","    if not st or \"img\" not in st: return None,None,\"Generate first.\",st,_box(user)\n","    new=dict(st); new[\"plan\"]=refine_plan(st[\"plan\"],st[\"m\"])\n","    img,mask,meta=generate(st[\"orig\"],new[\"plan\"],int(new[\"plan\"][\"seed\"]),st[\"model\"]); m=score_fn(st[\"orig\"],img,mask)\n","    if _q(m) < _q(st[\"m\"]):                          # new attempt worse -> keep the better previous one\n","        return st[\"img\"],_ov(st[\"orig\"].resize(st[\"img\"].size),st[\"mask\"]),f\"kept the better version · realism {st['m']['realism']:.2f} · identity {st['m']['identity']:.2f}\",st,_box(user)\n","    new.update(img=img,mask=mask,meta=meta,m=m)\n","    return img,_ov(st[\"orig\"].resize(img.size),mask),f\"improved · realism {m['realism']:.2f} · identity {m['identity']:.2f}\",new,_box(user)\n","\n","# ---------- Batch (admin) with RESUME ----------\n","def batch_load(n, edit, model, user, progress=gr.Progress()):\n","    if user not in ADMINS: return \"Admin only.\",None,None,-1,None,gr.update(),\"\"\n","    done=store.done_celeba_files(extra_csv=DONE_CSV if 'DONE_CSV' in globals() else None)\n","    pool=load_celeba_small(IMAGES_DIR,CAPTIONS_CSV,n=1500)\n","    todo=[p for p in pool if os.path.basename(p[0]) not in done][:int(n)]\n","    if not todo: return f\"All done — {len(done)} unique photos scored. 🎉\",None,None,-1,None,gr.update(),\"\"\n","    q=[]; cyc=list(EDITS.keys()); mlist=[\"realistic-vision\",\"juggernaut-xl\"] if model==\"(cycle both)\" else [model]\n","    skipped=0\n","    for k,(p,img,attrs) in progress.tqdm(list(enumerate(todo)),desc=\"generating\"):\n","        try:\n","            ek=_key(edit) if edit!=\"(cycle all)\" else cyc[k%len(cyc)]; mdl=mlist[k%len(mlist)]\n","            sid=store.new_source(\"celeba\",os.path.basename(p),attrs,img,source_path=p)\n","            _,iid,out,mask,m,vlm=run_and_store(store,sid,img,ek,generate,score_fn,mode=\"batch\",username=user,model=mdl)\n","            q.append({\"iid\":iid,\"img\":out,\"orig\":img,\"edit\":ek,\"model\":mdl,\"vlm\":vlm,\"src\":sid})\n","        except Exception as e:\n","            skipped+=1; print(\"skipped one photo:\", str(e)[:80]); continue\n","    if not q: return \"All loaded photos failed to generate — check the model/GPU.\",None,None,-1,None,gr.update(),\"\"\n","    f=q[0]\n","    return (f\"Loaded {len(q)} photos\"+(f\" ({skipped} skipped)\" if skipped else \"\")+f\" · {len(done)}/1500 done.\",\n","            f[\"orig\"], f[\"img\"], 0, q, gr.update(value=round(f[\"vlm\"])), f\"1 / {len(q)} · {f['edit']} · {f['model']}\")\n","def _show(q,idx):\n","    it=q[idx]; return it[\"orig\"],it[\"img\"],gr.update(value=round(it[\"vlm\"])),f\"{idx+1} / {len(q)} · {it['edit']} · {it['model']}\"\n","def batch_score(score, q, idx, user):\n","    if not q or idx<0 or idx>=len(q): return None,None,idx,q,gr.update(),\"\"\n","    store.update_score(q[idx][\"iid\"], float(score), user); idx+=1\n","    if idx>=len(q):\n","        c=store.table_counts(); return None,None,idx,q,gr.update(),f\"Chunk done. DB now {c['iterations']} rows. Load the next batch.\"\n","    o,e,sc,cap=_show(q,idx); return o,e,idx,q,sc,cap\n","def batch_refine(q, idx, user):\n","    if not q or idx<0 or idx>=len(q): return None,None,idx,q,gr.update(),\"\"\n","    it=q[idx]; base=build_plan(it[\"edit\"]); base[\"_iter\"]=it.get(\"ref\",0)\n","    plan=refine_plan(base,{\"identity\":0.82,\"realism\":0.5})\n","    img,mask,meta=generate(it[\"orig\"],plan,int(plan[\"seed\"]),it[\"model\"]); m=score_fn(it[\"orig\"],img,mask)\n","    sid=store.new_session(it[\"src\"],\"batch\",it[\"edit\"],None,user); vlm=round(1+4*m[\"realism\"],2)\n","    iid=store.add_iteration(sid,0,img,mask,plan,meta,m,False,vlm=vlm,orig_path=store.orig_path(it[\"src\"]))\n","    q[idx]={\"iid\":iid,\"img\":img,\"orig\":it[\"orig\"],\"edit\":it[\"edit\"],\"model\":it[\"model\"],\"vlm\":vlm,\"src\":it[\"src\"],\"ref\":it.get(\"ref\",0)+1}\n","    o,e,sc,cap=_show(q,idx); return o,e,idx,q,sc,\"refined (stronger) — re-score: \"+cap\n","\n","# ---------- One-shot: DSPy-style proactive suggest + SSIM ----------\n","def preferred_edits(k=3):\n","    con=store._c()\n","    rows=con.execute(\"SELECT edit_type, AVG(human_score) s, COUNT(*) n FROM iterations WHERE human_score IS NOT NULL GROUP BY edit_type HAVING n>=1 ORDER BY s DESC\").fetchall()\n","    con.close()\n","    prefs=[r[\"edit_type\"] for r in rows if (r[\"s\"] or 0)>=4]\n","    return (prefs or [\"clear_skin\",\"natural_makeup\",\"youthful\"])[:k]\n","def oneshot_analyze(image, user):\n","    if image is None: return None,\"Upload a photo to analyze.\"\n","    tone=detect_skin_tone(image); shade,why=recommend_shade(store,tone)\n","    prefs=preferred_edits(3)\n","    if \"lipstick\" not in prefs: prefs=prefs[:2]+[\"lipstick\"]\n","    cards=[]; ranked=[]\n","    for ek in prefs:\n","        sh=shade if ek==\"lipstick\" else None\n","        plan=build_plan(ek,shade=sh); img,mask,meta=generate(image,plan,42,\"realistic-vision\"); m=score_fn(image,img,mask)\n","        ss=_ssim2(image,img); score=0.5*m[\"realism\"]+0.3*m[\"identity\"]+0.2*ss\n","        lbl=EDITS[ek][\"label\"]+(f\" ({shade})\" if ek==\"lipstick\" else \"\")\n","        ranked.append((score,lbl,img,m,ss))\n","    ranked.sort(reverse=True)\n","    for score,lbl,img,m,ss in ranked:\n","        cards.append((img, f\"{lbl} · realism {m['realism']:.2f} · identity {m['identity']:.2f} · SSIM {ss:.2f}\"))\n","    return cards, (f\"Detected skin tone: **{tone}** → suggested lip shade **{shade}** ({why}).\\n\\n\"\n","                   f\"Top pick: **{ranked[0][1]}**. Ranked by realism, identity and SSIM — nothing is applied without your choice.\")\n","\n","# ---------- Community feed: per-user scoring + consensus ----------\n","def feed_load():\n","    con=store._c()\n","    rows=con.execute(\"SELECT iter_id,image_path,edit_type,human_score FROM iterations WHERE image_path IS NOT NULL ORDER BY human_score DESC, iter_id DESC LIMIT 30\").fetchall()\n","    con.close(); q=[dict(r) for r in rows if os.path.exists(r[\"image_path\"])]\n","    if not q: return None,-1,q,\"No posts yet — score some in Batch or Manual and they'll appear here.\"\n","    return _feed_card(q,0)\n","def _feed_card(q,idx):\n","    it=q[idx]; cons,nv=store.consensus(it[\"iter_id\"])\n","    cap=f\"### Post {idx+1} of {len(q)}\\n**{it['edit_type']}** · community rating **{cons if cons else '—new'}** from {nv} people\\n\\nWhat would *you* rate this? Your score is saved too.\"\n","    return it[\"image_path\"],idx,q,cap\n","def feed_score(val, q, idx, user):\n","    if not q or idx<0 or idx>=len(q): return None,idx,q,\"\",_box(user)\n","    store.add_community_score(q[idx][\"iter_id\"], user, val); store.add_shuriken(user,1)\n","    idx+=1\n","    if idx>=len(q): return None,idx,q,f\"### That's the feed for now\\nYou earned shuriken. Balance {_bal(user)}.\",_box(user)\n","    p,i,qq,cap=_feed_card(q,idx); return p,i,qq,cap,_box(user)\n","\n","def do_csv(): return store.export_csv()\n","def do_zip(): return store.export_zip()\n","def _ov(img,mask,color=(84,214,199)):\n","    b=np.array(img.convert(\"RGB\").resize(mask.size)); a=(np.array(mask.convert(\"L\"))>90)\n","    b[a]=(0.45*np.array(color)+0.55*b[a]).astype(\"uint8\"); return Image.fromarray(b)\n","\n","with gr.Blocks(css=CSS,title=\"Vision Studio\",theme=gr.themes.Base()) as demo:\n","    user=gr.State(\"guest\")\n","    shbox=gr.HTML(_box(\"guest\"))\n","    gr.Markdown(\"# Vision Studio\")\n","    with gr.Row() as signin_row:\n","        nm=gr.Textbox(label=\"Username\",scale=3,placeholder=\"admins: admin / zaki / fahima\")\n","        si=gr.Button(\"Sign in\",scale=1,variant=\"primary\")\n","    who=gr.Markdown(\"\")\n","\n","    with gr.Tab(\"Manual\"):\n","        with gr.Row(equal_height=True):\n","            mi=gr.Image(type=\"pil\",label=\"Photo\",height=420,width=340)\n","            mr=gr.Image(label=\"Edited region (MediaPipe)\",height=420,width=340)\n","            ma=gr.Image(label=\"Result\",height=420,width=340)\n","        with gr.Row():\n","            me=gr.Dropdown(EDIT_CHOICES,value=\"natural_makeup\",label=\"Edit\",scale=2)\n","            mshade=gr.Dropdown(LIP_SHADES,value=\"rosy pink\",label=\"Lip shade\",scale=1,visible=False)\n","            mm=gr.Dropdown([\"realistic-vision\",\"juggernaut-xl\",\"epicrealism\"],value=\"realistic-vision\",label=\"Model\",scale=1)\n","            mg=gr.Textbox(label=\"Note (optional)\",scale=2)\n","        mgo=gr.Button(\"Generate (1 shuriken)\",variant=\"primary\")\n","        mn=gr.Markdown()\n","        with gr.Row():\n","            msl=gr.Slider(1,5,step=1,value=4,label=\"Your score\",scale=3)\n","            msave=gr.Button(\"Save score\",scale=1); mref=gr.Button(\"Refine\",scale=1)\n","        mst=gr.State({})\n","        me.change(lambda e: gr.update(visible=(_key(e)=='lipstick')), me, mshade)\n","        mgo.click(manual_gen,[mi,me,mg,mshade,mm,user,mst],[ma,mr,mn,mst,shbox])\n","        msave.click(manual_rate,[msl,mst,user],[mn,mst])\n","        mref.click(manual_refine,[mst,user],[ma,mr,mn,mst,shbox])\n","\n","    with gr.Tab(\"Batch — score one by one (admin)\",visible=False) as bt:\n","        gr.Markdown(\"Load the next chunk, compare original vs edit, score 1–5. Resumes automatically where you left off.\")\n","        with gr.Row():\n","            bn=gr.Slider(10,300,value=50,step=10,label=\"Photos per chunk (use 50 to avoid timeouts)\")\n","            be=gr.Dropdown([\"(cycle all)\"]+[c[0] for c in EDIT_CHOICES],value=\"(cycle all)\",label=\"Edit\")\n","            bmodel=gr.Dropdown([\"realistic-vision\",\"juggernaut-xl\",\"(cycle both)\"],value=\"realistic-vision\",label=\"Model\")\n","            bload=gr.Button(\"Load & generate\",variant=\"primary\")\n","        bstat=gr.Markdown()\n","        with gr.Row():\n","            borig=gr.Image(label=\"Original\",height=380,width=330); bedit=gr.Image(label=\"Edited — score this\",height=380,width=330)\n","        bcap=gr.Markdown()\n","        bscore=gr.Slider(1,5,step=1,value=4,label=\"Human score\")\n","        with gr.Row(): brefine=gr.Button(\"🔄 Refine (too low)\"); bnext=gr.Button(\"Save score → next\",variant=\"primary\")\n","        bq=gr.State([]); bidx=gr.State(-1)\n","        bload.click(batch_load,[bn,be,bmodel,user],[bstat,borig,bedit,bidx,bq,bscore,bcap])\n","        bnext.click(batch_score,[bscore,bq,bidx,user],[borig,bedit,bidx,bq,bscore,bcap])\n","        brefine.click(batch_refine,[bq,bidx,user],[borig,bedit,bidx,bq,bscore,bcap])\n","\n","    with gr.Tab(\"✨ One-shot\"):\n","        gr.Markdown(\"### One-shot consultation\\nUpload a face. The system suggests the edits people rate highest, ranked by realism, identity and SSIM. You choose what to apply.\")\n","        with gr.Row():\n","            oi=gr.Image(type=\"pil\",label=\"Your photo\",height=380,width=330)\n","            with gr.Column():\n","                ogo=gr.Button(\"Analyze & suggest\",variant=\"primary\")\n","                onote=gr.Markdown()\n","        ogal=gr.Gallery(label=\"Suggestions (ranked)\",columns=3,height=320)\n","        ogo.click(oneshot_analyze,[oi,user],[ogal,onote])\n","\n","    with gr.Tab(\"Community\"):\n","        gr.Markdown(\"### Community feed\\nRate how real each result looks. Every rating is saved, so a photo an admin scored 5 can still become a community 4 — the consensus blends everyone.\")\n","        cimg=gr.Image(label=\"\",height=440,elem_id=\"feedimg\"); ccap=gr.Markdown()\n","        with gr.Row():\n","            c1=gr.Button(\"1\"); c2=gr.Button(\"2\"); c3=gr.Button(\"3\"); c4=gr.Button(\"4\"); c5=gr.Button(\"5\"); cskip=gr.Button(\"↻\")\n","        cq=gr.State([]); cidx=gr.State(-1)\n","        cskip.click(feed_load,None,[cimg,cidx,cq,ccap])\n","        for b,v in [(c1,1),(c2,2),(c3,3),(c4,4),(c5,5)]:\n","            b.click(lambda q,i,u,v=v: feed_score(v,q,i,u),[cq,cidx,user],[cimg,cidx,cq,ccap,shbox])\n","\n","    with gr.Tab(\"Data\"):\n","        gr.Markdown(\"Export your dataset. ZIP = all iterations + originals grouped per photo + a CSV (manual backup).\")\n","        with gr.Row():\n","            excsv=gr.Button(\"Export CSV\"); exzip=gr.Button(\"Export ZIP\",variant=\"primary\")\n","        exf=gr.File(label=\"download\")\n","        excsv.click(do_csv,None,exf); exzip.click(do_zip,None,exf)\n","\n","    si.click(sign_in,[nm],[user,who,bt,shbox,signin_row]); demo.load(feed_load,None,[cimg,cidx,cq,ccap])\n","demo.launch(share=True)\n"]},{"cell_type":"markdown","id":"ba5c7241","metadata":{"papermill":{"duration":0.007381,"end_time":"2026-07-11T05:51:08.28431+00:00","exception":false,"start_time":"2026-07-11T05:51:08.276929+00:00","status":"completed"},"tags":[]},"source":["---\n","### When you finish scoring\n","1. **Data tab → Export ZIP** (downloads all iterations + originals + datase