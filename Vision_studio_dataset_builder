candidate's header and only accept one that actually has a prompt + score column.\n","import pandas as _pd\n","_PROMPT_HINTS = [\"refined_prompt\",\"final_prompt\",\"optimized_prompt\",\"edited_prompt\",\"prompt\"]\n","_SCORE_HINTS  = [\"realism_score\",\"realism\",\"human_score\",\"quality_score\",\"rating\",\"score\"]\n","def _looks_like_results(path):\n","    try:\n","        cols = [str(c).strip().lower() for c in _pd.read_csv(path, nrows=0).columns]\n","    except Exception:\n","        return False\n","    has_prompt = any(any(h in c for h in _PROMPT_HINTS) for c in cols)\n","    has_score  = any(any(h in c for h in _SCORE_HINTS)  for c in cols)\n","    return has_prompt and has_score\n","\n","# Candidates, best-named first, then every csv under inputs/working as a last resort.\n","_cands = (glob.glob(\"/kaggle/input/**/*vision*studio*.csv\", recursive=True)\n","          + glob.glob(\"/kaggle/input/**/*result*.csv\", recursive=True)\n","          + [\"/kaggle/working/june 5th vision studio data.csv\"]\n","          + glob.glob(\"/kaggle/working/*.csv\")\n","          + glob.glob(\"/kaggle/input/**/*.csv\", recursive=True))\n","_seen, CSV_PATH = set(), None\n","for _p in _cands:\n","    if _p in _seen or not os.path.exists(_p): continue\n","    _seen.add(_p)\n","    if _looks_like_results(_p): CSV_PATH = _p; break\n","\n","if CSV_PATH:\n","    print(\"Recorded CSV :\", CSV_PATH)\n","else:\n","    print(\"Recorded CSV : NOT FOUND — no csv with a prompt+score column was located.\")\n","    _all = [p for p in _cands if os.path.exists(p)]\n","    if _all:\n","        print(\"  CSVs I did see (none matched):\")\n","        for _p in _all[:10]: print(\"   -\", _p)\n","        print(\"  → Add your 'june 5th vision studio data.csv' as an input, or drop it in /kaggle/working/.\")\n","    else:\n","        print(\"  → No csv files present at all. Add the results dataset or upload the file to /kaggle/working/.\")\n","    print(\"  (The notebook still runs — it falls back