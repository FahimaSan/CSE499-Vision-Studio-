apters.json_adapter: Failed to use structured output format, falling back to JSON mode.\n","100%|██████████| 1/1 [00:22<00:00, 22.27s/it]\n"]},{"name":"stdout","output_type":"stream","text":["Bootstrapped 1 full traces after 0 examples for up to 1 rounds, amounting to 1 attempts.\n","DSPy optimized with LM against your human-preference reward\n"]},{"name":"stderr","output_type":"stream","text":["2026/07/13 10:30:08 WARNING dspy.adapters.json_adapter: Failed to use structured output format, falling back to JSON mode.\n"]},{"name":"stdout","output_type":"stream","text":["  DSPy for unknown -> add_beard\n"]}],"source":["import dspy\n","class RecommendEdit(dspy.Signature):\n","    \"\"\"Given skin tone and concerns, recommend the best cosmetic edit + a photorealistic prompt, preserving identity.\"\"\"\n","    skin_tone=dspy.InputField(); concerns=dspy.InputField()\n","    edit=dspy.OutputField(desc=\"one edit key\"); prompt=dspy.OutputField()\n","def policy_pick(t):\n","    r=POLICY.get(t) or POLICY.get(\"unknown\") or [(\"youthful\",4.0)]; return r[0][0]\n","class OneShotRecommender(dspy.Module):\n","    def __init__(self): super().__init__(); self.think=dspy.Predict(RecommendEdit)\n","    def forward(self, skin_tone, concerns):\n","        try:\n","            o=self.think(skin_tone=skin_tone,concerns=concerns)\n","            return dspy.Prediction(edit=o.edit if o.edit in EDITS else policy_pick(skin_tone), prompt=o.prompt)\n","        except Exception:\n","            ek=policy_pick(skin_tone); return dspy.Prediction(edit=ek, prompt=build_plan(ek)[\"prompt\"])\n","def reward_metric(ex,pred,trace=None):\n","    ranked={e:s for e,s in (POLICY.get(ex.skin_tone) or [])}; return float(ranked.get(pred.edit,0.0))/5.0\n","RECOMMENDER=OneShotRecommender()\n","try:\n","    if os.environ.get(\"OPENAI_API_KEY\"):\n","        dspy.configure(lm=dspy.LM(\"openai/gpt-4o-mini\"))\n","        trainset=[dspy.Example(skin_tone=t,concerns=\"general\",edit=POLICY[t][0][0],\n","                    prompt=build_plan(POLICY[t][0][0])[\"prompt\"]).with_inputs(\"skin_tone\",\"concerns\") for t in POLICY]\n","        from dspy.teleprompt import BootstrapFewShot\n","        RECOMMENDER=BootstrapFewShot(metric=reward_metric,max_bootstrapped_demos=4).compile(OneShotRecommender(),trainset=trainset)\n","        print(\"DSPy optimized with LM against your human-preference reward\")\n","    else:\n","        print(\"DSPy policy mode (no key)\")\n","except Exception as e: print(\"DSPy policy mode:\",str(e)[:60])\n","for t in POLICY: print(\"  DSPy for\",t,\"->\",RECOMMENDER(skin_tone=t,concerns=\"general\").edit)"]},{"cell_type":"markdown","id":"dfe44666","metadata":{"papermill":{"duration":0.007276,"end_time":"2026-07-13T10:30:15.001909+00:00","exception":false,"start_time":"2026-07-13T10:30:14.994633+00:00","status":"completed"},"tags":[]},"source":["### 💾 Save the trained brain (Save Version, then attach as input to skip training next time)"]},{"cell_type":"code","execution_count":18,"id":"d0b5df89","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:30:15.017173Z","iopub.status.busy":"2026-07-13T10:30:15.016505Z","iopub.status.idle":"2026-07-13T10:30:15.03024Z","shell.execute_reply":"2026-07-13T10:30:15.029433Z"},"papermill":{"duration":0.022805,"end_time":"2026-07-13T10:30:15.031891+00:00","exception":false,"start_time":"2026-07-13T10:30:15.009086+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["saved brain -> /kaggle/working/brain/\n"]}],"source":["import joblib, json, shutil\n","os.makedirs(\"/kaggle/working/brain\",exist_ok=True)\n","if HUMAN_SCORER is not None: joblib.dump(HUMAN_SCORER,\"/kaggle/working/brain/scorer.joblib\")\n","json.dump({\"POLICY\":POLICY,\"SHADE_POLICY\":SHADE_POLICY,\"EDIT_VOCAB\":EDIT_VOCAB},open(\"/kaggle/working/brain/policy.json\",\"w\"))\n","if os.path.exists(\"/kaggle/working/vision_studio/vision_studio.db\"):\n","    shutil.copy(\"/kaggle/working/vision_studio/vision_studio.db\",\"/kaggle/working/brain/vision_studio.db\")\n","print(\"saved brain -> /kaggle/working/brain/\")"]},{"cell_type":"markdown","id":"e90985ad","metadata":{"papermill":{"duration":0.006334,"end_time":"2026-07-13T10:30:15.045062+00:00","exception":false,"start_time":"2026-07-13T10:30:15.038728+00:00","status":"completed"},"tags":[]},"source":["---\n","## Part 4 · Launch the app — One-shot uses SSIM + DSPy + learned scorer"]},{"cell_type":"code","execution_count":19,"id":"c8e06c28","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:30:15.059966Z","iopub.status.busy":"2026-07-13T10:30:15.059527Z","iopub.status.idle":"2026-07-13T10:30:17.556202Z","shell.execute_reply":"2026-07-13T10:30:17.555586Z"},"papermill":{"duration":2.506214,"end_time":"2026-07-13T10:30:17.557847+00:00","exception":false,"start_time":"2026-07-13T10:30:15.051633+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["* Running on local URL:  http://127.0.0.1:7860\n","* Running on public URL: https://2a34930de6f3aff354.gradio.live\n","\n","This share link expires in 1 week. For free permanent hosting and GPU upgrades, run `gradio deploy` from the terminal in the working directory to deploy to Hugging Face Spaces (https://huggingface.co/spaces)\n"]},{"data":{"text/html":["<div><iframe src=\"https://2a34930de6f3aff354.gradio.live\" width=\"100%\" height=\"500\" allow=\"autoplay; camera; microphone; clipboard-read; clipboard-write;\" frameborder=\"0\" allowfullscreen></iframe></div>"],"text/plain":["<IPython.core.display.HTML object>"]},"metadata":{},"output_type":"display_data"},{"data":{"text/plain":[]},"execution_count":19,"metadata":{},"output_type":"execute_result"}],"source":["# ── VISION STUDIO ── Manual · Batch (resume, admin) · One-shot (DSPy+SSIM) · Community feed · Data ──\n","import gradio as gr\n","from skimage.metrics import structural_similarity as _ssim\n","import numpy as np\n","CSS=\"\"\"\n",".gradio-container{max-width:100%!important;background:#0b0e13!important}\n","#shbox{position:fixed;top:8px;right:14px;z-index:99;background:#141b24;border:1px solid #2a3644;border-radius:12px;padding:6px 14px;font-weight:700;color:#ffd166}\n",".card{background:#121821;border:1px solid #223041;border-radius:16px;padding:14px}\n","h1,h2,h3{color:#e9eef5}\n","#feedimg img{border-radius:18px}\n",".gr-button-primary{background:linear-gradient(90deg,#ff7a45,#ff5470)!important;border:0!important}\n","\"\"\"\n","SH=\"🌟\"\n","ADMINS={\"admin\",\"zaki\",\"fahima\"}\n","EDIT_CHOICES=[(v[\"label\"],k) for k,v in EDITS.items()]\n","LABEL2KEY={v[\"label\"]:k for k,v in EDITS.items()}\n","def _key(e): return e if e in EDITS else LABEL2KEY.get(e,\"add_makeup\")\n","def _bal(u): n,adm=store.shuriken(u); return \"∞\" if adm else n\n","def _box(u): return f\"<div id='shbox'>{SH} {_bal(u)}</div>\"\n","def _ssim2(a_pil,b_pil):\n","    a=np.array(a_pil.convert(\"L\").resize((256,256))); b=np.array(b_pil.convert(\"L\").resize((256,256)))\n","    return float(_ssim(a,b))\n","\n","def sign_in(name):\n","    name=(name or \"guest\").strip().lower(); adm=name in ADMINS; store.ensure_user(name,is_admin=adm)\n","    return name, f\"### Welcome, {name}\"+(\"  ·  admin\" if adm else \"\"), gr.update(visible=adm), _box(name), gr.update(visible=False)\n","\n","# ---------- Manual ----------\n","def manual_gen(image, edit, goal, shade, model, user, st):\n","    if image is None: return None,None,\"Upload a photo first.\",st,_box(user)\n","    ok,rem=store.spend_shuriken(user,1)\n","    if not ok: return None,None,\"Out of shuriken. Score in Community to earn more.\",st,_box(user)\n","    ek=_key(edit); tone=detect_skin_tone(image)\n","    use_shade=shade if ek in ('lipstick',) else None\n","    plan=build_plan(ek,goal,shade=use_shade)\n","    img,mask,meta=generate(image,plan,int(plan[\"seed\"]),model); m=score_fn(image,img,mask)\n","    st={\"orig\":image,\"edit\":ek,\"goal\":goal,\"user\":user,\"img\":img,\"mask\":mask,\"meta\":meta,\"m\":m,\"plan\":plan,\"model\":model,\"tone\":tone,\"shade\":use_shade}\n","    tip=f\" · skin tone **{tone}**\" + (f\" · shade **{use_shade}**\" if use_shade else \"\")\n","    note=f\"region **{plan['region']}** · realism {m['realism']:.2f} · identity {m['identity']:.2f}{tip}\"\n","    return img,_ov(image.resize(img.size),mask),note,st,_box(user)\n","def manual_rate(score, st, user):\n","    if not st or \"img\" not in st: return \"Generate first.\",st\n","    src=store.new_source(\"upload\",\"manual\",{},st[\"orig\"].resize((256,256)))\n","    sid=store.new_session(src,\"manual\",st[\"edit\"],st[\"goal\"],user); vlm=round(1+4*st[\"m\"][\"realism\"],2)\n","    store.add_iteration(sid,0,st[\"img\"],st[\"mask\"],st[\"plan\"],st[\"meta\"],st[\"m\"],score>=4,vlm=vlm,\n","                        human=float(score),scored_by=user,orig_path=store.orig_path(src),\n","                        skin_tone=st.get(\"tone\"),lip_shade=st.get(\"shade\"))\n","    return f\"Saved · your score {score}/5.\",{}\n","def _q(m): return 0.6*m[\"realism\"]+0.4*m[\"identity\"]\n","def manual_refine(st, user):\n","    if not st or \"img\" not in st: return None,None,\"Generate first.\",st,_box(user)\n","    new=dict(st); new[\"plan\"]=refine_plan(st[\"plan\"],st[\"m\"])\n","    img,mask,meta=generate(st[\"orig\"],new[\"plan\"],int(new[\"plan\"][\"seed\"]),st[\"model\"]); m=score_fn(st[\"orig\"],img,mask)\n","    if _q(m) < _q(st[\"m\"]):                          # new attempt worse -> keep the better previous one\n","        return st[\"img\"],_ov(st[\"orig\"].resize(st[\"img\"].size),st[\"mask\"]),f\"kept the better version · realism {st['m']['realism']:.2f} · identity {st['m']['identity']:.2f}\",st,_box(user)\n","    new.update(img=img,mask=mask,meta=meta,m=m)\n","    return img,_ov(st[\"orig\"].resize(img.size),mask),f\"improved · realism {m['realism']:.2f} · identity {m['identity']:.2f}\",new,_box(user)\n","\n","# ---------- Batch (admin) with RESUME ----------\n","def batch_load(n, edit, model, user, progress=gr.Progress()):\n","    if user not in ADMINS: return \"Admin only.\",None,None,-1,None,gr.update(),\"\"\n","    done=store.done_celeba_files(extra_csv=DONE_CSV if 'DONE_CSV' in globals() else None)\n","    pool=load_celeba_small(IMAGES_DIR,CAPTIONS_CSV,n=1500)\n","    todo=[p for p in pool if os.path.basename(p[0]) not in done][:int(n)]\n","    if not todo: return f\"All done — {len(done)} unique photos scored. 🎉\",None,None,-1,None,gr.update(),\"\"\n","    q=[]; cyc=list(EDITS.keys()); mlist=[\"realistic-vision\",\"juggernaut-xl\"] if model==\"(cycle both)\" else [model]\n","    skipped=0\n","    for k,(p,img,attrs) in progress.tqdm(list(enumerate(todo)),desc=\"generating\"):\n","        try:\n","            ek=_key(edit) if edit!=\"(cycle all)\" else cyc[k%len(cyc)]; mdl=mlist[k%len(mlist)]\n","            sid=store.new_source(\"celeba\",os.path.basename(p),attrs,img,source_path=p)\n","            _,iid,out,mask,m,vlm=run_and_store(store,sid,img,ek,generate,score_fn,mode=\"batch\",username=user,model=mdl)\n","            q.append({\"iid\":iid,\"img\":out,\"orig\":img,\"edit\":ek,\"model\":mdl,\"vlm\":vlm,\"src\":sid})\n","        except Exception as e:\n","            skipped+=1; print(\"skipped one photo:\", str(e)[:80]); continue\n","    if not q: return \"All loaded photos failed to generate — check the model/GPU.\",None,None,-1,None,gr.update(),\"\"\n","    f=q[0]\n","    return (f\"Loaded {len(q)} photos\"+(f\" ({skipped} skipped)\" if skipped else \"\")+f\" · {len(done)}/1500 done.\",\n","            f[\"orig\"], f[\"img\"], 0, q, gr.update(value=round(f[\"vlm\"])), f\"1 / {len(q)} · {f['edit']} · {f['model']}\")\n","def _show(q,idx):\n","    it=q[idx]; return it[\"orig\"],it[\"img\"],gr.update(value=round(it[\"vlm\"])),f\"{idx+1} / {len(q)} · {it['edit']} · {it['model']}\"\n","def batch_score(score, q, idx, user):\n","    if not q or idx<0 or idx>=len(q): return None,None,idx,q,gr.update(),\"\"\n","    store.update_score(q[idx][\"iid\"], float(score), user); idx+=1\n","    if idx>=len(q):\n","        c=store.table_counts(); return None,None,idx,q,gr.update(),f\"Chunk done. DB now {c['iterations']} rows. Load the next batch.\"\n","    o,e,sc,cap=_show(q,idx); return o,e,idx,q,sc,cap\n","def batch_refine(q, idx, user):\n","    if not q or idx<0 or idx>=len(q): return None,None,idx,q,gr.update(),\"\"\n","    it=q[idx]; base=build_plan(it[\"edit\"]); base[\"_iter\"]=it.get(\"ref\",0)\n","    plan=refine_plan(base,{\"identity\":0.82,\"realism\":0.5})\n","    img,mask,meta=generate(it[\"orig\"],plan,int(plan[\"seed\"]),it[\"model\"]); m=score_fn(it[\"orig\"],img,mask)\n","    sid=store.new_session(it[\"src\"],\"batch\",it[\"edit\"],None,user); vlm=round(1+4*m[\"realism\"],2)\n","    iid=store.add_iteration(sid,0,img,mask,plan,meta,m,False,vlm=vlm,orig_path=store.orig_path(it[\"src\"]))\n","    q[idx]={\"iid\":iid,\"img\":img,\"orig\":it[\"orig\"],\"edit\":it[\"edit\"],\"model\":it[\"model\"],\"vlm\":vlm,\"src\":it[\"src\"],\"ref\":it.get(\"ref\",0)+1}\n","    o,e,sc,cap=_show(q,idx); return o,e,idx,q,sc,\"refined (stronger) — re-score: \"+cap\n","\n","# ---------- One-shot: DSPy-style proactive suggest + SSIM ----------\n","def preferred_edits(k=3):\n","    con=store._c()\n","    rows=con.execute(\"SELECT edit_type, AVG(human_score) s, COUNT(*) n FROM iterations WHERE human_score IS NOT NULL GROUP BY edit_type HAVING n>=1 ORDER BY s DESC\").fetchall()\n","    con.close()\n","    prefs=[r[\"edit_type\"] for r in rows if (r[\"s\"] or 0)>=4]\n","    return (prefs or [\"clear_skin\",\"natural_makeup\",\"youthful\"])[:k]\n","def _trained(): return \"RECOMMENDER\" in globals() and \"HUMAN_SCORER\" in globals() and globals().get(\"HUMAN_SCORER\") is not None\n","def oneshot_analyze(image, gender, user):\n","    if image is None: return None,\"Upload a photo to analyze.\"\n","    tone=detect_skin_tone(image)\n","    if \"SHADE_POLICY\" in globals() and SHADE_POLICY.get(tone): shade=SHADE_POLICY[tone][0][0]\n","    else: shade,_=recommend_shade(store,tone)\n","    c=detect_concerns(image)                                   # severity 0..1 per concern\n","    # map each concern to the edit that fixes it, keep only real ones, sort by SEVERITY (worst first)\n","    fixes=[(\"severe acne\" if c[\"acne\"]>0.6 else \"acne\", c[\"acne\"], \"clear_skin\"),\n","           (\"deep wrinkles\" if c[\"wrinkle\"]>0.6 else \"wrinkles\", c[\"wrinkle\"], \"youthful\"),\n","           (\"very full face\" if c[\"fat\"]>0.6 else \"full face\", c[\"fat\"], \"slimming\")]\n","    priority=[f for f in fixes if f[1]>0.30]\n","    priority.sort(key=lambda x:-x[1])                          # most serious issue first\n","    sev_of={f[2]:f[1] for f in priority}\n","    # candidates: priority fixes (worst first) then gender-appropriate universals\n","    universal=[\"add_beard\",\"remove_beard\"] if gender==\"Man\" else [\"lipstick\",\"smokey_glam\",\"lip_filler\"]\n","    cands=[f[2] for f in priority]+[e for e in universal if e not in sev_of]\n","    cands=cands[:5]\n","    ranked=[]\n","    for ek in cands:\n","        sh=shade if ek==\"lipstick\" else None\n","        plan=build_plan(ek,shade=sh); img,mask,meta=generate(image,plan,42,\"realistic-vision\"); m=score_fn(image,img,mask)\n","        ss=_ssim2(image,img)\n","        if _trained() and \"_feat\" in globals() and \"EDIT_VOCAB\" in globals():\n","            img.convert(\"RGB\").resize((128,128)).save(\"/tmp/_qq.png\")\n","            q=float(HUMAN_SCORER.predict([_feat(\"/tmp/_qq.png\")+[1.0 if ek==e else 0.0 for e in EDIT_VOCAB]])[0])\n","        else: q=1+4*m[\"realism\"]\n","        sev=sev_of.get(ek,0.0)\n","        # RANK: severity dominates (worst problem = top), predicted human score refines within that\n","        rank_key=sev*3.0 + (q/5.0)\n","        ranked.append((rank_key,ek,img,q,ss,sev))\n","    ranked.sort(reverse=True); top3=ranked[:3]\n","    cards=[]\n","    for rk,ek,img,q,ss,sev in top3:\n","        badge=\" ⚠ priority\" if sev>0.6 else (\" · addresses concern\" if sev>0.3 else \"\")\n","        cards.append((img, f\"{EDITS[ek]['label']}\"+(f\" ({shade})\" if ek=='lipstick' else \"\")+f\" · predicted {q:.1f}/5 · SSIM {ss:.2f}{badge}\"))\n","    worst=priority[0] if priority else None\n","    if worst:\n","        head=(f\"Most serious issue detected: **{worst[0]}** (severity {worst[1]:.0%}). \"\n","              f\"Top recommendation: **{EDITS[top3[0][1]]['label']}** to address it, \"\n","              f\"predicted **{top3[0][3]:.1f}/5** with identity SSIM **{top3[0][4]:.2f}**.\")\n","    else:\n","        head=(f\"No strong facial concerns detected. Suggesting enhancement edits. \"\n","              f\"Top pick: **{EDITS[top3[0][1]]['label']}** at predicted **{top3[0][3]:.1f}/5**.\")\n","    detected=\", \".join([f[0] for f in priority]) if priority else \"none\"\n","    note=f\"**{gender}** · skin tone **{tone}** · shade **{shade}** · concerns by severity: {detected}\\n\\n{head}\"\n","    return cards, note\n","\n","# ---------- Community feed: per-user scoring + consensus ----------\n","def feed_load():\n","    con=store._c()\n","    rows=con.execute(\"SELECT iter_id,image_path,edit_type,human_score FROM iterations WHERE image_path IS NOT NULL AND human_score>=3 ORDER BY RANDOM() LIMIT 30\").fetchall()\n","    con.close(); q=[dict(r) for r in rows if os.path.exists(r[\"image_path\"])]\n","    if not q: return None,-1,q,\"No posts yet — score some images (3+) and they'll appear here.\"\n","    return _feed_card(q,0)\n","def _feed_card(q,idx):\n","    it=q[idx]; cons,nv=store.consensus(it[\"iter_id\"])\n","    cap=f\"### Post {idx+1} of {len(q)}\\n**{it['edit_type']}** · community rating **{cons if cons else '—new'}** from {nv} people\\n\\nWhat would *you* rate this? Your score is saved too.\"\n","    return it[\"image_path\"],idx,q,cap\n","def feed_score(val, q, idx, user):\n","    if not q or idx<0 or idx>=len(q): return None,idx,q,\"\",_box(user)\n","    store.add_community_score(q[idx][\"iter_id\"], user, val); store.add_shuriken(user,1)\n","    idx+=1\n","    if idx>=len(q): return None,idx,q,f\"### That's the feed for now\\nYou earned shuriken. Balance {_bal(user)}.\",_box(user)\n","    p,i,qq,cap=_feed_card(q,idx); return p,i,qq,cap,_box(user)\n","\n","def do_csv(): return store.export_csv()\n","def do_zip(): return store.export_zip()\n","def _ov(img,mask,color=(84,214,199)):\n","    b=np.array(img.convert(\"RGB\").resize(mask.size)); a=(np.array(mask.convert(\"L\"))>90)\n","    b[a]=(0.45*np.array(color)+0.55*b[a]).astype(\"uint8\"); return Image.fromarray(b)\n","\n","with gr.Blocks(css=CSS,title=\"Vision Studio\",theme=gr.themes.Base()) as demo:\n","    user=gr.State(\"guest\")\n","    shbox=gr.HTML(_box(\"guest\"))\n","    gr.Markdown(\"# Vision Studio\")\n","    with gr.Row() as signin_row:\n","        nm=gr.Textbox(label=\"Username\",scale=3,placeholder=\"admins: admin / zaki / fahima\")\n","        si=gr.Button(\"Sign in\",scale=1,variant=\"primary\")\n","    who=gr.Markdown(\"\")\n","\n","    with gr.Tab(\"Manual\"):\n","        with gr.Row(equal_height=True):\n","            mi=gr.Image(type=\"pil\",label=\"Photo\",height=420,width=340)\n","            mr=gr.Image(label=\"Edited region (MediaPipe)\",height=420,width=340)\n","            ma=gr.Image(label=\"Result\",height=420,width=340)\n","        with gr.Row():\n","            me=gr.Dropdown(EDIT_CHOICES,value=\"natural_makeup\",label=\"Edit\",scale=2)\n","            mshade=gr.Dropdown(LIP_SHADES,value=\"rosy pink\",label=\"Lip shade\",scale=1,visible=False)\n","            mm=gr.Dropdown([\"realistic-vision\",\"juggernaut-xl\",\"epicrealism\"],value=\"realistic-vision\",label=\"Model\",scale=1)\n","            mg=gr.Textbox(label=\"Note (optional)\",scale=2)\n","        mgo=gr.Button(\"Generate (uses 1 star)\",variant=\"primary\")\n","        mn=gr.Markdown()\n","        with gr.Row():\n","            msl=gr.Slider(1,5,step=1,value=4,label=\"Your score\",scale=3)\n","            msave=gr.Button(\"Save score\",scale=1); mref=gr.Button(\"Refine\",scale=1)\n","        mst=gr.State({})\n","        me.change(lambda e: gr.update(visible=(_key(e)=='lipstick')), me, mshade)\n","        mgo.click(manual_gen,[mi,me,mg,mshade,mm,user,mst],[ma,mr,mn,mst,shbox])\n","        msave.click(manual_rate,[msl,mst,user],[mn,mst])\n","        mref.click(manual_refine,[mst,user],[ma,mr,mn,mst,shbox])\n","\n","    with gr.Tab(\"Batch\",visible=False) as bt:\n","        gr.Markdown(\"Load the next chunk, compare original vs edit, score 1–5. Resumes automatically where you left off.\")\n","        with gr.Row():\n","            bn=gr.Slider(10,300,value=50,step=10,label=\"Photos per chunk (use 50 to avoid timeouts)\")\n","            be=gr.Dropdown([\"(cycle all)\"]+[c[0] for c in EDIT_CHOICES],value=\"(cycle all)\",label=\"Edit\")\n","            bmodel=gr.Dropdown([\"realistic-vision\",\"juggernaut-xl\",\"(cycle both)\"],value=\"realistic-vision\",label=\"Model\")\n","            bload=gr.Button(\"Load & generate\",variant=\"primary\")\n","        bstat=gr.Markdown()\n","        with gr.Row():\n","            borig=gr.Image(label=\"Original\",height=380,width=330); bedit=gr.Image(label=\"Edited — score this\",height=380,width=330)\n","        bcap=gr.Markdown()\n","        bscore=gr.Slider(1,5,step=1,value=4,label=\"Human score\")\n","        with gr.Row(): brefine=gr.Button(\"🔄 Refine (too low)\"); bnext=gr.Button(\"Save score → next\",variant=\"primary\")\n","        bq=gr.State([]); bidx=gr.State(-1)\n","        bload.click(batch_load,[bn,be,bmodel,user],[bstat,borig,bedit,bidx,bq,bscore,bcap])\n","        bnext.click(batch_score,[bscore,bq,bidx,user],[borig,bedit,bidx,bq,bscore,bcap])\n","        brefine.click(batch_refine,[bq,bidx,user],[borig,bedit,bidx,bq,bscore,bcap])\n","\n","    with gr.Tab(\" Ai consultation\"):\n","        gr.Markdown(\"### One-shot consultation\\nUpload a face and pick the profile. DSPy recommends the best edit;