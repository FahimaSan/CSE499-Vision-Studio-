(resilient; safe to re-run) ───────────────────\n","import sys, subprocess, importlib\n","\n","def ensure(pip_name, import_name=None):\n","    mod = import_name or pip_name\n","    try:\n","        importlib.import_module(mod); print(\"✓\", mod)\n","    except Exception:\n","        print(\"installing\", pip_name, \"...\")\n","        subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", pip_name], check=False)\n","        try:\n","            importlib.import_module(mod); print(\"✓\", mod, \"installed\")\n","        except Exception as e:\n","            print(\"✗\", mod, \"->\", e)\n","\n","for pip_name, mod in [\n","    (\"diffusers\", \"diffusers\"), (\"transformers\", \"transformers\"),\n","    (\"accelerate\", \"accelerate\"), (\"safetensors\", \"safetensors\"),\n","    (\"huggingface_hub\", \"huggingface_hub\"), (\"datasets\", \"datasets\"),\n","    (\"opencv-python-headless\", \"cv2\"), (\"pillow\", \"PIL\"),\n","    (\"gradio\", \"gradio\"), (\"mediapipe\", \"mediapipe\"), (\"dspy-ai\", \"dspy\"),\n","    (\"scikit-image\", \"skimage\"), (\"scikit-learn\", \"sklearn\"),\n","]:\n","    ensure(pip_name, mod)\n","\n","print(\"Cell 0 complete\")"]},{"cell_type":"code","execution_count":2,"id":"c27fe0ab","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:32.863976Z","iopub.status.busy":"2026-07-13T10:20:32.863196Z","iopub.status.idle":"2026-07-13T10:20:32.887857Z","shell.execute_reply":"2026-07-13T10:20:32.886807Z"},"papermill":{"duration":0.033504,"end_time":"2026-07-13T10:20:32.889494+00:00","exception":false,"start_time":"2026-07-13T10:20:32.85599+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Device: cuda | torch 2.10.0+cu128\n","Cell 1 complete · 5 procedures\n"]}],"source":["# ── Cell 1 · Imports, device, paths, domain constants ───────────────────\n","import os, gc, glob, json, math, uuid, warnings, statistics, datetime, pathlib\n","from collections import defaultdict, Counter\n","warnings.filterwarnings(\"ignore\")\n","\n","import numpy as np\n","import pandas as pd\n","import cv2\n","import torch\n","from PIL import Image, ImageDraw, ImageFilter\n","\n","DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","DTYPE  = torch.float16 if DEVICE == \"cuda\" else torch.float32\n","\n","WORK   = pathlib.Path(\"/kaggle/working\")\n","OUT    = WORK / \"consultation_outputs\"; OUT.mkdir(exist_ok=True, parents=True)\n","RHINO_DIR = WORK / \"rhinoplasty_lora\"; RHINO_DIR.mkdir(exist_ok=True, parents=True)\n","print(\"Device:\", DEVICE, \"| torch\", torch.__version__)\n","\n","# ---- Procedure taxonomy (region to edit + surgery-specific realism tokens) ----\n","PROCEDURES = {\n","    \"Rhinoplasty (nose reshaping)\": dict(\n","        region=\"nose\", strength=0.42, blend=1.0, use_reference=True, ip_scale=0.7,\n","        keywords=[\"nose\",\"nasal\",\"rhino\",\"bridge\",\"hump\",\"tip\",\"nostril\",\"dorsal\"],\n","        core=(\"smaller thinner nose, narrow slim nasal bridge, refined pointed nasal tip, \"\n","              \"pinched narrower nostrils, straight nose without hump, delicate elegant small nose\")),\n","    \"Double chin / neck slimming\": dict(\n","        region=\"lower_face\", strength=0.54, blend=1.0, use_reference=False, ip_scale=0.0,\n","        keywords=[\"double chin\",\"submental\",\"neck\",\"under chin\",\"chin fat\",\"jowl\",\"turkey neck\"],\n","        core=(\"no double chin, slim tight under chin and jawline, defined slim neck, \"\n","              \"sculpted lean lower face, reduced chin and neck fat\")),\n","    \"Facelift / skin tightening\": dict(\n","        region=\"jowls\", strength=0.46, blend=1.0, use_reference=False, ip_scale=0.0,\n","        keywords=[\"facelift\",\"lift\",\"jowl\",\"sagging\",\"tighten\",\"firmer\",\"younger\",\"rejuven\",\"loose skin\"],\n","        core=(\"tight lifted facial skin, firm toned jawline, lifted cheeks, reduced jowls and sagging, \"\n","              \"smoothed nasolabial folds, taut youthful skin, natural facelift, same person younger\")),\n","    \"Botox / wrinkle softening\": dict(\n","        region=\"wrinkles\", strength=0.45, blend=1.0, use_reference=False, ip_scale=0.0,\n","        keywords=[\"botox\",\"wrinkle\",\"forehead\",\"frown\",\"glabella\",\"crow\",\"smile line\",\"fine line\"],\n","        core=(\"smooth youthful skin with natural pores, wrinkle lines removed, no forehead lines, \"\n","              \"no frown lines, no crows feet, no under eye lines, firm fresh complexion\")),\n","    \"Cheek / face slimming\": dict(\n","        region=\"face\", strength=0.58, blend=1.0, use_reference=False, ip_scale=0.0,\n","        keywords=[\"slim\",\"slimmer\",\"thinner\",\"buccal\",\"chubby\",\"round face\",\"cheek fat\",\"face fat\",\"narrow face\",\"lose weight\"],\n","        core=(\"slim slender face, thinner narrower face shape, much less facial fat, \"\n","              \"reduced chubby cheeks, sculpted high cheekbones, sharp defined jawline, slim V shape face\")),\n","}\n","\n","# Sensible starting goal per procedure (UI resets to this when the procedure changes,\n","# so a leftover sentence from another procedure never leaks into the prompt).\n","DEFAULT_GOALS = {\n","    \"Rhinoplasty (nose reshaping)\": \"reduce the dorsal hump and refine the nasal tip naturally\",\n","    \"Double chin / neck slimming\":  \"remove the double chin and slim the under chin and neck\",\n","    \"Facelift / skin tightening\":   \"lift and tighten the jawline and jowls for a natural younger look\",\n","    \"Botox / wrinkle softening\":    \"smooth the forehead lines and soften the wrinkles\",\n","    \"Cheek / face slimming\":        \"slim the face, reduce cheek fat and define the jawline\",\n","}\n","\n","# Data-derived defaults (these exact tokens dominate the score-5 rows in the recorded CSV);\n","# Cell 3 replaces REALISM_ANCHOR with tokens actually mined from your highest-scored results.\n","IDENTITY_ANCHOR = \"same person, same face structure, preserve identity, preserve facial features, natural skin tone\"\n","REALISM_ANCHOR  = \"realistic portrait photo, photorealistic, natural skin texture, visible pores, realistic lighting, high detail\"\n","NEGATIVE_ANCHOR = (\"different person, changed identity, distorted face, deformed, \"\n","                   \"distorted teeth, extra teeth, crooked teeth, altered mouth, open mouth, \"\n","                   \"changed eye color, asymmetric eyes, plastic waxy skin, overedited, \"\n","                   \"cartoon, anime, illustration, CGI, blurry, low quality, watermark, text, logo\")\n","DISCLAIMER = (\"AI generated cosmetic visualization only. Not medical advice or a guaranteed \"\n","              \"surgical result. A licensed clinician must review any medical decision.\")\n","\n","def classify_intent(text, procedure=None, return_hits=False):\n","    if procedure and procedure in PROCEDURES:\n","        return (procedure, 99) if return_hits else procedure\n","    t = (text or \"\").lower()\n","    best, hits = None, 0\n","    for name, cfg in PROCEDURES.items():\n","        h = sum(1 for kw in cfg[\"keywords\"] if kw in t)\n","        if h > hits: best, hits = name, h\n","    res = best or \"Rhinoplasty (nose reshaping)\"\n","    return (res, hits) if return_hits else res\n","\n","print(\"Cell 1 complete ·\", len(PROCEDURES), \"procedures\")"]},{"cell_type":"code","execution_count":3,"id":"19edc601","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:32.902974Z","iopub.status.busy":"2026-07-13T10:20:32.902743Z","iopub.status.idle":"2026-07-13T10:20:33.281036Z","shell.execute_reply":"2026-07-13T10:20:33.280152Z"},"papermill":{"duration":0.387371,"end_time":"2026-07-13T10:20:33.283079+00:00","exception":false,"start_time":"2026-07-13T10:20:32.895708+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Landmark backend: tasks | SSIM: skimage\n","Cell 5 complete\n"]},{"name":"stderr","output_type":"stream","text":["WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\n","W0000 00:00:1783938033.172154      85 face_landmarker_graph.cc:174] Sets FaceBlendshapesGraph acceleration to xnnpack by default.\n","INFO: Created TensorFlow Lite XNNPACK delegate for CPU.\n","W0000 00:00:1783938033.248239      88 inference_feedback_manager.cc:114] Feedback manager requires a model with a single signature inference. Disabling support for feedback tensors.\n","W0000 00:00:1783938033.272598      88 inference_feedback_manager.cc:114] Feedback manager requires a model with a single signature inference. Disabling support for feedback tensors.\n"]}],"source":["# ── Cell 5 · MediaPipe FaceMesh landmark + region-mask engine ──────────\n","# Backend priority: legacy solutions.face_mesh → tasks FaceLandmarker → OpenCV Haar (always works)\n","NOSE_IDX = [1,2,4,5,6,19,44,45,51,94,97,98,115,122,125,168,195,197,236,274,275,281,344,351,354,440,220,305]\n","FOREHEAD_IDX = [10,338,297,332,284,251,21,54,103,67,109,151,108,337,69,299,104,333,\n","                105,334,66,296,65,295,107,336,9,8]\n","# cheeks as TWO separate groups so the convex hull never bridges across the nose\n","LEFT_CHEEK_IDX  = [116,117,118,119,120,100,142,36,205,50,187,123,147,213]\n","RIGHT_CHEEK_IDX = [345,346,347,348,349,329,371,266,425,280,411,352,376,433]\n","# jawline / jowls as TWO side groups so the hull never covers the mouth (protects teeth)\n","LEFT_JAW_IDX  = [172,136,150,149,176,58,132,215,177,147,213,123]\n","RIGHT_JAW_IDX = [397,365,379,378,400,288,361,435,401,366,433,352]\n","# chin bottom points — used as the TOP edge of the under-chin/neck band (extended downward)\n","CHIN_IDX = [152,148,176,377,400,149,378,150,379,175,171,396]\n","# full face oval (for whole-face edits: slimming, facelift) and lower-face oval (double chin)\n","FACE_OVAL_IDX = [10,338,297,332,284,251,389,356,454,323,361,288,397,365,379,378,400,377,152,148,176,\n","                 149,150,136,172,58,132,93,234,127,162,21,54,103,67,109]\n","LOWERFACE_IDX = [234,93,132,58,172,136,150,149,176,148,152,377,400,378,379,365,397,288,361,323,454,\n","                 425,205,50,101,36,206,203,423,266,280,411]\n","\n","# wrinkle zones for Botox: forehead + under-eyes + nasolabial (smile) lines\n","UNDER_EYE_L_IDX = [230,231,232,233,228,229,25,110,24,23,22,26,112]\n","UNDER_EYE_R_IDX = [450,451,452,453,448,449,255,339,254,253,252,256,341]\n","NASOLABIAL_L_IDX = [129,203,206,216,207,187,205,50,101,118,117]\n","NASOLABIAL_R_IDX = [358,423,426,436,427,411,425,280,330,347,346]\n","# lips (outer contour) for lipstick / lip filler\n","LIPS_IDX = [61,146,91,181,84,17,314,405,321,375,291,409,270,269,267,0,37,39,40,185,\n","            76,77,90,180,85,16,315,404,320,307,306,408,304,303,302,11,72,73,74,184]\n","# eyelids (for eyeshadow / smokey eye / cut crease) — lid + crease, not the eyeball\n","EYELID_L_IDX = [33,246,161,160,159,158,157,173,133,46,53,52,65,55,70,63,105,66,107]\n","EYELID_R_IDX = [263,466,388,387,386,385,384,398,362,276,283,282,295,285,300,293,334,296,336]\n","\n","# region -> list of landmark groups (unioned hulls). Broad regions include a background margin\n","# so diffusion can actually reshape the silhouette (this is how slimming works, no warp).\n","REGION_PARTS = {\n","    \"nose\":       [NOSE_IDX],\n","    \"forehead\":   [FOREHEAD_IDX],\n","    \"face\":       [FACE_OVAL_IDX],\n","    \"lower_face\": [LOWERFACE_IDX],\n","    \"lips\":       [LIPS_IDX],\n","    \"eyes\":       [EYELID_L_IDX, EYELID_R_IDX],\n","    \"jowls\":      [LEFT_JAW_IDX, RIGHT_JAW_IDX, NASOLABIAL_L_IDX, NASOLABIAL_R_IDX],  # facelift target\n","    \"wrinkles\":   [FOREHEAD_IDX, UNDER_EYE_L_IDX, UNDER_EYE_R_IDX,\n","                   NASOLABIAL_L_IDX, NASOLABIAL_R_IDX],\n","}\n","REGION_NECK = {\"lower_face\"}          # lower-face edits extend down into the neck\n","# how far each region grows outward (margin of background) + how hard the edge is\n","REGION_GROW = {\"face\":0.16,\"lower_face\":0.14,\"nose\":0.10,\"forehead\":0.10,\"wrinkles\":0.06,\"jowls\":0.10,\"lips\":0.08,\"eyes\":0.10}\n","\n","_BACKEND=None; _FM=None; _TASK=None\n","def _init_backend():\n","    global _BACKEND,_FM,_TASK\n","    if _BACKEND is not None: return _BACKEND\n","    try:\n","        import mediapipe as mp\n","        _FM = mp.solutions.face_mesh.FaceMesh(static_image_mode=True, max_num_faces=1,\n","                                              refine_landmarks=True, min_detection_confidence=0.4)\n","        _BACKEND=\"solutions\"; return _BACKEND\n","    except Exception: pass\n","    try:\n","        import mediapipe as mp, urllib.request\n","        from mediapipe.tasks import python as mpp\n","        from mediapipe.tasks.python import vision as mpv\n","        mp_path = str(WORK/\"face_landmarker.task\")\n","        if not os.path.exists(mp_path):\n","            urllib.request.urlretrieve(\n","                \"https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/\"\n","                \"float16/1/face_landmarker.task\", mp_path)\n","        _TASK = mpv.FaceLandmarker.create_from_options(\n","            mpv.FaceLandmarkerOptions(base_options=mpp.BaseOptions(model_asset_path=mp_path), num_faces=1))\n","        _BACKEND=\"tasks\"; return _BACKEND\n","    except Exception: pass\n","    _BACKEND=\"opencv\"; return _BACKEND\n","\n","_HAAR = cv2.CascadeClassifier(cv2.data.haarcascades + \"haarcascade_frontalface_default.xml\")\n","\n","def get_landmarks(pil):\n","    b=_init_backend(); rgb=np.array(pil.convert(\"RGB\")); H,W=rgb.shape[:2]\n","    if b==\"solutions\":\n","        r=_FM.process(rgb)\n","        if not r.multi_face_landmarks: return None,b\n","        return np.array([[p.x*W,p.y*H] for p in r.multi_face_landmarks[0].landmark],np.float32),b\n","    if b==\"tasks\":\n","        import mediapipe as mp\n","        r=_TASK.detect(mp.Image(image_format=mp.ImageFormat.SRGB,data=rgb))\n","        if not r.face_landmarks: return None,b\n","        return np.array([[p.x*W,p.y*H] for p in r.face_landmarks[0]],np.float32),b\n","    return None,b\n","\n","def _haar_rect(pil):\n","    W,H=pil.size; gray=cv2.cvtColor(np.array(pil.convert(\"RGB\")),cv2.COLOR_RGB2GRAY)\n","    f=_HAAR.detectMultiScale(gray,1.05,4,minSize=(40,40))\n","    if len(f)==0:\n","        fw,fh=int(W*0.6),int(H*0.6); return ((W-fw)//2,int(H*0.18),fw,fh)\n","    return tuple(max(f,key=lambda r:r[2]*r[3]))\n","\n","def _hull(size, pts, idxs, dilate=0.10):\n","    W,H=size; m=Image.new(\"L\",(W,H),0)\n","    idxs=[i for i in idxs if i < len(pts)]\n","    if not idxs: return m\n","    sel=pts[idxs]; hull=cv2.convexHull(sel.astype(np.int32))\n","    cx,cy=sel[:,0].mean(),sel[:,1].mean()\n","    grown=[[cx+(x-cx)*(1+dilate),cy+(y-cy)*(1+dilate)] for x,y in hull.reshape(-1,2)]\n","    ImageDraw.Draw(m).polygon([tuple(p) for p in grown],fill=255)\n","    return m\n","\n","def detect_wrinkles(pil, pts):\n","    # THIN-LINE wrinkle finder: black-hat isolates the actual wrinkle LINES; we mask only those\n","    # (slightly dilated) so Botox erases lines while keeping real skin/pores -> no waxy over-smoothing.\n","    W,H=pil.size; gray=cv2.cvtColor(np.array(pil.convert(\"RGB\")),cv2.COLOR_RGB2GRAY)\n","    zones=Image.new(\"L\",(W,H),0)\n","    for g in [FOREHEAD_IDX,UNDER_EYE_L_IDX,UNDER_EYE_R_IDX,NASOLABIAL_L_IDX,NASOLABIAL_R_IDX]:\n","        h=_hull((W,H),pts,g,dilate=0.08); zones=Image.fromarray(np.maximum(np.array(zones),np.array(h)))\n","    z=np.array(zones)>0\n","    k=cv2.getStructuringElement(cv2.MORPH_ELLIPSE,(7,7))\n","    black=cv2.morphologyEx(gray,cv2.MORPH_BLACKHAT,k)                 # dark thin lines pop out\n","    thr=max(10,int(np.percentile(black[z],88))) if z.any() else 12\n","    lines=((black>=thr)&z).astype(np.uint8)*255\n","    lines=cv2.dilate(lines,cv2.getStructuringElement(cv2.MORPH_ELLIPSE,(5,5)),1)  # just thicken the lines\n","    cov=(lines>0).mean()\n","    if cov < 0.006:                       # no clear wrinkles found -> fall back to a soft zone smoothing\n","        return Image.fromarray((np.array(zones)*0.5).astype(np.uint8)).filter(ImageFilter.GaussianBlur(9))\n","    return Image.fromarray(lines).filter(ImageFilter.GaussianBlur(3))\n","\n","PROTECT_IDX = [33,133,157,158,159,160,161,173,246,7,145,153,\n","               263,362,384,385,386,387,388,398,466,249,374,380,\n","               1,2,4,5,6,168,197,195,98,327]      # eyes + nose = keep exactly (identity)\n","\n","def _poly_mask(size, pts, groups, region, grow, blur=6):\n","    W,H=size; m=Image.new(\"L\",(W,H),0)\n","    for g in groups:\n","        h=_hull(size,pts,g,dilate=grow); m=Image.fromarray(np.maximum(np.array(m),np.array(h)))\n","    if region in REGION_NECK:                          # extend down into the neck (double chin)\n","        chin=pts[[i for i in CHIN_IDX if i<len(pts)]]\n","        if len(chin):\n","            cx=float(chin[:,0].mean()); cy=float(chin[:,1].max())\n","            jaw_w=float(chin[:,0].max()-chin[:,0].min()) or W*0.25; dy=jaw_w*1.05\n","            ImageDraw.Draw(m).ellipse([cx-jaw_w*0.8,cy-dy*0.15,cx+jaw_w*0.8,min(H,cy+dy)],fill=255)\n","    if region in (\"face\",\"lower_face\"):                # punch out eyes+nose so identity stays exact\n","        core=_hull(size,pts,PROTECT_IDX,dilate=0.10)\n","        core=core.filter(ImageFilter.GaussianBlur(6))\n","        m=Image.fromarray(np.clip(np.array(m).astype(int)-np.array(core).astype(int),0,255).astype(np.uint8))\n","    return m.filter(ImageFilter.GaussianBlur(blur))\n","\n","def _box_mask(pil,region,blur=8):\n","    W,H=pil.size; m=Image.new(\"L\",(W,H),0); d=ImageDraw.Draw(m); fx,fy,fw,fh=_haar_rect(pil)\n","    pad=int(fw*0.14); cx=fx+fw//2\n","    if region==\"nose\":\n","        cx,cy=fx+fw//2,fy+int(fh*0.50); rx,ry=int(fw*0.22),int(fh*0.24)\n","        d.ellipse([cx-rx,cy-ry,cx+rx,cy+ry],fill=255)\n","    elif region==\"forehead\":\n","        d.rectangle([fx+int(fw*0.06),max(0,fy-int(fh*0.02)),fx+int(fw*0.94),fy+int(fh*0.30)],fill=255)\n","    elif region==\"wrinkles\":\n","        d.rectangle([fx+int(fw*0.08),fy+int(fh*0.03),fx+int(fw*0.92),fy+int(fh*0.30)],fill=255)\n","        for cx in (fx+int(fw*0.32),fx+int(fw*0.68)):\n","            d.ellipse([cx-int(fw*0.15),fy+int(fh*0.40),cx+int(fw*0.15),fy+int(fh*0.52)],fill=255)\n","        for cx in (fx+int(fw*0.34),fx+int(fw*0.66)):\n","            d.ellipse([cx-int(fw*0.11),fy+int(fh*0.58),cx+int(fw*0.11),fy+int(fh*0.74)],fill=255)\n","    elif region==\"lips\":\n","        d.ellipse([cx-int(fw*0.22),fy+int(fh*0.66),cx+int(fw*0.22),fy+int(fh*0.82)],fill=255)\n","    elif region==\"eyes\":\n","        for sx in (-1,1):\n","            ex=cx+sx*int(fw*0.20)\n","            d.ellipse([ex-int(fw*0.16),fy+int(fh*0.30),ex+int(fw*0.16),fy+int(fh*0.46)],fill=255)\n","    elif region==\"jowls\":\n","        for cx in (fx+int(fw*0.18),fx+int(fw*0.82)):          # jaw/jowl sides\n","            d.ellipse([cx-int(fw*0.16),fy+int(fh*0.52),cx+int(fw*0.16),fy+int(fh*0.82)],fill=255)\n","        for cx in (fx+int(fw*0.36),fx+int(fw*0.64)):          # nasolabial folds\n","            d.ellipse([cx-int(fw*0.08),fy+int(fh*0.52),cx+int(fw*0.08),fy+int(fh*0.70)],fill=255)\n","    else:  # face (whole face + background margin so slimming can reshape the outline)\n","        d.ellipse([max(0,fx-pad),max(0,fy-int(fh*0.06)),min(W,fx+fw+pad),min(H,fy+fh+int(fh*0.10))],fill=255)\n","    return m.filter(ImageFilter.GaussianBlur(blur))\n","\n","def build_region_mask(pil,region):\n","    pts,_=get_landmarks(pil)\n","    if pts is not None and region==\"wrinkles\":\n","        return detect_wrinkles(pil,pts)\n","    if pts is not None and region in REGION_PARTS:\n","        return _poly_mask(pil.size,pts,REGION_PARTS[region],region,REGION_GROW.get(region,0.12))\n","    return _box_mask(pil,region)\n","\n","def mask_overlay(pil,mask,color=(255,80,20)):\n","    # SHARP, clearly-visible marking (hard fill + bright outline) — no soft fade\n","    base=np.array(pil.convert(\"RGB\")); a=(np.array(mask.convert(\"L\"))>90)\n","    out=base.copy(); out[a]=(0.55*np.array(color)+0.45*base[a]).astype(np.uint8)\n","    edge=cv2.morphologyEx(a.astype(np.uint8),cv2.MORPH_GRADIENT,\n","                          cv2.getStructuringElement(cv2.MORPH_ELLIPSE,(5,5)))\n","    out[edge>0]=color\n","    return Image.fromarray(out)\n","\n","def composite_identity_safe(orig,gen,mask,blend=1.0):\n","    a=np.asarray(mask.convert(\"L\"),np.float32)[:,:,None]/255.0*float(blend)\n","    o=np.asarray(orig.convert(\"RGB\"),np.float32)\n","    g=np.asarray(gen.convert(\"RGB\").resize(orig.size),np.float32)\n","    return Image.fromarray((a*g+(1-a)*o).clip(0,255).astype(np.uint8))\n","\n","def texture_restore(orig, gen, mask, amount=0.35):\n","    # Light: lay the original skin's fine grain (pores/sheen) back over the edited region\n","    # so it doesn't look plastic/airbrushed. High-frequency add-back, masked to the edit area.\n","    o=np.asarray(orig.convert(\"RGB\").resize(gen.size),np.float32)\n","    g=np.asarray(gen.convert(\"RGB\"),np.float32)\n","    hf=o-cv2.GaussianBlur(o,(0,0),3.0)                         # fine texture of the original\n","    m=(np.asarray(mask.convert(\"L\").resize(gen.size),np.float32)/255.0)[:,:,None]\n","    out=np.clip(g+amount*hf*m,0,255).astype(np.uint8)\n","    return Image.fromarray(out)\n","\n","IDCORE_IDX = [33,133,362,263,1,2,168,6,197,195,98,327]   # eyes + nose bridge = identity core\n","\n","# ---- SSIM: structural-similarity quality + identity metric ----\n","try:\n","    from skimage.metrics import structural_similarity as _sk_ssim\n","    _HAS_SK=True\n","except Exception:\n","    _HAS_SK=False\n","def _ssim_flat(a,b):\n","    a=a.astype(np.float64); b=b.astype(np.float64)\n","    mu_a,mu_b=a.mean(),b.mean(); va,vb=a.var(),b.var(); cov=((a-mu_a)*(b-mu_b)).mean()\n","    c1=(0.01*255)**2; c2=(0.03*255)**2\n","    return float(((2*mu_a*mu_b+c1)*(2*cov+c2))/((mu_a**2+mu_b**2+c1)*(va+vb+c2)+1e-9))\n","def ssim_regions(orig,edited,mask):\n","    a=np.array(orig.convert(\"L\")); b=np.array(edited.convert(\"L\").resize(orig.size))\n","    m=np.array(mask.convert(\"L\").resize(orig.size))>128\n","    if _HAS_SK:\n","        full=_sk_ssim(a,b,data_range=255,full=True)[1]\n","        inside =float(full[m].mean())  if m.any()     else 1.0\n","        outside=float(full[~m].mean()) if (~m).any()  else 1.0\n","        overall=float(full.mean())\n","    else:\n","        inside =_ssim_flat(a[m],b[m])   if m.any()    else 1.0\n","        outside=_ssim_flat(a[~m],b[~m]) if (~m).any() else 1.0\n","        overall=_ssim_flat(a,b)\n","    return {\"ssim_overall\":round(overall,4),\"ssim_identity_outside\":round(outside,4),\n","            \"ssim_inside\":round(inside,4),\"region_change\":round(1.0-inside,4)}\n","\n","def landmark_identity_check(orig,edited):\n","    p0,b=get_landmarks(orig); p1,_=get_landmarks(edited)\n","    if p0 is None or p1 is None: return {\"face_found\":0,\"landmark_shift_mean\":-1.0,\"backend\":b}\n","    n=min(len(p0),len(p1)); diag=math.hypot(*orig.size)\n","    s=np.linalg.norm(p0[:n]-p1[:n],axis=1)/diag\n","    return {\"face_found\":1,\"landmark_shift_mean\":float(s.mean()),\n","            \"landmark_shift_max\":float(s.max()),\"landmark_count\":int(n),\"backend\":b}\n","\n","def idcore_ssim(orig,edited):\n","    p0,_=get_landmarks(orig)\n","    a=np.array(orig.convert(\"L\")); b=np.array(edited.convert(\"L\").resize(orig.size))\n","    if p0 is not None and len(p0)>200:\n","        idx=[i for i in IDCORE_IDX if i<len(p0)]; pc=p0[idx]\n","        x0,y0=int(pc[:,0].min())-10,int(pc[:,1].min())-10\n","        x1,y1=int(pc[:,0].max())+10,int(pc[:,1].max())+10\n","        x0,y0=max(0,x0),max(0,y0); x1,y1=min(a.shape[1],x1),min(a.shape[0],y1)\n","        a,b=a[y0:y1,x0:x1],b[y0:y1,x0:x1]\n","    if a.size==0: return 1.0\n","    if _HAS_SK: return float(_sk_ssim(a,b,data_range=255))\n","    return _ssim_flat(a,b)\n","\n","print(\"Landmark backend:\", _init_backend(), \"| SSIM:\", \"skimage\" if _HAS_SK else \"builtin\")\n","print(\"Cell 5 complete\")"]},{"cell_type":"code","execution_count":4,"id":"95d8fc32","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:33.297034Z","iopub.status.busy":"2026-07-13T10:20:33.296804Z","iopub.status.idle":"2026-07-13T10:20:39.901046Z","shell.execute_reply":"2026-07-13T10:20:39.899949Z"},"papermill":{"duration":6.613132,"end_time":"2026-07-13T10:20:39.902655+00:00","exception":false,"start_time":"2026-07-13T10:20:33.289523+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stderr","output_type":"stream","text":["Flax classes are deprecated and will be removed in Diffusers v1.0.0. We recommend migrating to PyTorch classes or pinning your version of Diffusers.\n","Flax classes are deprecated and will be removed in Diffusers v1.0.0. We recommend migrating to PyTorch classes or pinning your version of Diffusers.\n"]},{"name":"stdout","output_type":"stream","text":["Cell 6 complete · models: ['Realistic-Vision (SD1.5 inpaint)', 'SDXL (inpaint, max detail)']\n"]}],"source":["# ── Cell 6 · Inpainting models + ONE-SHOT generation ───────────────────\n","from diffusers import (StableDiffusionInpaintPipeline, StableDiffusionXLInpaintPipeline,\n","                       EulerDiscreteScheduler)\n","\n","# Only known-good inpaint checkpoints (DSPy's model *recommendation* is shown as info).\n","MODEL_REGISTRY = {\n","    \"Realistic-Vision (SD1.5 inpaint)\": dict(\n","        repo=\"Uminosachi/realisticVisionV51_v51VAE-inpainting\", size=(512,512),\n","        steps=30, guidance=7.0, is_xl=False),\n","    \"SDXL (inpaint, max detail)\": dict(\n","        repo=\"diffusers/stable-diffusion-xl-1.0-inpainting-0.1\", size=(1024,1024),\n","        steps=28, guidance=7.5, is_xl=True),\n","}\n","DEFAULT_MODEL = \"Realistic-Vision (SD1.5 inpaint)\"\n","_PIPES = {}\n","# ROOT-CAUSE FIX: loading IP-Adapter globally swaps the UNet attention processors, so any\n","# procedure that does NOT pass a reference image gets corrupted (grey/black) output. We therefore\n","# keep IP-Adapter OFF by default and learn the surgery look through the train-once LoRA instead\n","# (Cell 6b). If you enable it, generation neutralises it (scale 0 + neutral image) when unused.\n","USE_IP_ADAPTER = False\n","_IP_OK = {}\n","TRAINED_DIR = WORK / \"trained_surgery\"; TRAINED_DIR.mkdir(exist_ok=True, parents=True)\n","\n","# ---- TRAIN ONCE: distill each surgery dataset into a cached reference set ----\n","# Built a single time, then reused for every generation. Rhinoplasty learns the \"after\" nose look\n","# from morlako/rhinoplasty_lora (+ Roboflow if present); Botox learns firm skin from the Botox afters.\n","def _after_only(paths):\n","    a=[p for p in paths if \"after\" in os.path.basename(p).lower() or \"/after\" in p.lower()]\n","    return a or paths\n","_TRAINED_REFS = None\n","def trained_refs():\n","    global _TRAINED_REFS\n","    if _TRAINED_REFS is not None: return _TRAINED_REFS\n","    def load(paths, n=6):\n","        out=[]\n","        for p in _after_only(paths)[:n]:\n","            try: out.append(Image.open(p).convert(\"RGB\").resize((256,256)))\n","            except Exception: pass\n","        return out\n","    _TRAINED_REFS = {\n","        \"Rhinoplasty (nose reshaping)\": load(RHINO_IMAGES, 8),\n","        \"Botox / wrinkle softening\":    load(BOTOX_AFTER, 8),\n","    }\n","    for k,v in _TRAINED_REFS.items(): print(f\"Trained refs  : {k.split('/')[0].strip()} -> {len(v)} dataset images\")\n","    return _TRAINED_REFS\n","\n","def _lora_is_safe(pipe):\n","    # quick probe: inpaint a patch on a plain skin-tone image; a broken LoRA returns flat grey / NaN\n","    try:\n","        img=Image.new(\"RGB\",(256,256),(150,120,110))\n","        m=Image.new(\"L\",(256,256),0); ImageDraw.Draw(m).ellipse([88,88,168,168],fill=255)\n","        with torch.inference_mode():\n","            out=pipe(prompt=\"a close up photo of skin, face\", image=img, mask_image=m,\n","                     strength=0.7, num_inference_steps=6, guidance_scale=6.0,\n","                     generator=torch.Generator(device=DEVICE).manual_seed(0)).images[0]\n","        a=np.array(out.convert(\"RGB\")).astype(np.float32)\n","        if not np.isfinite(a).all(): return False\n","        patch=a[100:156,100:156]\n","        return float(patch.std()) > 6.0          # real texture, not a flat grey fill\n","    except Exception:\n","        return False\n","\n","def get_pipe(name):\n","    if name in _PIPES: return _PIPES[name]\n","    if len(_PIPES) >= 1:                       # keep 1 pipe hot (T4 memory)\n","        _PIPES.clear(); gc.collect()\n","        if DEVICE==\"cuda\": torch.cuda.empty_cache()\n","    cfg = MODEL_REGISTRY[name]\n","    cls = StableDiffusionXLInpaintPipeline if cfg[\"is_xl\"] else StableDiffusionInpaintPipeline\n","    kw = dict(torch_dtype=DTYPE, use_safetensors=True)\n","    if DEVICE==\"cuda\" and cfg[\"is_xl\"]: kw[\"variant\"]=\"fp16\"\n","    pipe = cls.from_pretrained(cfg[\"repo\"], **kw)\n","    pipe.scheduler = EulerDiscreteScheduler.from_config(pipe.scheduler.config)\n","    pipe.to(DEVICE)\n","    if DEVICE==\"cuda\":\n","        pipe.enable_attention_slicing()\n","        try: pipe.enable_vae_tiling()\n","        except Exception: pass\n","    # auto-load a trained LoRA if you ran the optional training cell — but VERIFY it first.\n","    # A bad LoRA corrupts every inpaint into grey, so we test it on a probe and unload if broken.\n","    lora=str(TRAINED_DIR/\"surgery_lora.safetensors\")\n","    if os.path.exists(lora):\n","        try:\n","            pipe.load_lora_weights(lora)\n","            if _lora_is_safe(pipe):\n","                print(\"Trained LoRA  : loaded + verified\", lora)\n","            else:\n","                pipe.unload_lora_weights(); print(\"Trained LoRA  : DISABLED — it produced artifacts, using plain inpaint. Retrain with Cell 6b.\")\n","        except Exception as e:\n","            try: pipe.unload_lora_weights()\n","            except Exception: pass\n","            print(\"Trained LoRA  : skip -\", str(e)[:60])\n","    _IP_OK[name]=False\n","    if USE_IP_ADAPTER and not cfg[\"is_xl\"]:\n","        try:\n","            pipe.load_ip_adapter(\"h94/IP-Adapter\", subfolder=\"models\",\n","                                 weight_name=\"ip-adapter_sd15.bin\")\n","            pipe.set_ip_adapter_scale(0.0)         # neutral by default; raised only when a ref is used\n","            _IP_OK[name]=True\n","            print(\"IP-Adapter    : loaded (surgery datasets steer rhinoplasty + botox)\")\n","        except Exception as e:\n","            print(\"IP-Adapter    : unavailable, using plain inpaint —\", str(e)[:60])\n","    _PIPES[name]=pipe; return pipe\n","\n","def reference_for(procedure):\n","    refs = trained_refs().get(procedure) or []\n","    return refs or None                        # a LIST of dataset images -> IP-Adapter averages them\n","\n","def center_square(img):\n","    w,h=img.size; s=min(w,h); return img.crop(((w-s)//2,(h-s)//2,(w-s)//2+s,(h-s)//2+s))\n","\n","# ---- Cosmetic realism scoring + artifact/corruption detection (kills grey/black outputs) ----\n","def _region_stats(img, mask):\n","    arr=np.array(img.convert(\"RGB\")); m=np.array(mask.convert(\"L\").resize(img.size))>90\n","    m=cv2.erode(m.astype(np.uint8), np.ones((9,9),np.uint8), 1).astype(bool)   # interior only (skip edge)\n","    if m.sum()<50: return 0.5, 200.0\n","    hsv=np.array(img.convert(\"HSV\")); sat=float(hsv[:,:,1][m].mean())/255.0\n","    lap=cv2.Laplacian(cv2.cvtColor(arr,cv2.COLOR_RGB2GRAY),cv2.CV_64F)\n","    return sat, float(lap[m].var())\n","\n","def is_corrupt(img, mask):\n","    arr=np.array(img.convert(\"RGB\"))\n","    if not np.isfinite(arr).all(): return True                # NaN/inf -> grey/black\n","    sat, sharp = _region_stats(img, mask)\n","    return (sat < 0.08 and sharp < 25) or sharp < 6           # flat grey / near-constant patch\n","\n","def realism_of(img, mask):                                    # 0..1 cosmetic realism proxy\n","    sat, sharp = _region_stats(img, mask)\n","    return float(np.clip(0.55*np.tanh(sharp/120.0)+0.45*np.clip(sat/0.35,0,1),0,1))\n","\n","# ---- DSPy prompt/parameter MEMORY: remember what produced the best results, reuse next time ----\n","MEM_PATH = TRAINED_DIR / \"prompt_memory.json\"\n","def load_memory():\n","    try: return json.loads(MEM_PATH.read_text())\n","    except Exception: return {}\n","def save_memory(m):\n","    try: MEM_PATH.write_text(json.dumps(m, indent=2))\n","    except Exception: pass\n","PROMPT_MEMORY = load_memory()\n","\n","def one_shot_consult(image, patient_goal, procedure, model_name, strength_override,\n","                     steps_override, seed, candidates=2):\n","    '''DSPy prompt -> region mask -> inpaint candidates -> realism+SSIM scoring -> best, artifact-safe.'''\n","    if image is None:\n","        return None, None, \"Please upload a photo or tap Load demo face first.\", None, None\n","    plan = OPTIMIZER(patient_goal=patient_goal, procedure=procedure)\n","    cfg  = MODEL_REGISTRY[model_name]\n","    W,H  = cfg[\"size\"]\n","    orig = center_square(image.convert(\"RGB\")).resize((W,H), Image.LANCZOS)\n","\n","    mask    = build_region_mask(orig, plan.region)\n","    overlay = mask_overlay(orig, mask)\n","    # AUTOMATIC PARAMETER SELECTION: if memory holds a strength that worked well before, use it\n","    mem = PROMPT_MEMORY.get(plan.procedure, {})\n","    strength = (float(strength_override) if strength_override\n","                else float(mem.get(\"strength\", plan.recommended_strength)))\n","    strength = max(0.25, min(0.85, strength))\n","    blend    = float(plan.recommended_blend)\n","    steps    = int(steps_override) if steps_override else int(cfg[\"steps\"])\n","    n_cand   = max(1, min(4, int(candidates)))\n","\n","    try:\n","        pipe = get_pipe(model_name)\n","        ref = reference_for(plan.procedure) if (_IP_OK.get(model_name) and plan.use_reference) else None\n","        if _IP_OK.get(model_name):                        # neutralise IP-Adapter unless a ref is used\n","            try: pipe.set_ip_adapter_scale(float(plan.ip_scale) if ref is not None else 0.0)\n","            except Exception: pass\n","        def _gen(gseed, guidance, use_ref):\n","            kw = dict(prompt=plan.optimized_prompt, negative_prompt=plan.negative_prompt,\n","                      image=orig, mask_image=mask, strength=strength,\n","                      num_inference_steps=steps, guidance_scale=float(guidance),\n","                      generator=torch.Generator(device=DEVICE).manual_seed(gseed))\n","            if ref is not None and use_ref: kw[\"ip_adapter_image\"]=ref\n","            with torch.inference_mode():\n","                try:\n","                    return pipe(**kw).images[0]\n","                except Exception:\n","                    kw.pop(\"ip_adapter_image\", None)\n","                    try: pipe.set_ip_adapter_scale(0.0)\n","                    except Exception: pass\n","                    return pipe(**kw).images[0]\n","        cand = []\n","        for k in range(n_cand):\n","            gen = _gen(int(seed)+k*101, cfg[\"guidance\"], True)\n","            res = composite_identity_safe(orig, gen, mask, blend)\n","            corrupt = is_corrupt(gen, mask)\n","            realism = 0.0 if corrupt else (SCORER.predict(res) if SCORER.fitted else realism_of(gen, mask))\n","            core = idcore_ssim(orig, res)\n","            reg  = ssim_regions(orig, res, mask)[\"region_change\"]\n","            # rank: not-corrupt >> identity kept >> realistic >> visibly changed\n","            score = (0 if corrupt else 100) + (10 if core>=0.55 else 0) + 3*realism + reg\n","            cand.append((score, res, core, reg, realism, corrupt, int(seed)+k*101))\n","        cand.sort(key=lambda t:t[0], reverse=True)\n","        best = cand[0]\n","        # SAFE RETRY: if the best is still corrupt, regenerate once with IP off + gentler guidance\n","        if best[5]:\n","            gen = _gen(int(seed)+999, max(4.5, cfg[\"guidance\"]-2.0), False)\n","            res = composite_identity_safe(orig, gen, mask, blend)\n","            best = (0, res, idcore_ssim(orig,res), ssim_regions(orig,res,mask)[\"region_change\"],\n","                    realism_of(gen,mask), is_corrupt(gen,mask), int(seed)+999)\n","        _, result, core_ssim, region_change, realism, corrupt, used_seed = best\n","    except RuntimeError as e:\n","        if \"out of memory\" in str(e).lower():\n","            gc.collect(); torch.cuda.empty_cache()\n","            return None, overlay, \"The GPU ran out of memory. Try the SD1.5 model or fewer steps.\", None, None\n","        return None, overlay, f\"Something went wrong during generation: {e}\", None, None\n","\n","    idc = landmark_identity_check(orig, result)\n","    # CONFIDENCE: identity kept + realistic + actually changed (0..1)\n","    confidence = round(float(np.clip(0.45*core_ssim + 0.35*realism +\n","                                     0.20*min(region_change/0.25,1.0), 0, 1)), 2)\n","    # MEMORY: remember settings that produced a confident, realistic, non-corrupt result\n","    if (not corrupt) and confidence >= 0.6 and confidence > mem.get(\"confidence\", 0):\n","        PROMPT_MEMORY[plan.procedure] = {\"strength\": round(strength,3),\n","            \"prompt\": plan.optimized_prompt, \"confidence\": confidence, \"realism\": round(realism,3)}\n","        save_memory(PROMPT_MEMORY)\n","    ssim = ssim_regions(orig, result, mask); ssim[\"identity_core\"]=round(core_ssim,4)\n","    meta = {\"procedure\": plan.procedure, \"edit_region\": plan.region,\n","            \"reference_dataset_used\": bool(_IP_OK.get(model_name) and plan.use_reference),\n","            \"generator_model\": model_name, \"recommended_by_dspy\": plan.recommended_source_model,\n","            \"learned_recipe\": plan.learned_tokens, \"dspy_lm_used\": bool(LM_ACTIVE),\n","            \"strength\": round(strength,3), \"identity_blend\": blend, \"steps\": steps,\n","            \"candidates_generated\": n_cand, \"chosen_seed\": used_seed,\n","            \"realism_score\": round(realism,3), \"confidence\": confidence,\n","            \"artifact_free\": (not corrupt), \"used_memory\": bool(mem),\n","            \"optimized_prompt\": plan.optimized_prompt, \"negative_prompt\": plan.negative_prompt,\n","            \"ssim_metrics\": ssim, \"identity_core_ssim\": round(core_ssim,4),\n","            \"region_change\": round(region_change,4),\n","            \"recorded_model_scores\": plan.model_scores, \"dataset_examples_used\": plan.n_examples,\n","            \"identity_check\": idc, \"disclaimer\": DISCLAIMER}\n","    path = OUT / f\"consult_{datetime.datetime.now():%Y%m%d_%H%M%S}.json\"\n","    path.write_text(json.dumps(meta, indent=2))\n","\n","    # ---- patient-friendly notes (plain language, no jargon) ----\n","    change_pct = int(round(region_change*100)); same_pct = int(round(core_ssim*100))\n","    strength_word = \"strong\" if region_change>0.25 else \"moderate\" if region_change>0.12 else \"subtle\"\n","    notes = (\n","        f\"Your {plan.procedure.split('/')[0].strip().lower()} preview is ready.\\n\\n\"\n","        f\"What we changed: {DEFAULT_GOALS.get(plan.procedure,'the requested area').lower()}.\\n\"\n","        f\"We only edited the {plan.region.replace('_',' ')} area and kept the rest of your face the same.\\n\\n\"\n","        f\"How noticeable is it: a {strength_word} change (about {change_pct}% difference in the edited area).\\n\"\n","        f\"Is it still you: yes. Your eyes and nose (the parts that make you recognisable) are about \"\n","        f\"{same_pct}% identical to your original photo, so this looks like you, just with the treatment applied.\\n\"\n","        f\"Confidence in this preview: {int(round(confidence*100))} out of 100\"\n","        f\"{' (clean, artifact-free result)' if not corrupt else ' (please regenerate — the edit looked off)'}.\\n\\n\"\n","        f\"This is a computer visualisation to help you picture a possible result. \"\n","        f\"It is not a promise of the exact outcome. Please discuss any real procedure with a qualified surgeon.\")\n","    return result, overlay, notes, str(path), plan.optimized_prompt\n","\n","print(\"Cell 6 complete · models:\", list(MODEL_REGISTRY))"]},{"cell_type":"code","execution_count":5,"id":"cf0d78e4","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:39.918014Z","iopub.status.busy":"2026-07-13T10:20:39.917004Z","iopub.status.idle":"2026-07-13T10:20:39.935851Z","shell.execute_reply":"2026-07-13T10:20:39.93496Z"},"papermill":{"duration":0.028389,"end_time":"2026-07-13T10:20:39.937545+00:00","exception":false,"start_time":"2026-07-13T10:20:39.909156+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["LoRA training OFF. Set TRAIN_LORA_NOW=True and run once to bake the surgery look into weights.\n"]}],"source":["# ── Cell 6b · OPTIONAL: train a surgery LoRA ONCE, then it is auto-loaded forever ───────\n","# This is the recommended way to teach the model the rhinoplasty + botox look from the datasets\n","# (the global IP-Adapter is OFF by default because it corrupted non-reference edits). Set\n","# TRAIN_LORA_NOW=True and run THIS cell one time to bake the \"after\" look into a small LoRA saved\n","# to /kaggle/working. On every future run, get_pipe() finds surgery_lora.safetensors and loads it\n","# automatically — train once, use always. Save it as a Kaggle Dataset so it survives session resets.\n","TRAIN_LORA_NOW = False        # <- set True once to train, then set back to False\n","LORA_STEPS     = 600          # ~15-25 min on a T4; raise for a stronger effect\n","\n","if TRAIN_LORA_NOW:\n","    try:\n","        import torch, random\n","        from diffusers import StableDiffusionInpaintPipeline, DDPMScheduler\n","        from peft import LoraConfig, get_peft_model_state_dict\n","        from safetensors.torch import save_file\n","\n","        # ---- keep only FRONTAL FACE photos (drop side profiles / nose-only crops) ----\n","        def _is_frontal(img):\n","            pts,_=get_landmarks(img)\n","            if pts is None or len(pts)<200: return False\n","            xs=pts[:,0]; ys=pts[:,1]\n","            w=xs.max()-xs.min(); h=ys.max()-ys.min()\n","            if w<img.size[0]*0.25 or h<img.size[1]*0.25: return False   # face too small (nose-only crop)\n","            # frontal = both eyes present and roughly level & symmetric about the nose\n","            le,re,nose=pts[33],pts[263],pts[1]\n","            eye_dx=abs(re[0]-le[0]); \n","            if eye_dx < w*0.35: return False                            # eyes too close -> profile view\n","            sym=abs((nose[0]-le[0])-(re[0]-nose[0]))/(eye_dx+1e-3)\n","            return sym < 0.45                                           # nose roughly centred between eyes\n","        pairs = [(\"a photorealistic frontal portrait after rhinoplasty, refined slim pointed nose\", RHINO_IMAGES),\n","                 (\"a photorealistic frontal portrait after botox, firm smooth wrinkle-free skin\", BOTOX_AFTER)]\n","        imgs=[]; caps=[]; dropped=0\n","        for cap, paths in pairs:\n","            for p in _after_only(paths)[:250]:\n","                try:\n","                    im=Image.open(p).convert(\"RGB\")\n","                    im=center_square(im).resize((512,512))\n","                    if _is_frontal(im): imgs.append(im); caps.append(cap)\n","                    else: dropped+=1\n","                except Exception: pass\n","        print(f\"Training images: kept {len(imgs)} frontal faces, dropped {dropped} side/nose-only\")\n","        assert len(imgs)>=8, \"Not enough frontal training images — add the datasets.\"\n","\n","        base=\"Uminosachi/realisticVisionV51_v51VAE-inpainting\"\n","        pipe=StableDiffusionInpaintPipeline.from_pretrained(base, torch_dtype=torch.float32,\n","                                                            safety_checker=None).to(DEVICE)\n","        sched=DDPMScheduler.from_config(pipe.scheduler.config)\n","        unet=pipe.unet\n","        unet.add_adapter(LoraConfig(r=8, lora_alpha=8, init_lora_weights=\"gaussian\",\n","                                    target_modules=[\"to_k\",\"to_q\",\"to_v\",\"to_out.0\"]))\n","        for p in pipe.vae.parameters(): p.requires_grad_(False)\n","        for p in pipe.text_encoder.parameters(): p.requires_grad_(False)\n","        unet.train()\n","        opt=torch.optim.AdamW([p for p in unet.parameters() if p.requires_grad], lr=5e-5)\n","        vae, te, tok = pipe.vae, pipe.text_encoder, pipe.tokenizer\n","        sf=vae.config.scaling_factor\n","        for step in range(LORA_STEPS):\n","            j=random.randrange(len(imgs))\n","            px=(torch.tensor(np.array(imgs[j])/127.5-1).permute(2,0,1)[None].float()).to(DEVICE)\n","            with torch.no_grad():\n","                lat=vae.encode(px).latent_dist.sample()*sf\n","                Lh,Lw=lat.shape[-2:]\n","                # RANDOM rectangular mask -> teaches the model to fill masked skin from context\n","                mh,mw=random.randint(Lh//4,Lh//2), random.randint(Lw//4,Lw//2)\n","                my,mx=random.randint(0,Lh-mh), random.randint(0,Lw-mw)\n","                mask=torch.zeros((1,1,Lh,Lw),device=DEVICE); mask[...,my:my+mh,mx:mx+mw]=1.0\n","                masked_lat=lat*(1.0-mask)                                  # masked region hidden (correct)\n","                ids=tok(caps[j],return_tensors=\"pt\",padding=\"max_length\",truncation=True,max_length=77).input_ids.to(DEVICE)\n","                enc=te(ids)[0]\n","            nz=torch.randn_like(lat)\n","            t=torch.randint(0,sched.config.num_train_timesteps,(1,),device=DEVICE).long()\n","            noisy=sched.add_noise(lat,nz,t)\n","            inp=torch.cat([noisy,mask,masked_lat],dim=1) if unet.config.in_channels==9 else noisy\n","            pred=unet(inp,t,encoder_hidden_states=enc).sample\n","            loss=torch.nn.functional.mse_loss(pred.float(),nz.float())\n","            loss.backward()\n","            torch.nn.utils.clip_grad_norm_([p for p in unet.parameters() if p.requires_grad],1.0)\n","            opt.step(); opt.zero_grad()\n","            if step%100==0: print(f\"  lora step {step}/{LORA_STEPS} loss {loss.item():.3f}\")\n","        unet.eval()\n","        ok = _lora_is_safe(pipe)                                          # validate before saving\n","        if ok:\n","            sd={f\"unet.{k}\":v for k,v in get_peft_model_state_dict(unet).items()}\n","            out=str(TRAINED_DIR/\"surgery_lora.safetensors\"); save_file(sd,out)\n","            print(\"Saved verified LoRA ->\", out, \" (auto-loads next run)\")\n","        else:\n","            print(\"Trained LoRA failed the artifact check and was NOT saved. Try more steps or check the data.\")\n","        del pipe; gc.collect()\n","        if DEVICE==\"cuda\": torch.cuda.empty_cache()\n","    except Exception as e:\n","        print(\"LoRA training skipped:\", str(e)[:160])\n","else:\n","    print(\"LoRA training OFF. Set TRAIN_LORA_NOW=True and run once to bake the surgery look into weights.\")"]},{"cell_type":"markdown","id":"b960e56e","metadata":{"papermill":{"duration":0.00592,"end_time":"2026-07-13T10:20:39.949568+00:00","exception":false,"start_time":"2026-07-13T10:20:39.943648+00:00","status":"completed"},"tags":[]},"source":["---\n","## Part 2 · Setup (local, CSV-only)"]},{"cell_type":"code","execution_count":6,"id":"d58f98ec","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:39.96463Z","iopub.status.busy":"2026-07-13T10:20:39.963605Z","iopub.status.idle":"2026-07-13T10:20:43.542971Z","shell.execute_reply":"2026-07-13T10:20:43.541926Z"},"papermill":{"duration":3.58798,"end_time":"2026-07-13T10:20:43.544632+00:00","exception":false,"start_time":"2026-07-13T10:20:39.956652+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["env ready (local, no Supabase)\n"]}],"source":["import subprocess, sys, os, glob\n","subprocess.run([sys.executable,\"-m\",\"pip\",\"install\",\"-q\",\"scikit-image\",\"dspy\",\"scikit-learn\"])\n","os.environ.pop(\"SUPABASE_URL\",None); os.environ.pop(\"SUPABASE_KEY\",None)   # Supabase OFF (CSV/zip only)\n","print(\"env ready (local, no Supabase)\")"]},{"cell_type":"code","execution_count":7,"id":"77f2752a","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:43.558658Z","iopub.status.busy":"2026-07-13T10:20:43.55837Z","iopub.status.idle":"2026-07-13T10:20:43.649429Z","shell.execute_reply":"2026-07-13T10:20:43.64851Z"},"papermill":{"duration":0.099717,"end_time":"2026-07-13T10:20:43.651053+00:00","exception":false,"start_time":"2026-07-13T10:20:43.551336+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["OPENAI_API_KEY loaded — DSPy will use the LLM\n"]}],"source":["# OpenAI key from Kaggle Secrets (early) so DSPy runs with the LLM\n","try:\n","    from kaggle_secrets import UserSecretsClient\n","    os.environ[\"OPENAI_API_KEY\"]=UserSecretsClient().get_secret(\"OPENAI_API_KEY\")\n","    print(\"OPENAI_API_KEY loaded — DSPy will use the LLM\")\n","except Exception as e:\n","    print(\"no OPENAI_API_KEY secret — DSPy will use policy mode:\", str(e)[:50])"]},{"cell_type":"markdown","id":"803284e6","metadata":{"papermill":{"duration":0.006786,"end_time":"2026-07-13T10:20:43.664623+00:00","exception":false,"start_time":"2026-07-13T10:20:43.657837+00:00","status":"completed"},"tags":[]},"source":["### Data layer"]},{"cell_type":"code","execution_count":8,"id":"183b5f8f","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:43.679303Z","iopub.status.busy":"2026-07-13T10:20:43.679014Z","iopub.status.idle":"2026-07-13T10:20:43.770469Z","shell.execute_reply":"2026-07-13T10:20:43.769807Z"},"papermill":{"duration":0.101268,"end_time":"2026-07-13T10:20:43.772079+00:00","exception":false,"start_time":"2026-07-13T10:20:43.670811+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["\"\"\"\n","data_layer.py — dataset engine for Vision Studio.\n","Local-first (SQLite, never lose data) with an optional Supabase mirror (auto-sync to cloud).\n","Provides: balanced CelebA sampling, an edit registry (makeup/beard/feminize/surgery/…),\n","and one iterate-and-store loop shared by Batch mode and Manual mode. Every iteration's\n","image + mask + row is saved and grouped per source face.\n","\"\"\"\n","import os, json, sqlite3, datetime, hashlib, glob, csv\n","import numpy as np\n","from PIL import Image, ImageDraw, ImageFilter\n","try:\n","    import cv2\n","except Exception:\n","    cv2=None\n","\n","ROOT    = os.environ.get(\"VS_ROOT\", \"/kaggle/working/vision_studio\")\n","IMG_DIR = os.path.join(ROOT, \"images\")\n","DB_PATH = os.path.join(ROOT, \"vision_studio.db\")\n","os.makedirs(IMG_DIR, exist_ok=True)\n","def _now(): return datetime.datetime.now().isoformat(timespec=\"seconds\")\n","\n","# --------------------------------------------------------------------- edit registry\n","# Each edit = a prompt recipe + the region it touches + a default strength.\n","TEX = \", natural skin pores, visible realistic skin texture, subsurface sheen, detailed hyperrealistic skin, not airbrushed\"\n","NEGTEX = \"plastic skin, over-smoothed, airbrushed, waxy, blurry\"\n","EDITS = {\n","  \"natural_makeup\":  dict(region=\"face\",  strength=0.42, label=\"Natural everyday makeup\",\n","     prompt=\"soft natural makeup, light foundation, subtle blush, neutral eyeshadow, groomed brows, tinted lips, fresh dewy skin\"+TEX,\n","     neg=\"heavy makeup, tacky, harsh, clown makeup, \"+NEGTEX+\", different person\"),\n","  \"smokey_glam\":     dict(region=\"face\",  strength=0.5,  label=\"Smokey glam (eyes + lips + blush)\",\n","     prompt=\"elegant smokey eye makeup, blended dark eyeshadow, smudged liner, long lashes, mauve nude lipstick, soft rosy blush, glam\"+TEX,\n","     neg=\"clown makeup, harsh, changed eye color, \"+NEGTEX+\", different person\"),\n","  \"double_eyelid\":   dict(region=\"eyes\",  strength=0.5,  label=\"Double eyelid surgery (hooded eyes)\",\n","     prompt=\"double eyelid, defined upper eyelid crease, less hooded eyes, brighter more open eyes, natural\"+TEX,\n","     neg=\"changed eye color, different person, distorted, \"+NEGTEX),\n","  \"remove_makeup\":   dict(region=\"face\",  strength=0.55, label=\"Remove makeup (whole face)\",\n","     prompt=\"completely bare face, no makeup anywhere, no eyeshadow no eyeliner no mascara, no lipstick natural pale lips, no blush, clean fresh face\"+TEX,\n","     neg=\"makeup, lipstick, eyeshadow, eyeliner, blush, mascara, \"+NEGTEX+\", different person\"),\n","  \"clear_skin\":      dict(region=\"face\",  strength=0.55, label=\"Clear skin (whole face)\",\n","     prompt=\"clear healthy skin across the whole face, acne removed, blemishes and pimples gone, even smooth complexion, keeps natural pores and texture\"+TEX,\n","     neg=\"acne, pimples, blemishes, red spots, plastic skin, airbrushed, different person\"),\n","  \"youthful\":        dict(region=\"face\",  strength=0.5,  label=\"Youthful (de-age, fox eyes)\",\n","     prompt=\"youthful refreshed face, no smile lines, no under-eye bags, subtly lifted fox-eyes, brighter rested eyes, firm cheeks, natural same person\"+TEX,\n","     neg=\"different person, feminized, \"+NEGTEX),\n","  \"lipstick\":        dict(region=\"lips\",  strength=0.5,  label=\"Lipstick (pick a shade)\",\n","     prompt=\"{shade} lipstick, smooth even application, defined lip line, natural lip shape, glossy realistic lips\",\n","     neg=\"smeared, uneven, overdrawn, different person\"),\n","  \"lip_filler\":      dict(region=\"lips\",  strength=0.5,  label=\"Lip filler (plump)\",\n","     prompt=\"fuller plumper juicy lips, natural lip filler, soft volume, hydrated glossy lips, balanced upper and lower lip, same person\",\n","     neg=\"overfilled, duck lips, distorted, different person\"),\n","  \"slimming\":        dict(region=\"face\",  strength=0.62, label=\"Face slimming (bone structure)\",\n","     prompt=\"noticeably slimmer narrower face, reduced cheek fat, visible cheekbones and defined bone structure, sharp sculpted jawline, slim V-shape face\"+TEX,\n","     neg=\"wide round face, chubby cheeks, \"+NEGTEX+\", different person\"),\n","  \"double_chin\":     dict(region=\"lower_face\", strength=0.6, label=\"Remove double chin\",\n","     prompt=\"double chin fully removed, slim tight defined neck and under-chin, sharp jawline, no submental fat, sculpted lower face, same person same gender\"+TEX,\n","     neg=\"double chin, fat neck, feminized, changed gender, \"+NEGTEX+\", different person\"),\n","  \"rhinoplasty\":     dict(region=\"nose\",  strength=0.44, label=\"Rhinoplasty\",\n","     prompt=\"smaller thinner refined nose, straight bridge, refined tip\"+TEX,\n","     neg=\"bigger nose, distorted, different person\"),\n","  \"add_beard\":       dict(region=\"lower_face\", strength=0.55, label=\"Add beard\",\n","     prompt=\"full natural beard, stubble, facial hair, well groomed\"+TEX, neg=\"clean shaven, patchy, different person\"),\n","  \"remove_beard\":    dict(region=\"lower_face\", strength=0.55, label=\"Remove beard (clean shave)\",\n","     prompt=\"clean shaven smooth jaw, no facial hair, natural skin with pores and stubble shadow\"+TEX,\n","     neg=\"beard, stubble, \"+NEGTEX+\", different person\"),\n","}\n","\n","LIP_SHADES = [\"classic red\",\"rosy pink\",\"nude beige\",\"berry\",\"coral\",\"mauve\",\"brick\",\"peach nude\"]\n","SHADE_BY_TONE = {\"light\":[\"rosy pink\",\"coral\",\"nude beige\"], \"medium\":[\"mauve\",\"brick\",\"classic red\"],\n","                 \"tan\":[\"brick\",\"berry\",\"coral\"], \"deep\":[\"berry\",\"classic red\",\"brick\"]}\n","\n","PROACTIVE_CONCERNS = [\"clear_skin\",\"botox\",\"slimming\"]\n","\n","# --------------------------------------------------------------------- store (SQLite + optional Supabase)\n","class Store:\n","    def __init__(self, db_path=DB_PATH):\n","        self.db_path = db_path; self._init()\n","        self.sb = self._connect_supabase()   # None unless env creds are present\n","    def _c(self):\n","        con = sqlite3.connect(self.db_path); con.row_factory = sqlite3.Row; return con\n","    def _init(self):\n","        con=self._c(); con.executescript(\"\"\"\n","        CREATE TABLE IF NOT EXISTS sources(source_id TEXT PRIMARY KEY, dataset TEXT, celeba_file TEXT,\n","          source_path TEXT, orig_path TEXT, attrs TEXT, created_at TEXT);\n","        CREATE TABLE IF NOT EXISTS sessions(session_id TEXT PRIMARY KEY, source_id TEXT, mode TEXT,\n","          edit_type TEXT, goal TEXT, username TEXT, created_at TEXT, best_iter_id INTEGER,\n","          n_iters INTEGER DEFAULT 0, status TEXT);\n","        CREATE TABLE IF NOT EXISTS iterations(iter_id INTEGER PRIMARY KEY AUTOINCREMENT, session_id TEXT,\n","          iter_num INTEGER, image_path TEXT, cloud_url TEXT, mask_path TEXT, prompt TEXT, negative TEXT,\n","          edit_type TEXT, model TEXT, strength REAL, seed INTEGER, realism REAL, identity REAL,\n","          ssim_locality REAL, drift REAL, vlm_score REAL, human_score REAL, scored_by TEXT, orig_path TEXT, skin_tone TEXT, lip_shade TEXT, accepted INTEGER, created_at TEXT);\n","        CREATE TABLE IF NOT EXISTS users(username TEXT PRIMARY KEY, google_sub TEXT, shuriken INTEGER DEFAULT 5,\n","          streak INTEGER DEFAULT 0, level INTEGER DEFAULT 1, is_admin INTEGER DEFAULT 0, created_at TEXT);\n","        CREATE TABLE IF NOT EXISTS model_usage(username TEXT, model TEXT, uses_today INTEGER DEFAULT 0,\n","          day TEXT, PRIMARY KEY(username,model));\n","        CREATE TABLE IF NOT EXISTS votes(vote_id INTEGER PRIMARY KEY AUTOINCREMENT, iter_id INTEGER,\n","          username TEXT, looks_real INTEGER, created_at TEXT);\n","        CREATE TABLE IF NOT EXISTS cscores(cs_id INTEGER PRIMARY KEY AUTOINCREMENT, iter_id INTEGER,\n","          username TEXT, score REAL, created_at TEXT);\n","        CREATE INDEX IF NOT EXISTS ix_it_sess ON iterations(session_id);\n","        \"\"\"); con.commit(); con.close()\n","    def _connect_supabase(self):\n","        url=os.environ.get(\"SUPABASE_URL\"); key=os.environ.get(\"SUPABASE_KEY\")\n","        if not (url and key): return None\n","        try:\n","            from supabase import create_client\n","            sb=create_client(url,key); print(\"Supabase: connected (cloud mirror ON)\"); return sb\n","        except Exception as e:\n","            print(\"Supabase: not available, staying local -\", str(e)[:60]); return None\n","    def _mirror(self, table, row):\n","        if not self.sb: return\n","        import math\n","        clean={k:(None if (isinstance(v,float) and (math.isnan(v) or math.isinf(v))) else v) for k,v in row.items()}\n","        try: self.sb.table(table).upsert(clean).execute()\n","        except Exception as e: print(\"cloud mirror skipped:\", str(e)[:50])\n","    def _upload(self, local_path):\n","        if not self.sb: return None\n","        try:\n","            with open(local_path,\"rb\") as f:\n","                key=os.path.basename(local_path)\n","                self.sb.storage.from_(\"iterations\").upload(key,f,{\"upsert\":\"true\"})\n","                return self.sb.storage.from_(\"iterations\").get_public_url(key)\n","        except Exception: return None\n","\n","    # ---- writes ----\n","    def new_source(self, dataset, celeba_file, attrs, img, source_path=None):\n","        sid=hashlib.md5((str(celeba_file)+_now()+str(np.random.rand())).encode()).hexdigest()[:12]\n","        orig=os.path.join(IMG_DIR, f\"{sid}_orig.png\"); img.convert(\"RGB\").save(orig)   # keep the original to compare later\n","        row=dict(source_id=sid,dataset=dataset,celeba_file=str(celeba_file),\n","                 source_path=str(source_path) if source_path else \"\",orig_path=orig,\n","                 attrs=json.dumps(attrs),created_at=_now())\n","        con=self._c(); con.execute(\"INSERT OR REPLACE INTO sources VALUES(:source_id,:dataset,:celeba_file,\"\n","            \":source_path,:orig_path,:attrs,:created_at)\",row)\n","        con.commit(); con.close(); self._mirror(\"sources\",row); return sid\n","    def orig_path(self, sid): return os.path.join(IMG_DIR, f\"{sid}_orig.png\")\n","    def new_session(self, source_id, mode, edit_type, goal, username):\n","        sid=hashlib.md5((source_id+_now()+edit_type+str(np.random.rand())).encode()).hexdigest()[:12]\n","        row=dict(session_id=sid,source_id=source_id,mode=mode,edit_type=edit_type,goal=goal,\n","                 username=username,created_at=_now(),best_iter_id=None,n_iters=0,status=\"open\")\n","        con=self._c(); con.execute(\"INSERT INTO sessions VALUES(:session_id,:source_id,:mode,:edit_type,:goal,\"\n","            \":username,:created_at,:best_iter_id,:n_iters,:status)\",row); con.commit(); con.close()\n","        self._mirror(\"sessions\",row); return sid\n","    def add_iteration(self, session_id, iter_num, image, mask, plan, meta, metrics, accepted, vlm=None, human=None, scored_by=None, orig_path=None, skin_tone=None, lip_shade=None):\n","        base=f\"{session_id}_{iter_num:02d}\"; ipath=os.path.join(IMG_DIR,base+\".png\"); mpath=os.path.join(IMG_DIR,base+\"_m.png\")\n","        image.save(ipath); mask.convert(\"L\").save(mpath); url=self._upload(ipath)\n","        con=self._c(); cur=con.execute(\"\"\"INSERT INTO iterations(session_id,iter_num,image_path,cloud_url,mask_path,\n","          prompt,negative,edit_type,model,strength,seed,realism,identity,ssim_locality,drift,vlm_score,human_score,scored_by,orig_path,skin_tone,lip_shade,accepted,created_at)\n","          VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)\"\"\",\n","          (session_id,iter_num,ipath,url,mpath,plan[\"prompt\"],plan[\"neg\"],plan[\"edit_type\"],meta[\"model\"],\n","           meta[\"strength\"],meta[\"seed\"],metrics[\"realism\"],metrics[\"identity\"],metrics[\"ssim_locality\"],\n","           metrics[\"drift\"],vlm,human,scored_by,orig_path,skin_tone,lip_shade,int(accepted),_now()))\n","        iid=cur.lastrowid; con.execute(\"UPDATE sessions SET n_iters=n_iters+1 WHERE session_id=?\",(session_id,))\n","        if accepted: con.execute(\"UPDATE sessions SET best_iter_id=?,status='accepted' WHERE session_id=?\",(iid,session_id))\n","        con.commit(); con.close()\n","        self._mirror(\"iterations\",{\"iter_id\":iid,\"session_id\":session_id,\"iter_num\":iter_num,\"cloud_url\":url,\n","            \"edit_type\":plan[\"edit_type\"],\"realism\":metrics[\"realism\"],\"identity\":metrics[\"identity\"],\n","            \"vlm_score\":vlm,\"human_score\":human,\"scored_by\":scored_by,\"accepted\":int(accepted)}); return iid\n","\n","    def update_score(self, iter_id, human_score, scored_by):\n","        \"\"\"Admin/human scores a stored iteration in the review feed.\"\"\"\n","        ok = 1 if human_score>=4 else 0\n","        con=self._c(); con.execute(\"UPDATE iterations SET human_score=?, scored_by=?, accepted=? WHERE iter_id=?\",\n","                                    (float(human_score), scored_by, ok, iter_id)); con.commit(); con.close()\n","        self._mirror(\"iterations\", {\"iter_id\":iter_id,\"human_score\":float(human_score),\"scored_by\":scored_by,\"accepted\":ok})\n","\n","    # ---- users / gamification (shuriken) ----\n","    def ensure_user(self, username, is_admin=False, google_sub=None):\n","        con=self._c(); u=con.execute(\"SELECT * FROM users WHERE username=?\",(username,)).fetchone()\n","        if not u:\n","            con.execute(\"INSERT INTO users(username,google_sub,shuriken,is_admin,created_at) VALUES(?,?,?,?,?)\",\n","                        (username,google_sub,5,1 if is_admin else 0,_now()))\n","        elif is_admin and not u[\"is_admin\"]:\n","            con.execute(\"UPDATE users SET is_admin=1 WHERE username=?\",(username,))\n","        con.commit(); con.close()\n","    def shuriken(self, username):\n","        con=self._c(); u=con.execute(\"SELECT shuriken,is_admin FROM users WHERE username=?\",(username,)).fetchone(); con.close()\n","        if not u: return 5, False\n","        return u[\"shuriken\"], bool(u[\"is_admin\"])\n","    def add_shuriken(self, username, n):\n","        con=self._c(); con.execute(\"UPDATE users SET shuriken=shuriken+? WHERE username=?\",(n,username)); con.commit(); con.close()\n","    def spend_shuriken(self, username, n=1):\n","        \"\"\"Admins are unlimited. Normal users spend; returns (allowed, remaining).\"\"\"\n","        bal, is_admin = self.shuriken(username)\n","        if is_admin: return True, \"∞\"\n","        if bal < n:  return False, bal\n","        con=self._c(); con.execute(\"UPDATE users SET shuriken=shuriken-? WHERE username=?\",(n,username)); con.commit(); con.close()\n","        return True, bal-n\n","    def add_vote(self, iter_id, username, looks_real):\n","        con=self._c(); con.execute(\"INSERT INTO votes(iter_id,username,looks_real,created_at) VALUES(?,?,?,?)\",\n","            (iter_id,username,int(looks_real),_now())); con.commit(); con.close()\n","\n","    # ---- view / clear the database ----\n","    def table_counts(self):\n","        con=self._c(); out={}\n","        for t in [\"sources\",\"sessions\",\"iterations\",\"users\",\"votes\"]:\n","            out[t]=con.execute(f\"SELECT COUNT(*) c FROM {t}\").fetchone()[\"c\"]\n","        con.close(); return out\n","    def preview(self, table=\"iterations\", n=10):\n","        con=self._c(); rows=con.execute(f\"SELECT * FROM {table} ORDER BY rowid DESC LIMIT ?\",(n,)).fetchall(); con.close()\n","        return [dict(r) for r in rows]\n","    def clear_all(self, keep_users=True):\n","        \"\"\"Wipe scoring data so the DB holds only your fresh human scores. Also clears Supabase mirror.\"\"\"\n","        con=self._c()\n","        for t in [\"iterations\",\"sessions\",\"sources\",\"votes\"]:\n","            con.execute(f\"DELETE FROM {t}\")\n","        if not keep_users: con.execute(\"DELETE FROM users\")\n","        con.commit(); con.close()\n","        if self.sb:\n","            for t in [\"iterations\",\"sessions\",\"sources\",\"votes\"]:\n","                try: self.sb.table(t).delete().neq(\"created_at\",\"\").execute()\n","                except Exception as e: print(\"cloud clear skipped\", t, str(e)[:40])\n","        return self.table_counts()\n","\n","\n","    # ---- community per-user scores + resume + training prep ----\n","    def import_from_csv(self, csv_path, images_root):\n","        \"\"\"Recover a previously exported batch (dataset.csv + images) back into the DB after a restart.\n","           Restores sources + iterations + human scores, grouped per source photo.\"\"\"\n","        import pandas as pd\n","        df=pd.read_csv(csv_path); seen={}\n","        for _,r in df.iterrows():\n","            sid=str(r.get(\"source_id\") or \"\"); celeba=str(r.get(\"celeba_file\") or \"\")\n","            if sid not in seen:\n","                op=os.path.join(images_root, str(r.get(\"original_file\",\"\")))\n","                img=Image.open(op).convert(\"RGB\") if os.path.exists(op) else Image.new(\"RGB\",(256,256),(200,200,200))\n","                seen[sid]=self.new_source(\"celeba\",celeba,{},img,source_path=celeba)\n","            real=seen[sid]\n","            ses=self.new_session(real,\"import\",str(r.get(\"edit_type\",\"\")),None,str(r.get(\"scored_by\") or \"admin\"))\n","            gp=os.path.join(images_root, str(r.get(\"generated_file\",\"\")))\n","            gimg=Image.open(gp).convert(\"RGB\") if os.path.exists(gp) else Image.new(\"RGB\",(256,256),(180,180,180))\n","            hs=r.get(\"human_score\"); hs=float(hs) if pd.notna(hs) else None\n","            self.add_iteration(ses,0,gimg,Image.new(\"L\",gimg.size,255),\n","                {\"prompt\":\"\",\"neg\":\"\",\"edit_type\":str(r.get(\"edit_type\",\"\"))},\n","                {\"model\":str(r.get(\"model\",\"realistic-vision\")),\"strength\":0.5,\"seed\":42},\n","                {\"realism\":float(r.get(\"realism\") or 0.7),\"identity\":float(r.get(\"identity\") or 0.9),\"ssim_locality\":0.97,\"drift\":0.01},\n","                (hs or 0)>=4, vlm=r.get(\"vlm_score\"), human=hs, scored_by=r.get(\"scored_by\"), orig_path=self.orig_path(real))\n","        return self.table_counts()\n","\n","    def add_community_score(self, iter_id, username, score):\n","        con=self._c(); con.execute(\"INSERT INTO cscores(iter_id,username,score,created_at) VALUES(?,?,?,?)\",\n","            (iter_id,username,float(score),_now())); con.commit(); con.close()\n","        self._mirror(\"cscores\",{\"iter_id\":iter_id,\"username\":username,\"score\":float(score)})\n","    def consensus(self, iter_id):\n","        \"\"\"Blend the admin human_score with all community scores -> everyone's opinion counts.\"\"\"\n","        con=self._c()\n","        h=con.execute(\"SELECT human_score FROM iterations WHERE iter_id=?\",(iter_id,)).fetchone()\n","        cs=con.execute(\"SELECT score FROM cscores WHERE iter_id=?\",(iter_id,)).fetchall(); con.close()\n","        vals=[h[\"human_score\"]] if h and h[\"human_score\"] is not None else []\n","        vals+=[r[\"score\"] for r in cs]\n","        return (round(sum(vals)/len(vals),2), len(vals)) if vals else (None,0)\n","    def done_celeba_files(self, extra_csv=None):\n","        \"\"\"Filenames already scored, from the DB and optionally an uploaded dataset.csv (after a restart).\"\"\"\n","        con=self._c()\n","        done={r[0] for r in con.execute(\n","            \"SELECT s.celeba_file FROM sources s JOIN sessions se ON se.source_id=s.source_id \"\n","            \"JOIN iterations it ON it.session_id=se.session_id WHERE it.human_score IS NOT NULL\").fetchall()}\n","        con.close()\n","        if extra_csv and os.path.exists(extra_csv):\n","            import pandas as pd\n","            try:\n","                df=pd.read_csv(extra_csv)\n","                col=next((c for c in df.columns if \"celeba\" in c.lower() or \"file\" in c.lower()), df.columns[0])\n","                done|={os.path.basename(str(x)) for x in df[col].dropna()}\n","            except Exception as e: print(\"done-csv read skipped:\",str(e)[:50])\n","        return done\n","    def training_groups(self, min_human=4.0):\n","        \"\"\"For the one-shot: per source photo, all iterations grouped, with the BEST (highest human) as target.\"\"\"\n","        con=self._c()\n","        rows=con.execute(\"\"\"SELECT s.source_id, s.orig_path, it.iter_id, it.image_path, it.edit_type,\n","            it.human_score, it.identity, it.realism FROM iterations it\n","            JOIN sessions se ON it.session_id=se.session_id JOIN sources s ON se.source_id=s.source_id\n","            WHERE it.image_path IS NOT NULL ORDER BY s.source_id, it.human_score DESC\"\"\").fetchall()\n","        con.close()\n","        groups={}\n","        for r in rows:\n","            r=dict(r); groups.setdefault(r[\"source_id\"],{\"orig\":r[\"orig_path\"],\"iters\":[]})[\"iters\"].append(r)\n","        out=[]\n","        for sid,g in groups.items():\n","            best=max(g[\"iters\"], key=lambda x:(x[\"human_score\"] or 0))\n","            out.append({\"source_id\":sid,\"orig\":g[\"orig\"],\"n_iters\":len(g[\"iters\"]),\n","                        \"best\":best,\"accepted\":(best[\"human_score\"] or 0)>=min_human,\"all\":g[\"iters\"]})\n","        return out\n","    # ---- reads / analytics ----\n","    def groups(self):\n","        con=self._c(); sess=con.execute(\"SELECT * FROM sessions ORDER BY created_at DESC\").fetchall(); out=[]\n","        for s in sess:\n","            its=con.execute(\"SELECT * FROM iterations WHERE session_id=? ORDER BY iter_num\",(s[\"session_id\"],)).fetchall()\n","            out.append({\"session\":dict(s),\"iterations\":[dict(x) for x in its]})\n","        con.close(); return out\n","    def stats(self):\n","        con=self._c()\n","        n_src=con.execute(\"SELECT COUNT(*) c FROM sources\").fetchone()[\"c\"]\n","        n_it =con.execute(\"SELECT COUNT(*) c FROM iterations\").fetchone()[\"c\"]\n","        acc  =con.execute(\"SELECT AVG(n_iters) a FROM sessions WHERE status='accepted'\").fetchone()[\"a\"]\n","        by   =con.execute(\"SELECT edit_type,COUNT(*) c,AVG(human_score) s FROM iterations GROUP BY edit_type\").fetchall()\n","        con.close()\n","        return {\"sources\":n_src,\"iterations\":n_it,\"avg_iters_to_accept\":round(acc,2) if acc else None,\n","                \"by_edit\":{r[\"edit_type\"]:{\"n\":r[\"c\"],\"avg_score\":round(r[\"s\"],2) if r[\"s\"] else None} for r in by}}\n","    def best_model(self, min_n=3):\n","        \"\"\"Model with the highest average human score — becomes the premium/limited one in gamification.\"\"\"\n","        con=self._c(); rows=con.execute(\"SELECT model, AVG(human_score) s, COUNT(*) n FROM iterations \"\n","            \"GROUP BY model HAVING n>=? ORDER BY s DESC\",(min_n,)).fetchall(); con.close()\n","        return (rows[0][\"model\"], round(rows[0][\"s\"],2)) if rows else (\"realistic-vision\", None)\n","    def model_leaderboard(self):\n","        con=self._c(); rows=con.execute(\"SELECT model, AVG(human_score) s, AVG(realism) r, COUNT(*) n \"\n","            \"FROM iterations GROUP BY model ORDER BY s DESC\").fetchall(); con.close()\n","        return [dict(x) for x in rows]\n","    def community_top(self, limit=12):\n","        con=self._c(); rows=con.execute(\"\"\"SELECT i.iter_id,i.image_path,i.edit_type,i.human_score,\n","            COALESCE(SUM(v.looks_real),0) up, COUNT(v.vote_id) votes FROM iterations i\n","            LEFT JOIN votes v ON v.iter_id=i.iter_id WHERE i.accepted=1\n","            GROUP BY i.iter_id ORDER BY i.human_score DESC, up DESC LIMIT ?\"\"\",(limit,)).fetchall()\n","        con.close(); return [dict(r) for r in rows]\n","    def export_csv(self, path=None):\n","        path=path or os.path.join(ROOT,\"iterations.csv\"); con=self._c()\n","        rows=con.execute(\"SELECT * FROM iterations\").fetchall(); con.close()\n","        if rows:\n","            with open(path,\"w\",newline=\"\") as f:\n","                w=csv.DictWriter(f,fieldnames=rows[0].keys()); w.writeheader()\n","                for r in rows: w.writerow(dict(r))\n","        return path\n","\n","    def export_zip(self, path=None):\n","        \"\"\"A ZIP with every iteration + its original, foldered per source photo, plus a CSV that\n","           references both filenames. This is your manual backup (independent of Supabase).\"\"\"\n","        import zipfile\n","        path=path or os.path.join(ROOT,\"vision_studio_dataset.zip\")\n","        con=self._c()\n","        rows=con.execute(\"\"\"SELECT it.*, s.celeba_file, s.source_path, s.source_id\n","                            FROM iterations it JOIN sessions se ON it.session_id=se.session_id\n","                            JOIN sources s ON se.source_id=s.source_id ORDER BY s.source_id, it.iter_id\"\"\").fetchall()\n","        con.close()\n","        manifest=[]\n","        with zipfile.ZipFile(path,\"w\",zipfile.ZIP_DEFLATED) as z:\n","            seen_orig=set()\n","            for r in rows:\n","                r=dict(r); sid=r[\"source_id\"]; folder=f\"{r.get('celeba_file') or sid}\".replace('/','_')\n","                folder=f\"sources/{sid}_{folder}\"\n","                # original once per source\n","                op=r.get(\"orig_path\")\n","                if op and os.path.exists(op) and sid not in seen_orig:\n","                    z.write(op, f\"{folder}/original.png\"); seen_orig.add(sid)\n","                # the generated/iterated image\n","                ip=r.get(\"image_path\"); gen_name=f\"iter{r['iter_num']}_{r['edit_type']}_{r['iter_id']}.png\"\n","                if ip and os.path.exists(ip): z.write(ip, f\"{folder}/{gen_name}\")\n","                manifest.append({\"source_id\":sid,\"celeba_file\":r.get(\"celeba_file\"),\n","                    \"original_file\":f\"{folder}/original.png\",\"generated_file\":f\"{folder}/{gen_name}\",\n","                    \"edit_type\":r[\"edit_type\"],\"model\":r[\"model\"],\"vlm_score\":r.get(\"vlm_score\"),\n","                    \"human_score\":r.get(\"human_score\"),\"scored_by\":r.get(\"scored_by\"),\n","                    \"identity\":r.get(\"identity\"),\"realism\":r.get(\"realism\"),\"accepted\":r.get(\"accepted\")})\n","            # manifest csv inside the zip\n","            import io\n","            buf=io.StringIO()\n","            if manifest:\n","                w=csv.DictWriter(buf,fieldnames=manifest[0].keys()); w.writeheader()\n","                for m in manifest: w.writerow(m)\n","            z.writestr(\"dataset.csv\", buf.getvalue())\n","        return path\n","\n","\n","# --------------------------------------------------------------------- concern severity (heuristics)\n","def detect_concerns(pil):\n","    \"\"\"Rule-based severity from image features (no trained model). Returns dict of 0..1 scores +\n","       a list of relevant concern tags, so the one-shot only suggests edits that actually apply.\"\"\"\n","    im=pil.convert(\"RGB\").resize((256,256)); a=np.array(im).astype(np.float32); g=cv2.cvtColor(a.astype(np.uint8),cv2.COLOR_RGB2GRAY)\n","    H,W=g.shape\n","    # wrinkles/texture: high-frequency energy in forehead + under-eye band\n","    band=g[int(H*0.15):int(H*0.55), int(W*0.2):int(W*0.8)]\n","    tex=float(cv2.Laplacian(band,cv2.CV_64F).var())\n","    wrinkle=max(0.0,min(1.0,(tex-70)/220))            # onset ~70; severe -> near 1.0\n","    # acne/blemish: redness + local color variance on cheeks\n","    cheeks=a[int(H*0.45):int(H*0.75), :]\n","    R,Gc,B=cheeks[:,:,0],cheeks[:,:,1],cheeks[:,:,2]\n","    redness=float(np.mean((R-(Gc+B)/2).clip(0,None)))\n","    spot=float(cv2.Laplacian(cv2.cvtColor(cheeks.astype(np.uint8),cv2.COLOR_RGB2GRAY),cv2.CV_64F).var())\n","    red_blur=cv2.GaussianBlur((R-(Gc+B)/2).astype(np.float32),(0,0),6)\n","    spottiness=float(np.mean(np.abs((R-(Gc+B)/2)-red_blur)))   # local deviations = spots, not skin tone\n","    acne=max(0.0,min(1.0,(spottiness-5)/14))          # onset ~5; severe acne -> near 1.0\n","    # face fullness: approximate; skip if skin covers most of the frame (flat/no background)\n","    skin=((R>95)&(Gc>40)&(B>20)&(R>B))\n","    ys,xs=np.where(skin); fat=0.0\n","    if len(xs)>500 and (xs.max()-xs.min())>30:\n","        w=xs.max()-xs.min(); h=ys.max()-ys.min(); ratio=w/max(1,h); cov=len(xs)/(cheeks.shape[0]*cheeks.shape[1])\n","        if cov<0.9: fat=max(0.0,min(1.0,(ratio-0.86)/0.24))\n","    tags=[]\n","    if wrinkle>0.3: tags.append(\"wrinkles/aging\")\n","    if acne>0.3:    tags.append(\"acne/blemishes\")\n","    if fat>0.35:     tags.append(\"full face\")\n","    return {\"wrinkle\":round(wrinkle,2),\"acne\":round(acne,2),\"fat\":round(fat,2),\"tags\":tags}\n","\n","def concern_edits(pil, gender):\n","    \"\"\"Pick candidate edits that actually apply to THIS face (gender + detected severity).\"\"\"\n","    c=detect_concerns(pil); cand=[]\n","    if c[\"acne\"]>0.4:    cand.append(\"clear_skin\")\n","    if c[\"wrinkle\"]>0.35: cand.append(\"youthful\")\n","    if c[\"fat\"]>0.5:     cand.append(\"slimming\")\n","    if gender==\"Man\":\n","        cand += [e for e in [\"add_beard\",\"remove_beard\"] if e not in cand]\n","    else:\n","        cand += [e for e in [\"lipstick\",\"smokey_glam\",\"lip_filler\"] if e not in cand]\n","    # always keep at least a couple of universally-flattering options\n","    # universal fallbacks are only ones that ALWAYS apply (makeup / grooming), never the gated ones\n","    universal = [\"add_beard\",\"remove_beard\"] if gender==\"Man\" else [\"lipstick\",\"smokey_glam\",\"lip_filler\"]\n","    for e in universal:\n","        if e not in cand and len(cand)<3: cand.append(e)\n","    return cand[:4], c\n","\n","# --------------------------------------------------------------------- skin tone + shade learning\n","def detect_skin_tone(pil):\n","    \"\"\"Rough skin-tone bucket from the central face region (no GPU). Returns light/medium/tan/deep.\"\"\"\n","    im=pil.convert(\"RGB\").resize((128,128)); a=np.array(im)\n","    cx,cy=64,72; patch=a[cy-18:cy+18, cx-18:cx+18].reshape(-1,3)\n","    # keep skin-like pixels (R>G>B, not too dark/bright)\n","    m=(patch[:,0]>patch[:,1])&(patch[:,1]>=patch[:,2])&(patch[:,0]>40)&(patch[:,0]<245)\n","    skin=patch[m] if m.sum()>20 else patch\n","    lum=float(skin[:,0].mean()*0.299+skin[:,1].mean()*0.587+skin[:,2].mean()*0.114)\n","    return \"light\" if lum>190 else \"medium\" if lum>150 else \"tan\" if lum>110 else \"deep\"\n","\n","def recommend_shade(store, skin_tone):\n","    \"\"\"Prefer the shade real people scored highest for this tone; else the sensible default.\"\"\"\n","    con=store._c()\n","    rows=con.execute(\"\"\"SELECT lip_shade, AVG(human_score) s, COUNT(*) n FROM iterations\n","        WHERE skin_tone=? AND lip_shade IS NOT NULL AND human_score IS NOT NULL\n","        GROUP BY lip_shade HAVING n>=2 ORDER BY s DESC\"\"\",(skin_tone,)).fetchall()\n","    con.close()\n","    if rows: return rows[0][\"lip_shade\"], f\"learned from {rows[0]['n']} ratings\"\n","    d=SHADE_BY_TONE.get(skin_tone,[\"rosy pink\"]); return d[0], \"starting suggestion (no data yet)\"\n","\n","# --------------------------------------------------------------------- ssim (for one-shot merge)\n","def ssim_score(path_a, path_b):\n","    from skimage.metrics import structural_similarity as ssim\n","    a=np.array(Image.open(path_a).convert(\"L\").resize((256,256)))\n","    b=np.array(Image.open(path_b).convert(\"L\").resize((256,256)))\n","    return float(ssim(a,b))\n","\n","def merge_iterations(group):\n","    \"\"\"Choose the training target from a source's iterations: highest human score, and among ties the one\n","       that best preserves the original (highest SSIM to original) — that's the identity-safe 'merge'.\"\"\"\n","    iters=group[\"all\"]; best_h=max((i[\"human_score\"] or 0) for i in iters)\n","    top=[i for i in iters if (i[\"human_score\"] or 0)==best_h]\n","    if len(top)>1 and group.get(\"orig\") and os.path.exists(group[\"orig\"]):\n","        top.sort(key=lambda i: ssim_score(group[\"orig\"], i[\"image_path\"]) if os.path.exists(i[\"image_path\"]) else 0, reverse=True)\n","    return {\"target\": top[0], \"human\": best_h, \"n_iters\": len(iters),\n","            \"edit_type\": top[0][\"edit_type\"], \"source_id\": group[\"source_id\"]}\n","\n","# --------------------------------------------------------------------- balanced CelebA sampler\n","def attrs_from_caption(cap):\n","    \"\"\"CelebA-small has captions, not attribute flags. Derive light Male/Young signals from the\n","       caption text so we can still show the demographic-balance graph (rebuts the JCM 2023 bias).\"\"\"\n","    c=(cap or \"\").lower()\n","    male  = 1 if any(w in c for w in [\" man\",\"male\",\" he \",\" his \",\"gentleman\",\" boy\"]) else \\\n","           -1 if any(w in c for w in [\"woman\",\"female\",\" she \",\" her \",\" lady\",\" girl\"]) else 0\n","    young = 1 if any(w in c for w in [\"young\",\"youth\"]) else \\\n","           -1 if any(w in c for w in [\" old\",\"elderly\",\"aged\",\"senior\",\"wrinkle\"]) else 0\n","    return {\"Male\":male, \"Young\":young}\n","\n","def load_celeba_small(images_dir, captions_csv=None, n=1500):\n","    \"\"\"Return up to n UNIQUE photos (one at a time), each as (path, PIL image, attrs-from-caption).\"\"\"\n","    files = sorted(glob.glob(os.path.join(images_dir, \"*.jpg\")) + glob.glob(os.path.join(images_dir, \"*.png\")))\n","    caps = {}\n","    if captions_csv and os.path.exists(captions_csv):\n","        import pandas as pd\n","        df = pd.read_csv(captions_csv)\n","        fcol = next((c for c in df.columns if any(k in c.lower() for k in [\"image\",\"file\",\"name\",\"id\"])), df.columns[0])\n","        ccol = next((c for c in df.columns if \"cap\" in c.lower() or \"text\" in c.lower()), df.columns[-1])\n","        for _,r in df.iterrows(): caps[os.path.basename(str(r[fcol]))] = str(r[ccol])\n","    out=[]\n","    for f in files[:n]:\n","        try:\n","            img=Image.open(f).convert(\"RGB\")\n","            out.append((f, img, attrs_from_caption(caps.get(os.path.basename(f),\"\"))))\n","        except Exception: pass\n","    return out\n","\n","def balanced_celeba_sample(attr_df, n, balance_on=(\"Male\",\"Young\",\"Pale_Skin\")):\n","    \"\"\"Pick n rows spread across the balance attributes so the dataset isn't all young pale women\n","       (directly addresses the bias the JCM 2023 paper reported).\"\"\"\n","    import itertools, random\n","    cols=[c for c in balance_on if c in attr_df.columns]\n","    if not cols: return attr_df.sample(min(n,len(attr_df))).to_dict(\"records\")\n","    groups={}\n","    for combo in itertools.product([1,-1],repeat=len(cols)):\n","        mask=np.ones(len(attr_df),bool)\n","        for c,v in zip(cols,combo): mask&=(attr_df[c]==v).values\n","        sub=attr_df[mask]\n","        if len(sub): groups[combo]=sub\n","    per=max(1,n//max(1,len(groups))); picked=[]\n","    for sub in groups.values(): picked.append(sub.sample(min(per,len(sub))))\n","    import pandas as pd; out=pd.concat(picked)\n","    if len(out)<n:  # top up\n","        rest=attr_df.drop(out.index); out=pd.concat([out,rest.sample(min(n-len(out),len(rest)))])\n","    return out.head(n).to_dict(\"records\")\n","\n","# --------------------------------------------------------------------- iterate-and-store loop\n","def build_plan(edit_type, goal=None, shade=None):\n","    e=EDITS[edit_type]; g=(goal or \"\").strip()\n","    prompt=e[\"prompt\"].replace(\"{shade}\", shade or \"natural\")   # lip shade injection\n","    prompt=(g+\", \" if g else \"\")+prompt+\", photorealistic, natural skin texture, same person, preserve identity\"\n","    return {\"edit_type\":edit_type,\"region\":e[\"region\"],\"strength\":e[\"strength\"],\"seed\":42,\n","            \"prompt\":prompt,\"neg\":e[\"neg\"]+\", different person, distorted, blurry\",\"_iter\":0}\n","\n","def refine_plan(plan, metrics):\n","    \"\"\"Progressive: each attempt pushes further in the right direction so results keep improving.\"\"\"\n","    plan=dict(plan); it=plan.get(\"_iter\",0)+1\n","    if metrics[\"identity\"]<0.85:                       # drifting -> pull back, protect identity\n","        plan[\"strength\"]=max(0.30, plan[\"strength\"]-0.06); plan[\"prompt\"]+=\", same person, preserve identity\"\n","    else:                                              # not enough change -> push harder each attempt\n","        plan[\"strength\"]=min(0.82, plan[\"strength\"]+0.05*it)\n","    if metrics[\"realism\"]<0.62:\n","        plan[\"prompt\"]+=\", sharp focus, natural skin pores, realistic texture, high detail\"\n","    plan[\"seed\"]=int(plan.get(\"seed\",42))+it*137\n","    plan[\"_iter\"]=it; return plan\n","\n","def run_and_store(store, source_id, source_img, edit_type, generate, score_fn, mode=\"batch\",\n","                  goal=None, username=\"admin\", max_iter=1, target=4.0, human_rater=None, model=\"realistic-vision\"):\n","    \"\"\"Generate one edit, store it with a vlm auto-suggestion; human_score stays blank until scored.\n","       Returns (session_id, iter_id, image, mask, metrics, vlm_suggestion).\"\"\"\n","    sid=store.new_session(source_id, mode, edit_type, goal, username)\n","    plan=build_plan(edit_type, goal); plan[\"edit_type\"]=edit_type\n","    img, mask, meta = generate(source_img, plan, int(plan.get(\"seed\",42)), model)\n","    m = score_fn(source_img, img, mask)\n","    vlm = round(1+4*m[\"realism\"], 2)\n","    human = human_rater(img, mask, m) if human_rater else None\n","    ok = (human is not None and human>=target)\n","    iid = store.add_iteration(sid, 0, img, mask, plan, meta, m, ok, vlm=vlm, human=human,\n","                              scored_by=(username if human is not None else None),\n","                              orig_path=store.orig_path(source_id))\n","    return sid, iid, img, mask, m, vlm\n"]},{"cell_type":"code","execution_count":9,"id":"d525add5","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:43.786761Z","iopub.status.busy":"2026-07-13T10:20:43.786524Z","iopub.status.idle":"2026-07-13T10:20:43.853129Z","shell.execute_reply":"2026-07-13T10:20:43.852192Z"},"papermill":{"duration":0.075847,"end_time":"2026-07-13T10:20:43.854683+00:00","exception":false,"start_time":"2026-07-13T10:20:43.778836+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["store ready\n"]}],"source":["store=Store(); print(\"store ready\")"]},{"cell_type":"markdown","id":"2f035a33","metadata":{"papermill":{"duration":0.006461,"end_time":"2026-07-13T10:20:43.867725+00:00","exception":false,"start_time":"2026-07-13T10:20:43.861264+00:00","status":"completed"},"tags":[]},"source":["### Recover your scored dataset (skips if already loaded)"]},{"cell_type":"code","execution_count":10,"id":"5d17c586","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:20:43.881749Z","iopub.status.busy":"2026-07-13T10:20:43.88109Z","iopub.status.idle":"2026-07-13T10:28:49.284869Z","shell.execute_reply":"2026-07-13T10:28:49.283976Z"},"papermill":{"duration":485.41946,"end_time":"2026-07-13T10:28:49.293423+00:00","exception":false,"start_time":"2026-07-13T10:20:43.873963+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["recovering -> {'sources': 920, 'sessions': 1162, 'iterations': 1162, 'users': 0, 'votes': 0}\n","row counts: {'sources':