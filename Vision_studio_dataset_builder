float16 if DEVICE == \"cuda\" else torch.float32\n\nWORK   = pathlib.Path(\"/kaggle/working\")\nOUT    = WORK / \"consultation_outputs\"; OUT.mkdir(exist_ok=True, parents=True)\nRHINO_DIR = WORK / \"rhinoplasty_lora\"; RHINO_DIR.mkdir(exist_ok=True, parents=True)\nprint(\"Device:\", DEVICE, \"| torch\", torch.__version__)\n\n# ---- Procedure taxonomy (region to edit + surgery-specific realism tokens) ----\nPROCEDURES = {\n    \"Rhinoplasty (nose reshaping)\": dict(\n        region=\"nose\", strength=0.42, blend=1.0, use_reference=True, ip_scale=0.7,\n        keywords=[\"nose\",\"nasal\",\"rhino\",\"bridge\",\"hump\",\"tip\",\"nostril\",\"dorsal\"],\n        core=(\"smaller thinner nose, narrow slim nasal bridge, refined pointed nasal tip, \"\n              \"pinched narrower nostrils, straight nose without hump, delicate elegant small nose\")),\n    \"Double chin / neck slimming\": dict(\n        region=\"lower_face\", strength=0.54, blend=1.0, use_reference=False, ip_scale=0.0,\n        keywords=[\"double chin\",\"submental\",\"neck\",\"under chin\",\"chin fat\",\"jowl\",\"turkey neck\"],\n        core=(\"no double chin, slim tight under chin and jawline, defined slim neck, \"\n              \"sculpted lean lower face, reduced chin and neck fat\")),\n    \"Facelift / skin tightening\": dict(\n        region=\"jowls\", strength=0.46, blend=1.0, use_reference=False, ip_scale=0.0,\n        keywords=[\"facelift\",\"lift\",\"jowl\",\"sagging\",\"tighten\",\"firmer\",\"younger\",\"rejuven\",\"loose skin\"],\n        core=(\"tight lifted facial skin, firm toned jawline, lifted cheeks, reduced jowls and sagging, \"\n              \"smoothed nasolabial folds, taut youthful skin, natural facelift, same person younger\")),\n    \"Botox / wrinkle softening\": dict(\n        region=\"wrinkles\", strength=0.45, blend=1.0, use_reference=False, ip_scale=0.0,\n        keywords=[\"botox\",\"wrinkle\",\"forehead\",\"frown\",\"glabella\",\"crow\",\"smile line\",\"fine line\"],\n        core=(\"smooth youthful skin with natural pores, wrinkle lines removed, no forehead lines, \"\n              \"no frown lines, no crows feet, no under eye lines, firm fresh complexion\")),\n    \"Cheek / face slimming\": dict(\n        region=\"face\", strength=0.58, blend=1.0, use_reference=False, ip_scale=0.0,\n        keywords=[\"slim\",\"slimmer\",\"thinner\",\"buccal\",\"chubby\",\"round face\",\"cheek fat\",\"face fat\",\"narrow face\",\"lose weight\"],\n        core=(\"slim slender face, thinner narrower face shape, much less facial fat, \"\n              \"reduced chubby cheeks, sculpted high cheekbones, sharp defined jawline, slim V shape face\")),\n}\n\n# Sensible starting goal per procedure (UI resets to this when the procedure changes,\n# so a leftover sentence from another procedure never leaks into the prompt).\nDEFAULT_GOALS = {\n    \"Rhinoplasty (nose reshaping)\": \"reduce the dorsal hump and refine the nasal tip naturally\",\n    \"Double chin / neck slimming\":  \"remove the double chin and slim the under chin and neck\",\n    \"Facelift / skin tightening\":   \"lift and tighten the jawline and jowls for a natural younger look\",\n    \"Botox / wrinkle softening\":    \"smooth the forehead lines and soften the wrinkles\",\n    \"Cheek / face slimming\":        \"slim the face, reduce cheek fat and define the jawline\",\n}\n\n# Data-derived defaults (these exact tokens dominate the score-5 rows in the recorded CSV);\n# Cell 3 replaces REALISM_ANCHOR with tokens actually mined from your highest-scored results.\nIDENTITY_ANCHOR = \"same person, same face structure, preserve identity, preserve facial features, natural skin tone\"\nREALISM_ANCHOR  = \"realistic portrait photo, photorealistic, natural skin texture, visible pores, realistic lighting, high detail\"\nNEGATIVE_ANCHOR = (\"different person, changed identity, distorted face, deformed, \"\n                   \"distorted teeth, extra teeth, crooked teeth, altered mouth, open mouth, \"\n                   \"changed eye color, asymmetric eyes, plastic waxy skin, overedited, \"\n                   \"cartoon, anime, illustration, CGI, blurry, low quality, watermark, text, logo\")\nDISCLAIMER = (\"AI generated cosmetic visualization only. Not medical advice or a guaranteed \"\n              \"surgical result. A licensed clinician must review any medical decision.\")\n\ndef classify_intent(text, procedure=None, return_hits=False):\n    if procedure and procedure in PROCEDURES:\n        return (procedure, 99) if return_hits else procedure\n    t = (text or \"\").lower()\n    best, hits = None, 0\n    for name, cfg in PROCEDURES.items():\n        h = sum(1 for kw in cfg[\"keywords\"] if kw in t)\n        if h > hits: best, hits = name, h\n    res = best or \"Rhinoplasty (nose reshaping)\"\n    return (res, hits) if return_hits else res\n\nprint(\"Cell 1 complete ·\", len(PROCEDURES), \"procedures\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:03:36.961087Z","iopub.execute_input":"2026-07-08T17:03:36.961548Z","iopub.status.idle":"2026-07-08T17:03:36.985594Z","shell.execute_reply.started":"2026-07-08T17:03:36.961514Z","shell.execute_reply":"2026-07-08T17:03:36.984881Z"}},"outputs":[{"name":"stdout","text":"Device: cuda | torch 2.10.0+cu128\nCell 1 complete · 5 procedures\n","output_type":"stream"}],"execution_count":2},{"id":"5df6aeb3","cell_type":"code","source":"# ── Cell 2 · Locate & load the four datasets (all optional / graceful) ──\ndef first_existing(paths):\n    for p in paths:\n        if p and os.path.exists(p): return p\n    return None\n\n# (1) Recorded Vision-Studio CSV — the file that has your prompts + realism scores.\n# We DON'T just grab any .csv (other datasets ship their own csvs); we peek at each\n# candidate's header and only accept one that actually has a prompt + score column.\nimport pandas as _pd\n_PROMPT_HINTS = [\"refined_prompt\",\"final_prompt\",\"optimized_prompt\",\"edited_prompt\",\"prompt\"]\n_SCORE_HINTS  = [\"realism_score\",\"realism\",\"human_score\",\"quality_score\",\"rating\",\"score\"]\ndef _looks_like_results(path):\n    try:\n        cols = [str(c).strip().lower() for c in _pd.read_csv(path, nrows=0).columns]\n    except Exception:\n        return False\n    has_prompt = any(any(h in c for h in _PROMPT_HINTS) for c in cols)\n    has_score  = any(any(h in c for h in _SCORE_HINTS)  for c in cols)\n    return has_prompt and has_score\n\n# Candidates, best-named first, then every csv under inputs/working as a last resort.\n_cands = (glob.glob(\"/kaggle/input/**/*vision*studio*.csv\", recursive=True)\n          + glob.glob(\"/kaggle/input/**/*result*.csv\", recursive=True)\n          + [\"/kaggle/working/june 5th vision studio data.csv\"]\n          + glob.glob(\"/kaggle/working/*.csv\")\n          + glob.glob(\"/kaggle/input/**/*.csv\", recursive=True))\n_seen, CSV_PATH = set(), None\nfor _p in _cands:\n    if _p in _seen or not os.path.exists(_p): continue\n    _seen.add(_p)\n    if _looks_like_results(_p): CSV_PATH = _p; break\n\nif CSV_PATH:\n    print(\"Recorded CSV :\", CSV_PATH)\nelse:\n    print(\"Recorded CSV : NOT FOUND — no csv with a prompt+score column was located.\")\n    _all = [p for p in _cands if os.path.exists(p)]\n    if _all:\n        print(\"  CSVs I did see (none matched):\")\n        for _p in _all[:10]: print(\"   -\", _p)\n        print(\"  → Add your 'june 5th vision studio data.csv' as an input, or drop it in /kaggle/working/.\")\n    else:\n        print(\"  → No csv files present at all. Add the results dataset or upload the file to /kaggle/working/.\")\n    print(\"  (The notebook still runs — it falls back to global model defaults.)\")\n\n# (2) CelebA-small source faces\nCELEBA_DIR = first_existing([\n    \"/kaggle/input/celeba-dataset-small/content/dataset_sample/images\",\n    *glob.glob(\"/kaggle/input/**/celeba*/**/images\", recursive=True),\n    *glob.glob(\"/kaggle/input/**/img_align_celeba*\", recursive=True),\n])\nCELEBA_IMAGES = []\nif CELEBA_DIR:\n    for e in (\"*.jpg\",\"*.jpeg\",\"*.png\"):\n        CELEBA_IMAGES += glob.glob(os.path.join(CELEBA_DIR, e))\nprint(\"CelebA faces :\", len(CELEBA_IMAGES), \"in\", CELEBA_DIR)\n\n# (3) Botox before/after\nBOTOX_ROOT = first_existing([\n    *glob.glob(\"/kaggle/input/**/botox*\", recursive=True),\n    *glob.glob(\"/kaggle/input/**/*before-and-after*\", recursive=True),\n])\ndef _imgs_under(root, keys):\n    out = []\n    if not root: return out\n    for e in (\"*.jpg\",\"*.jpeg\",\"*.png\",\"*.webp\"):\n        for f in glob.glob(os.path.join(root, \"**\", e), recursive=True):\n            if any(k in f.lower() for k in keys): out.append(f)\n    return out\nBOTOX_BEFORE = _imgs_under(BOTOX_ROOT, [\"before\"])\nBOTOX_AFTER  = _imgs_under(BOTOX_ROOT, [\"after\"])\nprint(\"Botox root   :\", BOTOX_ROOT, \"| before\", len(BOTOX_BEFORE), \"after\", len(BOTOX_AFTER))\n\n# (4) Rhinoplasty LoRA dataset (HF) — training IMAGES (not a trained LoRA), used as reference\nRHINO_IMAGES = []\ntry:\n    from huggingface_hub import snapshot_download\n    snapshot_download(repo_id=\"morlako/rhinoplasty_lora\", repo_type=\"dataset\",\n                      local_dir=str(RHINO_DIR), local_dir_use_symlinks=False)\n    for e in (\"*.jpg\",\"*.jpeg\",\"*.png\",\"*.webp\"):\n        RHINO_IMAGES += glob.glob(str(RHINO_DIR / \"**\" / e), recursive=True)\n    print(\"Rhinoplasty  :\", len(RHINO_IMAGES), \"reference images downloaded\")\nexcept Exception as e:\n    # also accept it pre-added as a Kaggle input\n    alt = first_existing([*glob.glob(\"/kaggle/input/**/rhinoplasty*\", recursive=True)])\n    if alt:\n        for ext in (\"*.jpg\",\"*.jpeg\",\"*.png\",\"*.webp\"):\n            RHINO_IMAGES += glob.glob(os.path.join(alt, \"**\", ext), recursive=True)\n    print(\"Rhinoplasty  :\", len(RHINO_IMAGES), \"reference images (download skipped:\", str(e)[:60], \")\")\n\n# (4b) Roboflow rhinoplasty CV — OPTIONAL nose-bbox prior. Set ROBOFLOW_API_KEY to enable.\nROBOFLOW_ANNOTS = None\ntry:\n    key = os.environ.get(\"ROBOFLOW_API_KEY\")\n    rf_local = first_existing([*glob.glob(\"/kaggle/input/**/rhinoplasty-*\", recursive=True)])\n    if key:\n        subprocess.run([sys.executable,\"-m\",\"pip\",\"install\",\"-q\",\"roboflow\"], check=False)\n        from roboflow import Roboflow\n        rf = Roboflow(api_key=key)\n        proj = rf.workspace(\"rhinoplasty\").project(\"rhinoplasty-f8lbn\")\n        ds = proj.version(1).download(\"yolov8\", location=str(WORK/\"roboflow_rhino\"))\n        ROBOFLOW_ANNOTS = ds.location\n    elif rf_local:\n        ROBOFLOW_ANNOTS = rf_local\n    print(\"Roboflow     :\", \"loaded\" if ROBOFLOW_ANNOTS else \"skipped (OPTIONAL — set ROBOFLOW_API_KEY to enable; not needed to run)\")\nexcept Exception as e:\n    print(\"Roboflow     : skipped ->\", str(e)[:80])\n\n# Reference gallery per procedure (before/after pairs shown in the UI)\ndef _load_thumbs(paths, n=8, size=(180,180)):\n    out=[]\n    for p in paths[:n]:\n        try: out.append(Image.open(p).convert(\"RGB\").resize(size))\n        except Exception: pass\n    return out\nREFERENCE_GALLERY = {\n    \"Rhinoplasty (nose reshaping)\": _load_thumbs(RHINO_IMAGES, 10),\n    \"Double chin / neck slimming\":  _load_thumbs(BOTOX_AFTER or BOTOX_BEFORE, 8),\n    \"Facelift / skin tightening\":   _load_thumbs((BOTOX_AFTER or BOTOX_BEFORE), 8),\n    \"Botox / wrinkle softening\":    _load_thumbs(BOTOX_AFTER or BOTOX_BEFORE, 8),\n    \"Cheek / face slimming\":        _load_thumbs(BOTOX_BEFORE or BOTOX_AFTER, 8),\n}\nprint(\"Cell 2 complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-08T17:03:41.785284Z","iopub.execute_input":"2026-07-08T17:03:41.785883Z","iopub.status.idle":"2026-07-08T17:03:50.249049Z","shell.execute_reply.started":"2026-07-08T17:03:41.785855Z","shell.execute_reply":"2026-07-08T17:03:50.248213Z"}},"outputs":[{"name":"stdout","text":"Recorded CSV : NOT FOUND — no csv with a prompt+score column w