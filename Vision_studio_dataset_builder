  else: print(\"need >=30 images scored >=3\")"]},{"cell_type":"markdown","id":"6aec394a","metadata":{"papermill":{"duration":0.006426,"end_time":"2026-07-13T10:29:32.733565+00:00","exception":false,"start_time":"2026-07-13T10:29:32.727139+00:00","status":"completed"},"tags":[]},"source":["### TRAIN 2 · SSIM merge — combine each face's iterations into the best target"]},{"cell_type":"code","execution_count":15,"id":"4170954c","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:29:32.748191Z","iopub.status.busy":"2026-07-13T10:29:32.746889Z","iopub.status.idle":"2026-07-13T10:29:32.763574Z","shell.execute_reply":"2026-07-13T10:29:32.762597Z"},"papermill":{"duration":0.025347,"end_time":"2026-07-13T10:29:32.765082+00:00","exception":false,"start_time":"2026-07-13T10:29:32.739735+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["SSIM-merged training targets (best iteration per face): 700\n"]}],"source":["if SKIP_TRAIN:\n","    PAIRS=[]; print(\"using saved brain - SSIM merge skipped\")\n","else:\n","    groups=store.training_groups(min_human=MIN_SCORE)\n","    PAIRS=[merge_iterations(g) for g in groups if g[\"all\"] and (g[\"best\"][\"human_score\"] or 0)>=MIN_SCORE]\n","    print(\"SSIM-merged training targets (best iteration per face):\",len(PAIRS))"]},{"cell_type":"markdown","id":"4beb3d3d","metadata":{"papermill":{"duration":0.006433,"end_time":"2026-07-13T10:29:32.777741+00:00","exception":false,"start_time":"2026-07-13T10:29:32.771308+00:00","status":"completed"},"tags":[]},"source":["### TRAIN 3 · preference policy per skin tone (≥3)"]},{"cell_type":"code","execution_count":16,"id":"a109a249","metadata":{"execution":{"iopub.execute_input":"2026-07-13T10:29:32.795172Z","iopub.status.busy":"2026-07-13T10:29:32.794608Z","iopub.status.idle":"2026-07-13T10:29:32.802994Z","shell.execute_reply":"2026-07-13T10:29:32.802293Z"},"papermill":{"duration":0.017077,"end_time":"2026-07-13T10:29:32.804652+00:00","except